.page {
  min-height: 100vh;
  padding: 24rpx 0 48rpx;
}

.hint {
  margin: 0 24rpx 24rpx;
  font-size: 24rpx;
  color: #5c4d3d;
  line-height: 1.65;
}

.stage {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0 80rpx;
}

.tube-wrap {
  position: relative;
  width: 200rpx;
  height: 320rpx;
}

.tube-wrap.shaking {
  animation: shake 0.4s ease-in-out infinite;
}

@keyframes shake {
  0% {
    transform: rotate(-6deg) translateX(0);
  }
  50% {
    transform: rotate(8deg) translateX(6rpx);
  }
  100% {
    transform: rotate(-6deg) translateX(0);
  }
}

.tube {
  position: absolute;
  left: 20rpx;
  right: 20rpx;
  bottom: 0;
  top: 40rpx;
  background: linear-gradient(180deg, #5d4037 0%, #3e2723 100%);
  border-radius: 20rpx 20rpx 12rpx 12rpx;
  box-shadow: inset 0 -20rpx 40rpx rgba(0, 0, 0, 0.35);
  border: 4rpx solid #8d6e63;
}

.sticks {
  position: absolute;
  left: 56rpx;
  right: 56rpx;
  top: 0;
  height: 120rpx;
  background: repeating-linear-gradient(
    90deg,
    #d7ccc8 0,
    #d7ccc8 8rpx,
    #a1887f 8rpx,
    #a1887f 16rpx
  );
  border-radius: 8rpx 8rpx 0 0;
}

.shake-tip {
  margin-top: 40rpx;
  font-size: 28rpx;
  color: #6d5d4a;
}

.sim-tip {
  margin-top: 24rpx;
  font-size: 24rpx;
  color: #78909c;
  text-decoration: underline;
  padding: 16rpx;
}

.result-card {
  margin: 0 24rpx;
}

.tier {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.lot-name {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #2c2416;
  margin-bottom: 24rpx;
}

/* 未揭晓：与箴言配图同尺寸的神秘黑金闪动封面 */
.sealed-mystery-outer {
  display: flex;
  justify-content: center;
  align-items: center;
  width: 100%;
  margin-bottom: 24rpx;
  box-sizing: border-box;
}

.sealed-mystery--hover {
  opacity: 0.88;
}

.sealed-mystery {
  position: relative;
  max-width: 100%;
  box-sizing: border-box;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow:
    0 12rpx 40rpx rgba(0, 0, 0, 0.35),
    0 0 0 1rpx rgba(201, 162, 39, 0.25);
}

.sealed-mystery-base {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(155deg, #050505 0%, #12100c 38%, #1c1810 72%, #0a0906 100%);
}

.sealed-mystery-veins {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  opacity: 0.55;
  background:
    radial-gradient(ellipse 90% 55% at 15% 25%, rgba(212, 175, 55, 0.35), transparent 52%),
    radial-gradient(ellipse 70% 50% at 88% 78%, rgba(180, 140, 50, 0.22), transparent 48%),
    radial-gradient(circle at 50% 50%, transparent 30%, rgba(0, 0, 0, 0.45) 100%);
}

.sealed-mystery-grid {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  opacity: 0.4;
  background-image:
    repeating-linear-gradient(
      -42deg,
      transparent,
      transparent 5rpx,
      rgba(201, 162, 39, 0.07) 5rpx,
      rgba(201, 162, 39, 0.07) 6rpx
    ),
    repeating-linear-gradient(
      38deg,
      transparent,
      transparent 5rpx,
      rgba(140, 110, 50, 0.06) 5rpx,
      rgba(140, 110, 50, 0.06) 6rpx
    );
}

.sealed-mystery-shine {
  position: absolute;
  top: 0;
  left: -60%;
  width: 55%;
  height: 100%;
  background: linear-gradient(
    100deg,
    transparent 0%,
    rgba(255, 236, 180, 0.08) 40%,
    rgba(255, 248, 220, 0.38) 50%,
    rgba(255, 236, 180, 0.1) 60%,
    transparent 100%
  );
  animation: sealed-mystery-sweep 2.6s ease-in-out infinite;
}

.sealed-mystery-spark {
  position: absolute;
  top: -20%;
  right: -30%;
  width: 70%;
  height: 70%;
  background: radial-gradient(
    circle,
    rgba(255, 230, 160, 0.2) 0%,
    rgba(201, 162, 39, 0.06) 35%,
    transparent 65%
  );
  animation: sealed-mystery-spark 3.4s ease-in-out infinite;
  pointer-events: none;
}

.sealed-mystery-frame {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  border-radius: 16rpx;
  border: 2rpx solid rgba(201, 162, 39, 0.45);
  box-shadow:
    inset 0 0 50rpx rgba(0, 0, 0, 0.55),
    0 0 28rpx rgba(201, 162, 39, 0.2);
  pointer-events: none;
  animation: sealed-mystery-glow 2.2s ease-in-out infinite;
}

.sealed-mystery-caption {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 12rpx 18rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  background: linear-gradient(180deg, transparent, rgba(0, 0, 0, 0.55));
  pointer-events: none;
}

.sealed-mystery-hint {
  font-size: 22rpx;
  letter-spacing: 12rpx;
  color: rgba(232, 212, 160, 0.85);
  text-shadow:
    0 0 16rpx rgba(201, 162, 39, 0.7),
    0 2rpx 8rpx rgba(0, 0, 0, 0.8);
  animation: sealed-mystery-hint-pulse 2s ease-in-out infinite;
}

@keyframes sealed-mystery-sweep {
  0% {
    transform: translateX(0) skewX(-6deg);
  }
  100% {
    transform: translateX(320%) skewX(-6deg);
  }
}

@keyframes sealed-mystery-spark {
  0%,
  100% {
    opacity: 0.35;
    transform: scale(1) translate(0, 0);
  }
  50% {
    opacity: 0.85;
    transform: scale(1.08) translate(-4%, 4%);
  }
}

@keyframes sealed-mystery-glow {
  0%,
  100% {
    border-color: rgba(201, 162, 39, 0.4);
    box-shadow:
      inset 0 0 50rpx rgba(0, 0, 0, 0.55),
      0 0 22rpx rgba(201, 162, 39, 0.18);
  }
  50% {
    border-color: rgba(255, 224, 130, 0.65);
    box-shadow:
      inset 0 0 40rpx rgba(0, 0, 0, 0.45),
      0 0 40rpx rgba(255, 215, 120, 0.35);
  }
}

@keyframes sealed-mystery-hint-pulse {
  0%,
  100% {
    opacity: 0.65;
  }
  50% {
    opacity: 1;
  }
}

.poem {
  display: block;
  font-size: 28rpx;
  color: #3e3428;
  line-height: 1.75;
  margin-bottom: 20rpx;
  font-style: italic;
}

/* 配图区域：约一屏高度的 1/5，介于诗句与释义之间 */
.lot-art-wrap {
  width: 100%;
  height: 20vh;
  min-height: 180rpx;
  max-height: 340rpx;
  margin: 8rpx 0 28rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #2c3e55;
  box-shadow: 0 10rpx 28rpx rgba(26, 35, 126, 0.15);
}

/* 宽高由 lotArtW/lotArtH（px）与内联 style 指定；配图使用 canvas-id 旧版接口绘制 */
.lot-art-canvas {
  display: block;
}

.block {
  margin-bottom: 24rpx;
}

.b-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #3949ab;
  margin-bottom: 8rpx;
}

.b-body {
  display: block;
  font-size: 26rpx;
  color: #4a4034;
  line-height: 1.65;
}

.adv-line {
  display: block;
  font-size: 26rpx;
  color: #3e3428;
  line-height: 1.7;
  margin-top: 14rpx;
  padding-left: 8rpx;
  border-left: 4rpx solid rgba(57, 73, 171, 0.35);
}

.share-btn::after {
  border: none;
}

.share-btn {
  width: 100%;
  margin-bottom: 16rpx;
}

.footer {
  padding: 24rpx 48rpx;
}
