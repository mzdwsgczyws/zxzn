<view class="page">
  <view class="ft-hero">
    <text class="ft-hero-title">趋势日历</text>
    <text class="ft-hero-sub">以日为轴，回看心象箴言的脉络走势。</text>
  </view>

  <!-- iOS：同上，示意图 canvas 避免放在 enhanced scroll-view 内 -->
  <scroll-view scroll-y="{{true}}" class="scroll">
    <view class="card intro">
      <text class="intro-p">按自然日展示抽签记录（同日多次取最后一次）。月历中有底色标记的为当日有签；长按该日可看诗文与释义。下方为历史记录的层级示意图（类比图示，仅供自察趣味，不作任何前瞻判断）。</text>
    </view>

    <view class="chart-card card">
      <text class="chart-title">趋势走势（示意）</text>
      <canvas
        canvas-id="fortuneCandleCanvas"
        class="candle-canvas"
        style="width: {{chartW}}px; height: {{chartH}}px;"
        disable-scroll="{{true}}"
      ></canvas>
    </view>

    <view class="card calendar-card">
      <text class="section-h">月历</text>
      <text class="section-tip">选择年月 · 长按有签之日查看释义</text>

      <view class="cal-toolbar">
        <picker mode="selector" range="{{yearLabels}}" value="{{yearPickIdx}}" bindchange="onYearPick">
          <view class="cal-picker">{{yearLabels[yearPickIdx]}}</view>
        </picker>
        <picker mode="selector" range="{{monthLabels}}" value="{{monthPickIdx}}" bindchange="onMonthPick">
          <view class="cal-picker">{{monthLabels[monthPickIdx]}}</view>
        </picker>
      </view>

      <empty-state
        wx:if="{{empty}}"
        icon="☽"
        title="尚无趋势数据"
        body="去首页抽取第一签，记录便会出现在这里"
        actionText="去首页"
        bind:action="goHome"
      />

      <block wx:if="{{!empty}}">
        <view class="cal-weekdays">
          <text class="cal-wd" wx:for="{{weekDayTitles}}" wx:key="*this">{{item}}</text>
        </view>
        <view class="cal-grid">
          <view
            wx:for="{{calCells}}"
            wx:key="cellKey"
            class="cal-cell cal-cell--{{item.type}} {{item.hasSign ? 'cal-cell--hit' : ''}} {{item.isWeekend ? 'cal-cell--wk' : ''}}"
          >
            <block wx:if="{{item.type === 'pad'}}"></block>
            <view
              wx:else
              class="cal-day-inner"
              bindlongpress="onCalLongPress"
              data-datestr="{{item.dateStr}}"
            >
              <text class="cal-day-num">{{item.day}}</text>
              <view wx:if="{{item.hasSign}}" class="cal-tier-dot" style="background-color: {{item.tierColor}};"></view>
              <text wx:if="{{item.hasSign}}" class="cal-mini-tier">{{item.tierLabel}}</text>
            </view>
          </view>
        </view>
      </block>
    </view>

    <text class="fine-print">仅供文化自察与行动参考；图示仅反映已抽取记录，不作前瞻推断。</text>
    <view class="scroll-pad"></view>
  </scroll-view>

  <view class="detail-mask" wx:if="{{detailVisible}}" catchtap="closeDetail">
    <view class="detail-sheet" catchtap="noop">
      <view class="detail-head">
        <text class="detail-date">{{detail.dateStr}}</text>
        <text class="detail-tier" style="color: {{detail.tierColor}};">{{detail.tierLabel}} · {{detail.title}}</text>
        <text class="detail-name">{{detail.name}}</text>
      </view>
      <scroll-view scroll-y="{{true}}" class="detail-body">
        <text class="detail-poem">{{detail.poem}}</text>
        <text class="detail-label">释义</text>
        <text class="detail-interpret">{{detail.interpret}}</text>
      </scroll-view>
      <button class="detail-close btn-primary" bindtap="closeDetail">关闭</button>
    </view>
  </view>
</view>
