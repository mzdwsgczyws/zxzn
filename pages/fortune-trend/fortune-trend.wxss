.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--dao-bg-page);
  box-sizing: border-box;
}

.ft-hero {
  flex-shrink: 0;
  padding: 28rpx 32rpx;
  background: linear-gradient(165deg, var(--dao-ritual-purple-a) 0%, var(--dao-ritual-purple-b) 100%);
}

.ft-hero-title {
  display: block;
  font-family: var(--dao-font-display);
  font-size: var(--dao-fs-hero);
  font-weight: 700;
  color: var(--dao-gold-pale);
  letter-spacing: 6rpx;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.35);
  animation: daoHeroIn 0.5s ease both;
}

.ft-hero-sub {
  display: block;
  font-size: var(--dao-fs-caption);
  color: rgba(232, 212, 168, 0.78);
  line-height: 1.5;
}

.scroll {
  flex: 1;
  min-height: 0;
  box-sizing: border-box;
}

.card {
  margin: 24rpx;
  padding: 28rpx 24rpx;
  background: var(--dao-bg-card);
  border-radius: 20rpx;
  border: 1rpx solid var(--dao-border-gold);
  box-shadow: 0 8rpx 28rpx var(--dao-shadow-purple);
  box-sizing: border-box;
}

.intro-p {
  font-size: 24rpx;
  line-height: 1.62;
  color: var(--dao-ink-muted);
}

.chart-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--dao-purple-deep);
  margin-bottom: 16rpx;
}

.candle-canvas {
  display: block;
  width: 100%;
  margin: 0 auto;
  border-radius: 12rpx;
  background: #faf7f0;
}

.calendar-card {
  padding-bottom: 32rpx;
}

.cal-toolbar {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  margin-bottom: 20rpx;
}

.cal-picker {
  min-width: 160rpx;
  padding: 14rpx 28rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--dao-purple-deep);
  background: rgba(57, 73, 171, 0.08);
  border-radius: 12rpx;
  border: 1rpx solid rgba(212, 175, 55, 0.28);
}

.cal-weekdays {
  display: flex;
  flex-direction: row;
  margin-bottom: 8rpx;
}

.cal-wd {
  flex: 1;
  text-align: center;
  font-size: 22rpx;
  color: var(--dao-ink-caption);
  padding: 8rpx 0;
}

.cal-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
}

.cal-cell {
  width: 14.285%;
  box-sizing: border-box;
  padding: 4rpx;
  min-height: 104rpx;
}

.cal-cell--pad {
  min-height: 104rpx;
}

.cal-cell--wk .cal-day-num {
  color: var(--dao-purple-mid);
}

.cal-cell--hit {
  background: rgba(212, 175, 55, 0.12);
  border-radius: 10rpx;
}

.cal-day-inner {
  height: 100%;
  min-height: 96rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding-top: 8rpx;
  border-radius: 8rpx;
  border: 1rpx solid rgba(109, 93, 74, 0.08);
}

.cal-cell--hit .cal-day-inner {
  border-color: rgba(212, 175, 55, 0.35);
}

.cal-day-num {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--dao-ink);
  line-height: 1.2;
}

.cal-tier-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-top: 6rpx;
}

.cal-mini-tier {
  font-size: 18rpx;
  color: var(--dao-ink-muted);
  margin-top: 4rpx;
  transform: scale(0.92);
}

.section-h {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--dao-purple-mid);
  margin-bottom: 8rpx;
}

.section-tip {
  display: block;
  font-size: 22rpx;
  color: var(--dao-ink-faint);
  margin-bottom: 20rpx;
}

.empty-box {
  padding: 48rpx 0;
  text-align: center;
}

.empty-t {
  font-size: 26rpx;
  color: var(--dao-ink-muted);
}

.fine-print {
  display: block;
  text-align: center;
  font-size: 20rpx;
  color: var(--dao-ink-caption);
  padding: 16rpx 32rpx 32rpx;
}

.scroll-pad {
  height: 48rpx;
}

.detail-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 2000;
  background: rgba(26, 35, 126, 0.38);
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.detail-sheet {
  width: 100%;
  max-height: 78vh;
  background: var(--dao-bg-card);
  border-radius: 24rpx 24rpx 0 0;
  padding: 28rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  border-top: 2rpx solid rgba(212, 175, 55, 0.35);
}

.detail-head {
  margin-bottom: 16rpx;
}

.detail-date {
  display: block;
  font-size: 24rpx;
  color: var(--dao-ink-muted);
  margin-bottom: 8rpx;
}

.detail-tier {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 6rpx;
}

.detail-name {
  display: block;
  font-size: 24rpx;
  color: var(--dao-ink-body);
}

.detail-body {
  max-height: 42vh;
  margin-bottom: 20rpx;
}

.detail-poem {
  display: block;
  font-size: 26rpx;
  line-height: 1.65;
  color: var(--dao-ink);
  margin-bottom: 20rpx;
  white-space: pre-wrap;
}

.detail-label {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--dao-purple-mid);
  margin-bottom: 8rpx;
}

.detail-interpret {
  display: block;
  font-size: 26rpx;
  line-height: 1.62;
  color: var(--dao-ink-body);
  white-space: pre-wrap;
}

.detail-close {
  width: 100%;
}
