.page {
  min-height: 100vh;
  background: linear-gradient(165deg, #1a1530 0%, #2a1f4a 40%, #f5f0e8 40.2%);
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

.hero {
  padding: 32rpx 32rpx 28rpx;
}

.hero-title {
  display: block;
  font-family: "DaoDisplay", "Songti SC", "STSong", serif;
  font-size: 40rpx;
  font-weight: 700;
  color: #e8d4a8;
  letter-spacing: 6rpx;
  margin-bottom: 8rpx;
}

.hero-sub {
  display: block;
  font-size: 24rpx;
  color: rgba(232, 212, 168, 0.7);
}

.card {
  margin: 16rpx 24rpx;
  padding: 28rpx 24rpx;
  background: rgba(255, 252, 248, 0.95);
  border-radius: 20rpx;
  border: 1rpx solid rgba(212, 175, 55, 0.2);
}

.empty-text, .invite-text {
  display: block;
  font-size: 28rpx;
  color: #6b5d4f;
  text-align: center;
  margin-bottom: 24rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #3a2e5c, #5a3e8c);
  color: #e8d4a8;
  border-radius: 999rpx;
  font-size: 28rpx;
  padding: 20rpx 48rpx;
  border: none;
  margin: 0 auto;
}

.btn-primary::after { border: none; }

.btn-ghost {
  background: transparent;
  color: #5a3e8c;
  border: 1rpx solid rgba(90, 62, 140, 0.35);
  border-radius: 999rpx;
  font-size: 26rpx;
  padding: 16rpx 40rpx;
  margin: 0 auto;
}

.btn-ghost::after { border: none; }

.share-btn {
  width: 80%;
}

.result-area {
  padding: 0 24rpx;
}

.score-ring {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 200rpx;
  height: 200rpx;
  margin: 32rpx auto;
  border-radius: 50%;
  background: linear-gradient(135deg, #1a1530, #2a1f4a);
  border: 4rpx solid rgba(212, 175, 55, 0.5);
  box-shadow: 0 0 32rpx rgba(212, 175, 55, 0.2);
}

.ring-num {
  font-size: 56rpx;
  font-weight: 700;
  color: #e8d4a8;
}

.ring-label {
  font-size: 24rpx;
  color: rgba(232, 212, 168, 0.7);
  margin-top: -4rpx;
}

.analysis-card, .tips-card {
  margin: 16rpx 0;
}

.sec-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #2a1f15;
  letter-spacing: 2rpx;
  margin-bottom: 12rpx;
}

.analysis-text {
  display: block;
  font-size: 26rpx;
  color: #4a4034;
  line-height: 1.65;
}

.tip-item {
  display: block;
  font-size: 26rpx;
  color: #4a4034;
  line-height: 1.65;
  margin-bottom: 8rpx;
}

.actions {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  margin-top: 32rpx;
}
