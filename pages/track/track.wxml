<view class="page dao-paper-bg">
  <loading-mask show="{{radarLoading}}" text="绘制雷达中" />
  <view class="card card-radar">
    <text class="title-lg">身心状态雷达</text>
    <text class="radar-lead">基于最近 7 天的记录生成，分数越高表示该方面负荷越重。金→木→水→火→土，详情见下方卡片。</text>
    <canvas
      canvas-id="fiveRadar"
      class="five-radar-canvas"
      disable-scroll="true"
    ></canvas>
    <view class="radar-legend" wx:if="{{hasPrevWeek}}">
      <view class="legend-item">
        <view class="legend-dot legend-dot--cur"></view>
        <text class="legend-text">本周</text>
      </view>
      <view class="legend-item">
        <view class="legend-dot legend-dot--prev"></view>
        <text class="legend-text">上周</text>
      </view>
    </view>
    <view class="radar-axis-panel">
      <view class="radar-axis-card" wx:for="{{fiveRows}}" wx:key="name">
        <view class="radar-axis-top">
          <text class="radar-axis-name">{{item.name}}</text>
          <text class="radar-axis-val">{{item.value}}</text>
        </view>
        <text class="radar-axis-tip">{{item.tip}}</text>
      </view>
    </view>
  </view>

  <view class="card">
    <text class="title-lg">今日记录</text>
    <text class="subtitle">每天花一分钟记录，帮你看清身心变化趋势（仅供参考，非医疗诊断）。</text>

    <text class="sec-title sec-title-inline">我最关注的方面（最多选 3 项）</text>
    <text class="chip-hint">选中后，相关建议会优先展示；不选则各方面均衡。</text>
    <view class="chip-row">
      <view
        class="chip {{item.on ? 'chip-on' : ''}}"
        wx:for="{{priorityChips}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="togglePriority"
      >{{item.label}}</view>
    </view>

    <view class="field">
      <text class="label">睡眠时长（小时）</text>
      <slider min="0" max="12" step="0.5" show-value value="{{form.sleepHours}}" bindchange="onSleep" />
    </view>
    <view class="field">
      <text class="label">今天精力恢复如何？（1 很差—5 很好）</text>
      <slider min="1" max="5" step="1" show-value value="{{form.recoveryScore}}" bindchange="onRecovery" />
    </view>
    <view class="field">
      <text class="label">今天累不累？（1 不累—5 很累）</text>
      <slider min="1" max="5" step="1" show-value value="{{form.drainScore}}" bindchange="onDrain" />
    </view>
    <view class="field">
      <text class="label">今天社交多吗？（0 没有—5 非常多）</text>
      <slider min="0" max="5" step="1" show-value value="{{form.socialLoad}}" bindchange="onSocial" />
    </view>
    <view class="field">
      <text class="label">今天主要在做什么？</text>
      <picker mode="selector" range="{{phaseLabels}}" value="{{phaseIndex}}" bindchange="onPhase">
        <view class="picker-val">{{phaseLabels[phaseIndex]}}</view>
      </picker>
    </view>
    <view class="field">
      <text class="label">今天有多少放空时间？（分钟）</text>
      <slider min="0" max="60" step="5" show-value value="{{form.blankMinutes}}" bindchange="onBlank" />
    </view>
    <view class="field row-switch">
      <text class="label">今天完成了一件小事</text>
      <switch checked="{{form.miniActionDone}}" bindchange="onMiniAction" />
    </view>

    <view class="divider-label">情绪与生活习惯</view>

    <view class="field">
      <text class="label">今天生气或烦躁了几次？</text>
      <slider min="0" max="20" step="1" show-value value="{{form.angerCount}}" bindchange="onAnger" />
    </view>
    <view class="field">
      <text class="label">反复想烦心事的次数</text>
      <slider min="0" max="30" step="1" show-value value="{{form.worryCount}}" bindchange="onWorry" />
    </view>
    <view class="field">
      <text class="label">刷手机/看视频时间（小时）</text>
      <slider min="0" max="16" step="0.5" show-value value="{{form.screenHours}}" bindchange="onScreen" />
    </view>
    <view class="field">
      <text class="label">步行（分钟）</text>
      <slider min="0" max="180" step="5" show-value value="{{form.walkMinutes}}" bindchange="onWalk" />
    </view>
    <view class="field">
      <text class="label">静坐或冥想（分钟）</text>
      <slider min="0" max="120" step="5" show-value value="{{form.calmMinutes}}" bindchange="onCalm" />
    </view>

    <button class="btn-primary save-btn" bindtap="saveToday">保存今日</button>
  </view>

  <view class="card" wx:if="{{weekChange && weekChange.hasData}}">
    <text class="title-lg">你的变化</text>
    <text class="subtitle">本周 vs 上周关键指标对比</text>
    <view class="wow-list">
      <view class="wow-item" wx:for="{{weekChange.changes}}" wx:key="key">
        <text class="wow-label">{{item.label}}</text>
        <text class="wow-diff {{item.improved ? 'wow-good' : 'wow-warn'}}">{{item.arrow}} {{item.text}}</text>
      </view>
    </view>
    <text class="wow-summary" wx:if="{{weekChange.summary}}">{{weekChange.summary}}</text>
  </view>

  <view class="card" wx:if="{{analysis}}">
    <text class="title-lg">{{analysis.title}}</text>
    <text class="para" wx:for="{{analysis.lines}}" wx:key="*this">{{item}}</text>

    <view class="focus-wrap" wx:if="{{analysis.modules}}">
      <text class="sec-title">状态总览</text>
      <text class="li sm">· 消耗与恢复：{{analysis.modules.yinyang.headline}}</text>
      <text class="li sm muted-li" wx:if="{{analysis.modules.yinyang.detail}}">{{analysis.modules.yinyang.detail}}</text>
      <text class="li sm">· {{analysis.modules.phase.headline}}：{{analysis.modules.phase.detail}}</text>
      <text class="li sm">· {{analysis.modules.wuwei.headline}}：{{analysis.modules.wuwei.detail}}</text>
    </view>

    <view class="focus-wrap" wx:if="{{analysis.recommendations.length}}">
      <text class="sec-title">改善建议</text>
      <view class="rec-card" wx:for="{{analysis.recommendations}}" wx:key="priority">
        <text class="rec-p">优先级 {{item.priority}}</text>
        <text class="rec-title">{{item.title}}</text>
        <text class="rec-block"><text class="rec-k">建议：</text>{{item.adjust}}</text>
        <text class="rec-block"><text class="rec-k">原因：</text>{{item.reason}}</text>
      </view>
    </view>

    <view class="focus-wrap" wx:if="{{analysis.focus.length}}">
      <text class="sec-title">今天可以做的一件事</text>
      <text class="li" wx:for="{{analysis.focus}}" wx:key="*this">· {{item}}</text>
    </view>
    <text class="muted tiny" wx:if="{{analysis.meta.disclaimer}}">{{analysis.meta.disclaimer}}</text>
    <view class="analysis-actions">
      <button class="btn-ghost" bindtap="runAnalysis">刷新分析</button>
      <button class="btn-ghost" bindtap="goReport">查看完整报告</button>
    </view>
  </view>

  <view class="card" wx:else>
    <text class="muted">保存记录后，点击下方按钮查看个性化的改善建议。</text>
    <button class="btn-primary" bindtap="runAnalysis">生成改善建议</button>
  </view>

  <view class="card" wx:if="{{records.length}}">
    <text class="title-lg">最近记录</text>
    <view class="row" wx:for="{{records}}" wx:key="date">
      <text class="d">{{item.date}}</text>
      <text class="r">睡{{item.sleepHours}}h · 恢{{item.recoveryScore != null ? item.recoveryScore : '—'}} · 耗{{item.drainScore != null ? item.drainScore : '—'}} · {{item.phaseShort}}</text>
    </view>
  </view>

  <view class="track-page-footer">
    <text class="track-footer-line" wx:for="{{radarFooterLines}}" wx:key="*this">{{item}}</text>
    <text class="track-footer-line" wx:if="{{radarFooterExtra}}">{{radarFooterExtra}}</text>
  </view>
</view>
