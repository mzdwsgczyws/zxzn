.page {
  min-height: 100vh;
  padding: 24rpx 0 64rpx;
}

.title-lg {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #1a237e;
}

.subtitle {
  display: block;
  margin: 12rpx 0 28rpx;
  font-size: 24rpx;
  color: #6d5d4a;
  line-height: 1.55;
}

.field {
  margin-bottom: 28rpx;
}

.label {
  display: block;
  font-size: 26rpx;
  color: #4a4034;
  margin-bottom: 8rpx;
}

.save-btn {
  margin-top: 16rpx;
  width: 100%;
}

.para {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #4a4034;
  line-height: 1.65;
}

.muted {
  display: block;
  font-size: 26rpx;
  color: #8d7b68;
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.focus-wrap {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #ece5d8;
}

.sec-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #3949ab;
  margin-bottom: 12rpx;
}

.li {
  display: block;
  font-size: 26rpx;
  color: #4a4034;
  margin-bottom: 6rpx;
}

.row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0ebe3;
  font-size: 24rpx;
}

.d {
  color: #78909c;
}

.r {
  color: #5c4d3d;
  text-align: right;
  max-width: 70%;
}
