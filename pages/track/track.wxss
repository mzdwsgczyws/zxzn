.page {
  min-height: 100vh;
  padding: 24rpx 0 48rpx;
}

.title-lg {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #1a237e;
}

.subtitle {
  display: block;
  margin: 12rpx 0 28rpx;
  font-size: 24rpx;
  color: #6d5d4a;
  line-height: 1.55;
}

.field {
  margin-bottom: 28rpx;
}

.label {
  display: block;
  font-size: 26rpx;
  color: #4a4034;
  margin-bottom: 8rpx;
}

.save-btn {
  margin-top: 16rpx;
  width: 100%;
}

.para {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #4a4034;
  line-height: 1.65;
}

.muted {
  display: block;
  font-size: 26rpx;
  color: #8d7b68;
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.focus-wrap {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #ece5d8;
}

.sec-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #3949ab;
  margin-bottom: 12rpx;
}

.li {
  display: block;
  font-size: 26rpx;
  color: #4a4034;
  margin-bottom: 6rpx;
}

.row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0ebe3;
  font-size: 24rpx;
}

.d {
  color: #78909c;
}

.r {
  color: #5c4d3d;
  text-align: right;
  max-width: 70%;
}

.sec-title-inline {
  margin-top: 0;
}

.chip-hint {
  display: block;
  font-size: 22rpx;
  color: #8d7b68;
  margin-bottom: 12rpx;
  line-height: 1.5;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.chip {
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #5c4d3d;
  background: #f5f0e8;
  border: 1rpx solid #e0d8cc;
}

.chip-on {
  background: #e8eaf6;
  border-color: #9fa8da;
  color: #1a237e;
}

.picker-val {
  padding: 16rpx 20rpx;
  background: #faf8f5;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #4a4034;
  border: 1rpx solid #ece5d8;
}

.row-switch {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.row-switch .label {
  margin-bottom: 0;
  flex: 1;
}

.divider-label {
  display: block;
  font-size: 24rpx;
  color: #78909c;
  margin: 8rpx 0 16rpx;
  padding-top: 8rpx;
  border-top: 1rpx dashed #e0d8cc;
}

.li.sm {
  font-size: 24rpx;
  margin-bottom: 4rpx;
}

.muted-li {
  color: #8d7b68 !important;
  margin-left: 12rpx;
  margin-bottom: 8rpx !important;
}

.rec-card {
  margin-bottom: 20rpx;
  padding: 20rpx;
  background: #faf8f5;
  border-radius: 12rpx;
  border: 1rpx solid #ece5d8;
}

.rec-p {
  font-size: 22rpx;
  color: #78909c;
  margin-bottom: 8rpx;
}

.rec-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #3949ab;
  margin-bottom: 12rpx;
}

.rec-block {
  display: block;
  font-size: 24rpx;
  color: #4a4034;
  line-height: 1.55;
  margin-bottom: 8rpx;
}

.rec-k {
  color: #6d5d4a;
  font-weight: 600;
}

.tiny {
  font-size: 22rpx;
  margin-top: 16rpx;
}

.card-radar {
  margin-bottom: 24rpx;
}

.card-radar .title-lg {
  margin-bottom: 8rpx;
}

/* 雷达约占可视区域约 1/3，略设上下限以免过小或过大 */
.five-radar-canvas {
  width: 100%;
  height: 33vh;
  min-height: 220rpx;
  max-height: 360rpx;
  display: block;
  margin: 0 auto;
}

.track-page-footer {
  margin: 32rpx 24rpx 0;
  padding-top: 16rpx;
  border-top: 1rpx solid #e8e0d4;
}

.track-footer-line {
  display: block;
  font-size: 20rpx;
  color: #9a8b7a;
  line-height: 1.55;
  margin-bottom: 10rpx;
}
