.page {
  min-height: 100vh;
  padding: 24rpx 0 48rpx;
}

.title-lg {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: var(--dao-purple-deep);
}

.subtitle {
  display: block;
  margin: 12rpx 0 28rpx;
  font-size: 24rpx;
  color: var(--dao-ink-muted);
  line-height: 1.55;
}

.field {
  margin-bottom: 28rpx;
}

.label {
  display: block;
  font-size: 26rpx;
  color: var(--dao-ink-body);
  margin-bottom: 8rpx;
}

.save-btn {
  margin-top: 16rpx;
  width: 100%;
}

.para {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  color: var(--dao-ink-body);
  line-height: 1.65;
}

.muted {
  display: block;
  font-size: 26rpx;
  color: var(--dao-ink-faint);
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.focus-wrap {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--dao-divider);
}

.sec-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--dao-purple-mid);
  margin-bottom: 12rpx;
}

.li {
  display: block;
  font-size: 26rpx;
  color: var(--dao-ink-body);
  margin-bottom: 6rpx;
}

.row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0ebe3;
  font-size: 24rpx;
}

.d {
  color: #78909c;
}

.r {
  color: var(--dao-brown-warm);
  text-align: right;
  max-width: 70%;
}

.sec-title-inline {
  margin-top: 0;
}

.chip-hint {
  display: block;
  font-size: 22rpx;
  color: var(--dao-ink-faint);
  margin-bottom: 12rpx;
  line-height: 1.5;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.chip {
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: var(--dao-brown-warm);
  background: var(--dao-bg-page);
  border: 1rpx solid #e0d8cc;
}

.chip-on {
  background: #e8eaf6;
  border-color: var(--dao-purple-tint);
  color: var(--dao-purple-deep);
}

.picker-val {
  padding: 16rpx 20rpx;
  background: var(--dao-bg-card);
  border-radius: 12rpx;
  font-size: 26rpx;
  color: var(--dao-ink-body);
  border: 1rpx solid var(--dao-divider);
}

.row-switch {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.row-switch .label {
  margin-bottom: 0;
  flex: 1;
}

.divider-label {
  display: block;
  font-size: 24rpx;
  color: #78909c;
  margin: 8rpx 0 16rpx;
  padding-top: 8rpx;
  border-top: 1rpx dashed #e0d8cc;
}

.li.sm {
  font-size: 24rpx;
  margin-bottom: 4rpx;
}

.muted-li {
  color: var(--dao-ink-faint) !important;
  margin-left: 12rpx;
  margin-bottom: 8rpx !important;
}

.rec-card {
  margin-bottom: 20rpx;
  padding: 20rpx;
  background: var(--dao-bg-card);
  border-radius: 12rpx;
  border: 1rpx solid var(--dao-divider);
}

.rec-p {
  font-size: 22rpx;
  color: #78909c;
  margin-bottom: 8rpx;
}

.rec-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--dao-purple-mid);
  margin-bottom: 12rpx;
}

.rec-block {
  display: block;
  font-size: 24rpx;
  color: var(--dao-ink-body);
  line-height: 1.55;
  margin-bottom: 8rpx;
}

.rec-k {
  color: var(--dao-ink-muted);
  font-weight: 600;
}

.tiny {
  font-size: 22rpx;
  margin-top: 16rpx;
}

.card-radar {
  margin-bottom: 24rpx;
}

.card-radar .title-lg {
  margin-bottom: 6rpx;
}

.radar-lead {
  display: block;
  font-size: 22rpx;
  color: var(--dao-ink-faint);
  line-height: 1.45;
  margin-bottom: 16rpx;
}

/* 雷达主体加高，图形占满宽度内区域 */
.five-radar-canvas {
  width: 100%;
  height: 48vh;
  min-height: 400rpx;
  max-height: 620rpx;
  display: block;
  margin: 0 auto;
}

/* 分数+释义区：垂直占位约为原先的 ~60%（缩 40%），字号同步略减 */
.radar-axis-panel {
  margin-top: 14rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid var(--dao-divider);
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.radar-axis-card {
  background: var(--dao-bg-card);
  border-radius: 8rpx;
  padding: 11rpx 14rpx;
  border: 1rpx solid var(--dao-divider);
}

.radar-axis-top {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 12rpx;
}

.radar-axis-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--dao-purple-mid);
}

.radar-axis-val {
  font-size: 27rpx;
  font-weight: 600;
  color: var(--dao-purple-deep);
  font-variant-numeric: tabular-nums;
}

.radar-axis-tip {
  display: block;
  font-size: 19rpx;
  color: var(--dao-brown-warm);
  line-height: 1.4;
  margin-top: 6rpx;
}

.track-page-footer {
  margin: 32rpx 24rpx 0;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--dao-divider);
}

.track-footer-line {
  display: block;
  font-size: 20rpx;
  color: var(--dao-ink-caption);
  line-height: 1.55;
  margin-bottom: 10rpx;
}
