.page {
  min-height: 100vh;
  padding: 24rpx 0 48rpx;
}

.title-lg {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: var(--dao-purple-deep);
}

.subtitle {
  display: block;
  margin: 12rpx 0 28rpx;
  font-size: 24rpx;
  color: var(--dao-ink-muted);
  line-height: 1.55;
}

.field {
  margin-bottom: 30rpx;
}

.label {
  display: block;
  font-size: 26rpx;
  color: var(--dao-ink-body);
  margin-bottom: 10rpx;
  font-weight: 500;
}

.save-btn {
  margin-top: 16rpx;
  width: 100%;
}

.para {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  color: var(--dao-ink-body);
  line-height: 1.65;
}

.muted {
  display: block;
  font-size: 26rpx;
  color: var(--dao-ink-faint);
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.focus-wrap {
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid var(--dao-divider);
  position: relative;
}

.focus-wrap::before {
  content: '';
  position: absolute;
  top: -1rpx;
  left: 0;
  width: 80rpx;
  height: 3rpx;
  background: linear-gradient(90deg, var(--dao-purple-mid), transparent);
  border-radius: 2rpx;
}

.sec-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--dao-purple-mid);
  margin-bottom: 14rpx;
  letter-spacing: 1rpx;
}

.li {
  display: block;
  font-size: 26rpx;
  color: var(--dao-ink-body);
  margin-bottom: 6rpx;
}

.row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  padding: 18rpx 12rpx;
  margin: 0 -12rpx;
  border-bottom: 1rpx solid #f0ebe3;
  font-size: 24rpx;
  border-radius: 8rpx;
  transition: background 0.15s ease;
}

.row:last-child {
  border-bottom: none;
}

.row:active {
  background: rgba(57, 73, 171, 0.03);
}

.d {
  color: #78909c;
}

.r {
  color: var(--dao-brown-warm);
  text-align: right;
  max-width: 70%;
}

.sec-title-inline {
  margin-top: 0;
}

.chip-hint {
  display: block;
  font-size: 22rpx;
  color: var(--dao-ink-faint);
  margin-bottom: 12rpx;
  line-height: 1.5;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.chip {
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: var(--dao-brown-warm);
  background: var(--dao-bg-page);
  border: 1rpx solid #e0d8cc;
  transition: all 0.2s ease;
}

.chip-on {
  background: linear-gradient(135deg, #e8eaf6, #c5cae9);
  border-color: var(--dao-purple-tint);
  color: var(--dao-purple-deep);
  font-weight: 500;
  box-shadow: 0 2rpx 8rpx rgba(57, 73, 171, 0.12);
}

.picker-val {
  padding: 16rpx 20rpx;
  background: var(--dao-bg-card);
  border-radius: 12rpx;
  font-size: 26rpx;
  color: var(--dao-ink-body);
  border: 1rpx solid var(--dao-divider);
}

.row-switch {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.row-switch .label {
  margin-bottom: 0;
  flex: 1;
}

.divider-label {
  display: block;
  font-size: 22rpx;
  color: var(--dao-ink-faint);
  margin: 16rpx 0 20rpx;
  padding-top: 14rpx;
  border-top: 1rpx dashed var(--dao-divider);
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.li.sm {
  font-size: 24rpx;
  margin-bottom: 4rpx;
}

.muted-li {
  color: var(--dao-ink-faint) !important;
  margin-left: 12rpx;
  margin-bottom: 8rpx !important;
}

.rec-card {
  margin-bottom: 20rpx;
  padding: 24rpx;
  background: var(--dao-bg-card);
  border-radius: 16rpx;
  border: 1rpx solid var(--dao-divider);
  box-shadow: 0 2rpx 12rpx rgba(26, 35, 126, 0.04);
  transition: box-shadow 0.2s ease;
}

.rec-p {
  display: inline-block;
  font-size: 20rpx;
  color: #fff;
  background: linear-gradient(135deg, var(--dao-purple-mid), var(--dao-purple-deep));
  padding: 2rpx 14rpx;
  border-radius: 6rpx;
  margin-bottom: 10rpx;
  letter-spacing: 1rpx;
}

.rec-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--dao-purple-mid);
  margin-bottom: 12rpx;
}

.rec-block {
  display: block;
  font-size: 24rpx;
  color: var(--dao-ink-body);
  line-height: 1.55;
  margin-bottom: 8rpx;
}

.rec-k {
  color: var(--dao-ink-muted);
  font-weight: 600;
}

.tiny {
  font-size: 22rpx;
  margin-top: 16rpx;
}

.card-radar {
  margin-bottom: 24rpx;
  border-top: 3rpx solid var(--dao-purple-soft);
  overflow: hidden;
}

.card-radar .title-lg {
  margin-bottom: 8rpx;
  letter-spacing: 2rpx;
}

.radar-lead {
  display: block;
  font-size: 22rpx;
  color: var(--dao-ink-faint);
  line-height: 1.45;
  margin-bottom: 16rpx;
}

/* 雷达主体加高，图形占满宽度内区域 */
.five-radar-canvas {
  width: 100%;
  height: 48vh;
  min-height: 400rpx;
  max-height: 620rpx;
  display: block;
  margin: 0 auto;
}

.radar-legend {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  margin-top: 16rpx;
  margin-bottom: 8rpx;
  padding: 8rpx 0;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.legend-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
}

.legend-dot--cur {
  background: rgba(48, 63, 159, 0.7);
  box-shadow: 0 0 6rpx rgba(48, 63, 159, 0.4);
}

.legend-dot--prev {
  background: rgba(160, 155, 145, 0.45);
  border: 1rpx dashed rgba(140, 130, 120, 0.6);
}

.legend-text {
  font-size: 22rpx;
  color: var(--dao-ink-faint);
}

/* 分数+释义区：垂直占位约为原先的 ~60%（缩 40%），字号同步略减 */
.radar-axis-panel {
  margin-top: 14rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid var(--dao-divider);
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.radar-axis-card {
  background: var(--dao-bg-card);
  border-radius: 12rpx;
  padding: 14rpx 18rpx;
  border: 1rpx solid var(--dao-divider);
  box-shadow: 0 1rpx 6rpx rgba(26, 35, 126, 0.03);
}

.radar-axis-top {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 12rpx;
}

.radar-axis-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--dao-purple-mid);
}

.radar-axis-val {
  font-size: 27rpx;
  font-weight: 600;
  color: var(--dao-purple-deep);
  font-variant-numeric: tabular-nums;
}

.radar-axis-tip {
  display: block;
  font-size: 19rpx;
  color: var(--dao-brown-warm);
  line-height: 1.4;
  margin-top: 6rpx;
}

.track-page-footer {
  margin: 36rpx 24rpx 0;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--dao-divider);
  opacity: 0.8;
}

.track-footer-line {
  display: block;
  font-size: 20rpx;
  color: var(--dao-ink-caption);
  line-height: 1.6;
  margin-bottom: 10rpx;
  letter-spacing: 0.5rpx;
}
