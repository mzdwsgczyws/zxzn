.home {
  min-height: 100vh;
  background: #f5f0e8;
  box-sizing: border-box;
}

/* 自定义导航：深紫底 + 紫金标题 */
.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  background: linear-gradient(180deg, #3d2b69 0%, #2a1f4a 100%);
  border-bottom: 2rpx solid rgba(212, 175, 55, 0.45);
  box-sizing: border-box;
}

.nav-inner {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  letter-spacing: 6rpx;
  color: #e8d4a8;
  text-shadow:
    0 0 20rpx rgba(180, 140, 60, 0.5),
    0 2rpx 0 rgba(60, 40, 20, 0.35);
}

.main-column {
  box-sizing: border-box;
  min-height: 100vh;
}

.lot-scroll {
  box-sizing: border-box;
  width: 100%;
}

.lot-panel {
  padding: 32rpx 28rpx 48rpx;
  min-height: 200rpx;
  box-sizing: border-box;
}

/* —— 未抽取 —— */
.lot-idle {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 80rpx;
  padding-bottom: 80rpx;
}

.idle-warm-wrap {
  width: 100%;
  padding: 0 36rpx;
  box-sizing: border-box;
  margin-bottom: 48rpx;
}

.idle-warm-tip {
  display: block;
  text-align: center;
  font-size: 26rpx;
  line-height: 1.7;
  /* 与底栏/顶栏同系金色；纸本底上用略深金保证可读，外圈光晕贴近 #e8d4a8 氛围 */
  color: #9a7b2e;
  letter-spacing: 2rpx;
  text-shadow:
    0 0 18rpx rgba(201, 162, 39, 0.4),
    0 1rpx 0 rgba(255, 248, 230, 0.95),
    0 2rpx 8rpx rgba(166, 124, 31, 0.2);
}

.idle-deco {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 35% 30%, rgba(255, 248, 220, 0.35), transparent 55%),
    linear-gradient(145deg, #4a3a6b 0%, #2d2248 100%);
  border: 3rpx solid rgba(212, 175, 55, 0.5);
  box-shadow: 0 12rpx 40rpx rgba(45, 31, 74, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}

.idle-moon {
  font-size: 72rpx;
  color: rgba(232, 212, 168, 0.9);
  line-height: 1;
}

.idle-tag {
  font-size: 26rpx;
  color: #8d7b68;
  letter-spacing: 8rpx;
  margin-bottom: 28rpx;
}

.idle-btn {
  width: 420rpx;
  padding: 32rpx 24rpx;
  line-height: 1.4;
  font-size: 32rpx;
  font-weight: 600;
  color: #2a1f15;
  background: linear-gradient(180deg, #f0dfa0 0%, #c9a227 45%, #a67c1f 100%);
  border: 3rpx solid rgba(90, 60, 30, 0.35);
  border-radius: 999rpx;
  box-shadow: 0 10rpx 32rpx rgba(166, 124, 31, 0.35);
}

.idle-btn::after {
  border: none;
}

.idle-hint {
  margin-top: 36rpx;
  padding: 0 40rpx;
  font-size: 24rpx;
  color: #9a8b7a;
  text-align: center;
  line-height: 1.65;
}

/* —— 摇动舞台 —— */
.lot-stage {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 60rpx;
  padding-bottom: 60rpx;
}

.tube-wrap {
  position: relative;
  width: 200rpx;
  height: 320rpx;
}

.tube-wrap.shaking {
  animation: shake 0.4s ease-in-out infinite;
}

@keyframes shake {
  0% {
    transform: rotate(-6deg) translateX(0);
  }
  50% {
    transform: rotate(8deg) translateX(6rpx);
  }
  100% {
    transform: rotate(-6deg) translateX(0);
  }
}

.tube {
  position: absolute;
  left: 20rpx;
  right: 20rpx;
  bottom: 0;
  top: 40rpx;
  background: linear-gradient(180deg, #5d4037 0%, #3e2723 100%);
  border-radius: 20rpx 20rpx 12rpx 12rpx;
  box-shadow: inset 0 -20rpx 40rpx rgba(0, 0, 0, 0.35);
  border: 4rpx solid #8d6e63;
}

.sticks {
  position: absolute;
  left: 56rpx;
  right: 56rpx;
  top: 0;
  height: 120rpx;
  background: repeating-linear-gradient(
    90deg,
    #d7ccc8 0,
    #d7ccc8 8rpx,
    #a1887f 8rpx,
    #a1887f 16rpx
  );
  border-radius: 8rpx 8rpx 0 0;
}

.shake-tip {
  margin-top: 40rpx;
  font-size: 28rpx;
  color: #6d5d4a;
}

.sim-tip {
  margin-top: 24rpx;
  font-size: 24rpx;
  color: #78909c;
  text-decoration: underline;
  padding: 16rpx;
}

/* —— 结果 —— */
.lot-result {
  background: #fffef8;
  margin: 16rpx 20rpx 24rpx;
  border-radius: 20rpx;
  padding: 28rpx 24rpx 36rpx;
  box-shadow: 0 8rpx 28rpx rgba(26, 35, 126, 0.08);
  border: 1rpx solid rgba(212, 175, 55, 0.2);
}

.result-head {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.tier {
  font-size: 36rpx;
  font-weight: 700;
}

.btn-redraw {
  margin: 0 !important;
  padding: 0 20rpx !important;
  font-size: 22rpx !important;
  line-height: 1.8 !important;
  color: #5c4d3d !important;
  background: rgba(212, 175, 55, 0.2) !important;
  border: 1rpx solid rgba(139, 115, 85, 0.4) !important;
  border-radius: 8rpx !important;
}

.btn-redraw::after {
  border: none;
}

.lot-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #2c2416;
  margin-bottom: 20rpx;
}

/* 未揭晓：与箴言配图同尺寸的神秘黑金闪动封面 */
.sealed-mystery-outer {
  display: flex;
  justify-content: center;
  align-items: center;
  width: 100%;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.sealed-mystery--hover {
  opacity: 0.88;
}

.sealed-mystery {
  position: relative;
  max-width: 100%;
  box-sizing: border-box;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow:
    0 12rpx 40rpx rgba(0, 0, 0, 0.35),
    0 0 0 1rpx rgba(201, 162, 39, 0.25);
}

.sealed-mystery-base {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(155deg, #050505 0%, #12100c 38%, #1c1810 72%, #0a0906 100%);
}

.sealed-mystery-veins {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  opacity: 0.55;
  background:
    radial-gradient(ellipse 90% 55% at 15% 25%, rgba(212, 175, 55, 0.35), transparent 52%),
    radial-gradient(ellipse 70% 50% at 88% 78%, rgba(180, 140, 50, 0.22), transparent 48%),
    radial-gradient(circle at 50% 50%, transparent 30%, rgba(0, 0, 0, 0.45) 100%);
}

.sealed-mystery-grid {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  opacity: 0.4;
  background-image:
    repeating-linear-gradient(
      -42deg,
      transparent,
      transparent 5rpx,
      rgba(201, 162, 39, 0.07) 5rpx,
      rgba(201, 162, 39, 0.07) 6rpx
    ),
    repeating-linear-gradient(
      38deg,
      transparent,
      transparent 5rpx,
      rgba(140, 110, 50, 0.06) 5rpx,
      rgba(140, 110, 50, 0.06) 6rpx
    );
}

.sealed-mystery-shine {
  position: absolute;
  top: 0;
  left: -60%;
  width: 55%;
  height: 100%;
  background: linear-gradient(
    100deg,
    transparent 0%,
    rgba(255, 236, 180, 0.08) 40%,
    rgba(255, 248, 220, 0.38) 50%,
    rgba(255, 236, 180, 0.1) 60%,
    transparent 100%
  );
  animation: sealed-mystery-sweep 2.6s ease-in-out infinite;
}

.sealed-mystery-spark {
  position: absolute;
  top: -20%;
  right: -30%;
  width: 70%;
  height: 70%;
  background: radial-gradient(
    circle,
    rgba(255, 230, 160, 0.2) 0%,
    rgba(201, 162, 39, 0.06) 35%,
    transparent 65%
  );
  animation: sealed-mystery-spark 3.4s ease-in-out infinite;
  pointer-events: none;
}

.sealed-mystery-frame {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  border-radius: 16rpx;
  border: 2rpx solid rgba(201, 162, 39, 0.45);
  box-shadow:
    inset 0 0 50rpx rgba(0, 0, 0, 0.55),
    0 0 28rpx rgba(201, 162, 39, 0.2);
  pointer-events: none;
  animation: sealed-mystery-glow 2.2s ease-in-out infinite;
}

.sealed-mystery-caption {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 12rpx 18rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  background: linear-gradient(180deg, transparent, rgba(0, 0, 0, 0.55));
  pointer-events: none;
}

.sealed-mystery-hint {
  font-size: 22rpx;
  letter-spacing: 12rpx;
  color: rgba(232, 212, 160, 0.85);
  text-shadow:
    0 0 16rpx rgba(201, 162, 39, 0.7),
    0 2rpx 8rpx rgba(0, 0, 0, 0.8);
  animation: sealed-mystery-hint-pulse 2s ease-in-out infinite;
}

@keyframes sealed-mystery-sweep {
  0% {
    transform: translateX(0) skewX(-6deg);
  }
  100% {
    transform: translateX(320%) skewX(-6deg);
  }
}

@keyframes sealed-mystery-spark {
  0%,
  100% {
    opacity: 0.35;
    transform: scale(1) translate(0, 0);
  }
  50% {
    opacity: 0.85;
    transform: scale(1.08) translate(-4%, 4%);
  }
}

@keyframes sealed-mystery-glow {
  0%,
  100% {
    border-color: rgba(201, 162, 39, 0.4);
    box-shadow:
      inset 0 0 50rpx rgba(0, 0, 0, 0.55),
      0 0 22rpx rgba(201, 162, 39, 0.18);
  }
  50% {
    border-color: rgba(255, 224, 130, 0.65);
    box-shadow:
      inset 0 0 40rpx rgba(0, 0, 0, 0.45),
      0 0 40rpx rgba(255, 215, 120, 0.35);
  }
}

@keyframes sealed-mystery-hint-pulse {
  0%,
  100% {
    opacity: 0.65;
  }
  50% {
    opacity: 1;
  }
}

.poem {
  display: block;
  font-size: 28rpx;
  color: #3e3428;
  line-height: 1.75;
  margin-bottom: 20rpx;
  font-style: italic;
}

.lot-art-wrap {
  width: 100%;
  height: 20vh;
  min-height: 180rpx;
  max-height: 340rpx;
  margin: 8rpx 0 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #2c3e55;
  box-shadow: 0 10rpx 28rpx rgba(26, 35, 126, 0.12);
}

.lot-art-canvas {
  display: block;
}

.block {
  margin-bottom: 20rpx;
}

.b-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #3949ab;
  margin-bottom: 8rpx;
}

.b-body {
  display: block;
  font-size: 26rpx;
  color: #4a4034;
  line-height: 1.65;
}

.adv-line {
  display: block;
  font-size: 26rpx;
  color: #3e3428;
  line-height: 1.7;
  margin-top: 12rpx;
  padding-left: 8rpx;
  border-left: 4rpx solid rgba(57, 73, 171, 0.35);
}

.fine-print {
  display: block;
  margin-top: 28rpx;
  font-size: 22rpx;
  color: #a0907c;
  line-height: 1.5;
}

.ai-block {
  margin-top: 8rpx;
  padding-top: 20rpx;
  border-top: 1rpx dashed rgba(57, 73, 171, 0.2);
}

.btn-ai {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin: 12rpx 0;
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  color: #3d2b69;
  background: rgba(212, 175, 55, 0.22);
  border: 1rpx solid rgba(61, 43, 105, 0.35);
  border-radius: 10rpx;
  box-sizing: border-box;
}

.btn-ai-hover {
  opacity: 0.88;
}

.btn-ai-disabled {
  opacity: 0.5;
  pointer-events: none;
}

.ai-loading {
  display: block;
  font-size: 24rpx;
  color: #78909c;
  margin-bottom: 8rpx;
}

.ai-err {
  display: block;
  font-size: 24rpx;
  color: #c62828;
  line-height: 1.5;
  margin-bottom: 8rpx;
}

.ai-body {
  display: block;
  font-size: 26rpx;
  color: #3e3428;
  line-height: 1.7;
  margin-top: 8rpx;
  white-space: pre-wrap;
}

.ai-note {
  display: block;
  margin-top: 16rpx;
  font-size: 20rpx;
  color: #9a8b7a;
  line-height: 1.45;
}

/* —— 心象展馆 / 成就 圆形入口（贴在底栏上方） —— */
.hall-strip {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 950;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  padding-bottom: 6rpx;
  box-sizing: border-box;
  pointer-events: none;
}

.hall-fade {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  top: 0;
  background: linear-gradient(180deg, transparent 0%, rgba(245, 240, 232, 0.55) 55%, rgba(245, 240, 232, 0.92) 100%);
  pointer-events: none;
}

.hall-btns {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: center;
  gap: 56rpx;
  pointer-events: auto;
}

.hall-col {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.hall-col-hover {
  opacity: 0.92;
}

.hall-meta {
  font-size: 22rpx;
  font-weight: 600;
  color: #6d5d4a;
  letter-spacing: 1rpx;
}

.hall-whisper {
  position: relative;
  z-index: 1;
  display: block;
  text-align: center;
  font-size: 20rpx;
  color: #9a8b7a;
  letter-spacing: 2rpx;
  margin-top: 4rpx;
  padding: 0 24rpx;
  pointer-events: none;
}

.hall-circle {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  border: 3rpx solid rgba(212, 175, 55, 0.65);
  box-shadow:
    0 8rpx 28rpx rgba(45, 34, 74, 0.2),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.35);
}

.hall-c1 {
  background: linear-gradient(160deg, #f0dfa0 0%, #c9a227 48%, #8a6a1f 100%);
}

.hall-c2 {
  background: linear-gradient(160deg, #d4c4f0 0%, #8b6bc4 45%, #5a3d8a 100%);
}

.hall-circle-icon {
  font-size: 34rpx;
  font-weight: 700;
  color: rgba(42, 31, 21, 0.88);
  line-height: 1;
  margin-bottom: 6rpx;
}

.hall-c2 .hall-circle-icon {
  color: rgba(255, 252, 245, 0.95);
}

.hall-circle-t {
  font-size: 20rpx;
  font-weight: 600;
  color: #2a1f15;
  letter-spacing: 1rpx;
  transform: scale(0.92);
  transform-origin: center;
}

.hall-c2 .hall-circle-t {
  color: #f5f0ff;
}

/* —— 底部：主页 + 三入口，紫底金文与顶栏统一 —— */
.bottom-dock {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 900;
  background: linear-gradient(180deg, #35285a 0%, #2a1f4a 42%, #1f1638 100%);
  border-top: 2rpx solid rgba(212, 175, 55, 0.55);
  box-shadow: 0 -6rpx 28rpx rgba(26, 18, 48, 0.45);
  padding: 14rpx 12rpx;
  padding-bottom: calc(14rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: row;
  flex-wrap: nowrap;
  align-items: stretch;
  gap: 8rpx;
  box-sizing: border-box;
}

.dock-home {
  flex: 0 0 76rpx;
  width: 76rpx;
  min-width: 76rpx;
  margin: 0;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(165deg, rgba(100, 82, 150, 0.45) 0%, rgba(61, 43, 105, 0.88) 100%);
  border-radius: 18rpx;
  border: 1rpx solid rgba(212, 175, 55, 0.5);
  box-shadow:
    0 4rpx 14rpx rgba(0, 0, 0, 0.28),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.08);
  box-sizing: border-box;
}

/* 道宫轮廓：与底栏紫金、描金与「道性测验」按钮同系 */
.dock-home-temple {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  padding: 8rpx 0 6rpx;
  box-sizing: border-box;
}

.dock-home-temple-bead {
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  margin-bottom: 2rpx;
  background: radial-gradient(circle at 30% 30%, #fff8e0, #e8d4a8 45%, #c9a227 100%);
  border: 1rpx solid rgba(166, 124, 31, 0.55);
  box-shadow: 0 0 6rpx rgba(212, 175, 55, 0.45);
}

.dock-home-temple-roof {
  width: 44rpx;
  height: 14rpx;
  background: linear-gradient(180deg, #f2e6b8 0%, #d4af37 42%, #b8892a 88%, #8b6914 100%);
  border: 1rpx solid rgba(232, 212, 168, 0.65);
  border-bottom: none;
  border-radius: 22rpx 22rpx 0 0;
  box-shadow:
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.35),
    inset 0 -6rpx 10rpx rgba(0, 0, 0, 0.18);
}

.dock-home-temple-eave {
  width: 48rpx;
  height: 3rpx;
  margin-top: -1rpx;
  background: linear-gradient(
    90deg,
    transparent 0%,
    rgba(232, 212, 168, 0.35) 15%,
    #e8d4a8 50%,
    rgba(232, 212, 168, 0.35) 85%,
    transparent 100%
  );
  border-radius: 1rpx;
  opacity: 0.95;
}

.dock-home-temple-hall {
  width: 40rpx;
  height: 20rpx;
  margin-top: 0;
  box-sizing: border-box;
  background: linear-gradient(180deg, rgba(55, 42, 95, 0.95) 0%, rgba(31, 22, 56, 0.98) 100%);
  border: 1rpx solid rgba(212, 175, 55, 0.5);
  border-top: 1rpx solid rgba(180, 150, 80, 0.35);
  border-radius: 0 0 6rpx 6rpx;
  box-shadow: inset 0 4rpx 12rpx rgba(0, 0, 0, 0.35);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding-bottom: 3rpx;
}

.dock-home-temple-door {
  width: 16rpx;
  height: 12rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(232, 212, 168, 0.45);
  border-bottom: 1rpx solid rgba(212, 175, 55, 0.35);
  border-radius: 10rpx 10rpx 2rpx 2rpx;
  background: linear-gradient(180deg, rgba(20, 16, 40, 0.9), rgba(10, 8, 22, 0.95));
  box-shadow: inset 0 0 8rpx rgba(0, 0, 0, 0.5);
}

.dock-home-hover {
  opacity: 0.88;
  background: linear-gradient(165deg, rgba(110, 92, 165, 0.55) 0%, rgba(70, 52, 118, 0.95) 100%);
}

.dock-home-hover .dock-home-temple-roof {
  background: linear-gradient(180deg, #faf0c8 0%, #e8d4a8 40%, #c9a227 85%, #9a7b2e 100%);
}

.dock-divider--home {
  flex: 0 0 2rpx;
  margin: 0 2rpx;
}

.dock-divider {
  flex: 0 0 2rpx;
  width: 2rpx;
  align-self: center;
  height: 68rpx;
  border-radius: 1rpx;
  background: linear-gradient(
    180deg,
    transparent 0%,
    rgba(212, 175, 55, 0.25) 15%,
    rgba(232, 212, 168, 0.55) 50%,
    rgba(212, 175, 55, 0.25) 85%,
    transparent 100%
  );
  opacity: 0.9;
}

.dock-btn {
  flex: 1;
  min-width: 0;
  margin: 0;
  padding: 18rpx 10rpx;
  background: linear-gradient(165deg, rgba(100, 82, 150, 0.55) 0%, rgba(61, 43, 105, 0.92) 48%, rgba(45, 34, 82, 0.95) 100%);
  border-radius: 18rpx;
  border: 1rpx solid rgba(212, 175, 55, 0.42);
  box-shadow:
    0 4rpx 14rpx rgba(0, 0, 0, 0.28),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.dock-btn-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #e8d4a8;
  letter-spacing: 1rpx;
