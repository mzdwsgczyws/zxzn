.home {
  min-height: 100vh;
  background: #f5f0e8;
  box-sizing: border-box;
}

/* 自定义导航：深紫底 + 紫金标题 */
.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  background: linear-gradient(180deg, var(--dao-ritual-purple-a) 0%, var(--dao-ritual-purple-b) 100%);
  border-bottom: 2rpx solid var(--dao-border-gold-strong);
  box-sizing: border-box;
}

.nav-inner {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  letter-spacing: 6rpx;
  color: var(--dao-gold-pale);
  text-shadow:
    0 0 20rpx rgba(180, 140, 60, 0.5),
    0 2rpx 0 rgba(60, 40, 20, 0.35);
}

.main-column {
  box-sizing: border-box;
  min-height: 100vh;
}

.lot-scroll {
  box-sizing: border-box;
  width: 100%;
}

.lot-panel {
  padding: 32rpx 28rpx 48rpx;
  min-height: 200rpx;
  box-sizing: border-box;
}

/* —— 未抽取 —— */
.lot-idle {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 80rpx;
  padding-bottom: 80rpx;
}

.idle-warm-wrap {
  width: 100%;
  padding: 0 36rpx;
  box-sizing: border-box;
  margin-bottom: 48rpx;
}

.idle-warm-tip {
  display: block;
  text-align: center;
  font-size: 26rpx;
  line-height: 1.7;
  /* 与底栏/顶栏同系金色；纸本底上用略深金保证可读，外圈光晕贴近 #e8d4a8 氛围 */
  color: #9a7b2e;
  letter-spacing: 2rpx;
  text-shadow:
    0 0 18rpx rgba(201, 162, 39, 0.4),
    0 1rpx 0 rgba(255, 248, 230, 0.95),
    0 2rpx 8rpx rgba(166, 124, 31, 0.2);
}

.idle-deco {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 35% 30%, rgba(255, 248, 220, 0.35), transparent 55%),
    linear-gradient(145deg, #4a3a6b 0%, #2d2248 100%);
  border: 3rpx solid rgba(212, 175, 55, 0.5);
  box-shadow: 0 12rpx 40rpx rgba(45, 31, 74, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}

.idle-moon {
  font-size: 72rpx;
  color: rgba(232, 212, 168, 0.9);
  line-height: 1;
}

.idle-tag {
  font-size: 26rpx;
  color: #8d7b68;
  letter-spacing: 8rpx;
  margin-bottom: 28rpx;
}

.idle-btn {
  width: 420rpx;
  padding: 32rpx 24rpx;
  line-height: 1.4;
  font-size: 32rpx;
  font-weight: 600;
  color: #2a1f15;
  background: linear-gradient(180deg, #f0dfa0 0%, #c9a227 45%, #a67c1f 100%);
  border: 3rpx solid rgba(90, 60, 30, 0.35);
  border-radius: 999rpx;
  box-shadow: 0 10rpx 32rpx rgba(166, 124, 31, 0.35);
}

.idle-btn::after {
  border: none;
}

.idle-hint {
  margin-top: 36rpx;
  padding: 0 40rpx;
  font-size: 24rpx;
  color: #9a8b7a;
  text-align: center;
  line-height: 1.65;
}

.idle-theory-link {
  display: block;
  margin-top: 28rpx;
  font-size: 24rpx;
  color: #9a7b2e;
  text-align: center;
  letter-spacing: 2rpx;
  text-decoration: underline;
  text-decoration-color: rgba(201, 162, 39, 0.45);
  padding: 12rpx;
}

/* 首次空闲态：轻提示条（关闭或点阅后不再出现） */
.theory-nudge {
  margin: 16rpx 24rpx 8rpx;
  padding: 20rpx 22rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, rgba(53, 40, 90, 0.08) 0%, rgba(201, 162, 39, 0.12) 100%);
  border: 1rpx solid rgba(212, 175, 55, 0.35);
  box-sizing: border-box;
}

.theory-nudge-line {
  display: block;
  font-size: 24rpx;
  line-height: 1.55;
  color: #5c4d3d;
}

.theory-nudge-actions {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-end;
  gap: 28rpx;
  margin-top: 16rpx;
}

.theory-nudge-go {
  font-size: 26rpx;
  font-weight: 600;
  color: #3949ab;
  padding: 8rpx 12rpx;
}

.theory-nudge-x {
  font-size: 24rpx;
  color: #8d7b68;
  padding: 8rpx 12rpx;
}

.checkin-strip {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin: 0 24rpx 16rpx;
  padding: 18rpx 22rpx;
  border-radius: 16rpx;
  background: rgba(57, 73, 171, 0.07);
  border: 1rpx solid rgba(57, 73, 171, 0.2);
  box-sizing: border-box;
}

.checkin-left {
  flex: 1;
  min-width: 0;
  padding-right: 16rpx;
}

.checkin-streak {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1a237e;
}

.checkin-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #6d5d4a;
  line-height: 1.45;
}

.checkin-btn {
  flex-shrink: 0;
  margin: 0;
  padding: 0 28rpx;
  height: 56rpx;
  line-height: 56rpx;
  font-size: 24rpx;
  background: linear-gradient(180deg, #3949ab 0%, #283593 100%);
  color: #f5f0e8;
  border-radius: 28rpx;
  border: none;
}

.checkin-btn::after {
  border: none;
}

.checkin-btn-hover {
  opacity: 0.92;
}

.checkin-btn[disabled] {
  background: #b0b8d4;
  color: #f0f0f0;
}

/* —— 摇动舞台：竹筒 —— */
.lot-stage--bamboo {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 56rpx;
  padding-bottom: 64rpx;
  overflow: hidden;
}

.bamboo-ambient {
  position: absolute;
  left: 50%;
  top: 42%;
  width: 420rpx;
  height: 440rpx;
  margin-left: -210rpx;
  margin-top: -220rpx;
  border-radius: 50%;
  background: radial-gradient(
    circle,
    rgba(92, 78, 58, 0.16) 0%,
    rgba(245, 238, 225, 0.4) 45%,
    transparent 70%
  );
  pointer-events: none;
  z-index: 0;
}

.bamboo-wrap {
  position: relative;
  z-index: 1;
  width: 240rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  transform-origin: 50% 85%;
}

.bamboo-wrap--shaking {
  animation: bamboo-sway 0.58s cubic-bezier(0.45, 0, 0.55, 1) infinite;
}

.bamboo-wrap--drawing {
  animation: bamboo-draw-breathe 0.72s ease-in-out infinite;
}

@keyframes bamboo-sway {
  0%,
  100% {
    transform: rotate(-4deg) translateY(0);
  }
  50% {
    transform: rotate(4deg) translateY(-6rpx);
  }
}

@keyframes bamboo-draw-breathe {
  0%,
  100% {
    transform: scale(1) translateY(0);
    filter: brightness(1);
  }
  50% {
    transform: scale(1.03) translateY(-4rpx);
    filter: brightness(1.06);
  }
}

.bamboo-crown {
  width: 168rpx;
  height: 14rpx;
  border-radius: 8rpx 8rpx 4rpx 4rpx;
  background: linear-gradient(180deg, #4a3f32 0%, #2e261c 100%);
  border: 1rpx solid rgba(180, 150, 90, 0.4);
  box-shadow:
    0 2rpx 8rpx rgba(0, 0, 0, 0.25),
    inset 0 1rpx 0 rgba(120, 100, 70, 0.25);
  z-index: 4;
}

.bamboo-slips {
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  justify-content: center;
  gap: 5rpx;
  margin-top: -2rpx;
  margin-bottom: -10rpx;
  z-index: 3;
  height: 102rpx;
  max-width: 100%;
  padding: 0 4rpx;
  box-sizing: border-box;
}

/* 黑金签条：与揭晓封面同系（深底 + 金边 + 暗纹） */
.bamboo-slip {
  flex-shrink: 0;
  width: 13rpx;
  height: 88rpx;
  border-radius: 4rpx 4rpx 2rpx 2rpx;
  background: linear-gradient(
    90deg,
    #060606 0%,
    #141210 22%,
    #1f1c18 50%,
    #12100c 78%,
    #080807 100%
  );
  border: 1rpx solid rgba(201, 162, 39, 0.5);
  box-shadow:
    0 4rpx 14rpx rgba(0, 0, 0, 0.45),
    0 0 10rpx rgba(201, 162, 39, 0.12),
    inset 0 0 0 1rpx rgba(212, 175, 55, 0.12),
    inset 3rpx 0 8rpx rgba(255, 220, 160, 0.06);
}

.bamboo-slip--1 {
  transform: rotate(-9deg);
  height: 74rpx;
}

.bamboo-slip--2 {
  transform: rotate(-5deg);
  height: 82rpx;
}

.bamboo-slip--3 {
  transform: rotate(-2deg);
  height: 90rpx;
}

.bamboo-slip--4 {
  height: 98rpx;
}

.bamboo-slip--5 {
  transform: rotate(2deg);
  height: 90rpx;
}

.bamboo-slip--6 {
  transform: rotate(5deg);
  height: 82rpx;
}

.bamboo-slip--7 {
  transform: rotate(9deg);
  height: 74rpx;
}

.bamboo-wrap--shaking .bamboo-slip--1 {
  animation: bamboo-rattle-l1 0.48s ease-in-out infinite;
  animation-delay: 0s;
}

.bamboo-wrap--shaking .bamboo-slip--2 {
  animation: bamboo-rattle-l2 0.48s ease-in-out infinite;
  animation-delay: 0.06s;
}

.bamboo-wrap--shaking .bamboo-slip--3 {
  animation: bamboo-rattle-c3 0.48s ease-in-out infinite;
  animation-delay: 0s;
}

.bamboo-wrap--shaking .bamboo-slip--4 {
  animation: bamboo-rattle-c4 0.48s ease-in-out infinite;
  animation-delay: 0.09s;
}

.bamboo-wrap--shaking .bamboo-slip--5 {
  animation: bamboo-rattle-c5 0.48s ease-in-out infinite;
  animation-delay: 0.18s;
}

.bamboo-wrap--shaking .bamboo-slip--6 {
  animation: bamboo-rattle-r6 0.48s ease-in-out infinite;
  animation-delay: 0.04s;
}

.bamboo-wrap--shaking .bamboo-slip--7 {
  animation: bamboo-rattle-r7 0.48s ease-in-out infinite;
  animation-delay: 0.11s;
}

@keyframes bamboo-rattle-l1 {
  0%,
  100% {
    transform: rotate(-9deg) translateY(0);
  }
  35% {
    transform: rotate(-8deg) translateY(-11rpx);
  }
  70% {
    transform: rotate(-10deg) translateY(5rpx);
  }
}

@keyframes bamboo-rattle-l2 {
  0%,
  100% {
    transform: rotate(-5deg) translateY(0);
  }
  35% {
    transform: rotate(-4deg) translateY(-11rpx);
  }
  70% {
    transform: rotate(-6deg) translateY(5rpx);
  }
}

@keyframes bamboo-rattle-c3 {
  0%,
  100% {
    transform: rotate(-2deg) translateY(0);
  }
  35% {
    transform: rotate(-2deg) translateY(-12rpx);
  }
  70% {
    transform: rotate(-2deg) translateY(5rpx);
  }
}

@keyframes bamboo-rattle-c4 {
  0%,
  100% {
    transform: translateY(0);
  }
  35% {
    transform: translateY(-12rpx);
  }
  70% {
    transform: translateY(5rpx);
  }
}

@keyframes bamboo-rattle-c5 {
  0%,
  100% {
    transform: rotate(2deg) translateY(0);
  }
  35% {
    transform: rotate(2deg) translateY(-12rpx);
  }
  70% {
    transform: rotate(2deg) translateY(5rpx);
  }
}

@keyframes bamboo-rattle-r6 {
  0%,
  100% {
    transform: rotate(5deg) translateY(0);
  }
  35% {
    transform: rotate(4deg) translateY(-11rpx);
  }
  70% {
    transform: rotate(6deg) translateY(5rpx);
  }
}

@keyframes bamboo-rattle-r7 {
  0%,
  100% {
    transform: rotate(9deg) translateY(0);
  }
  35% {
    transform: rotate(8deg) translateY(-11rpx);
  }
  70% {
    transform: rotate(10deg) translateY(5rpx);
  }
}

/* 老竹筒：枯褐、灰黄、风化斑与细裂纹 */
.bamboo-tube {
  position: relative;
  width: 152rpx;
  height: 256rpx;
  border-radius: 14rpx 14rpx 20rpx 20rpx;
  background: linear-gradient(
    90deg,
    #2a241c 0%,
    #4a3f32 14%,
    #6b5d48 32%,
    #7a6a52 50%,
    #5c5040 68%,
    #3d352a 86%,
    #221c18 100%
  );
  border: 1rpx solid rgba(55, 48, 38, 0.9);
  box-shadow:
    inset 5rpx 0 14rpx rgba(140, 120, 95, 0.12),
    inset -8rpx 0 20rpx rgba(0, 0, 0, 0.35),
    0 18rpx 36rpx rgba(30, 26, 20, 0.38),
    0 0 0 1rpx rgba(160, 130, 70, 0.15);
  z-index: 2;
  overflow: hidden;
}

.bamboo-tube-patina {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  opacity: 0.55;
  pointer-events: none;
  background:
    radial-gradient(ellipse 55% 35% at 18% 28%, rgba(60, 52, 42, 0.45), transparent 58%),
    radial-gradient(ellipse 45% 30% at 82% 62%, rgba(45, 38, 30, 0.5), transparent 55%),
    radial-gradient(ellipse 30% 22% at 55% 18%, rgba(90, 78, 58, 0.25), transparent 60%);
}

.bamboo-tube-grain {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  opacity: 0.38;
  pointer-events: none;
  background-image:
    repeating-linear-gradient(
      90deg,
      transparent,
      transparent 4rpx,
      rgba(35, 30, 24, 0.14) 4rpx,
      rgba(35, 30, 24, 0.14) 5rpx
    ),
    repeating-linear-gradient(
      0deg,
      transparent,
      transparent 22rpx,
      rgba(40, 34, 28, 0.12) 22rpx,
      rgba(40, 34, 28, 0.12) 23rpx
    );
}

.bamboo-tube-crack {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  opacity: 0.35;
  pointer-events: none;
  background:
    linear-gradient(102deg, transparent 46%, rgba(20, 18, 14, 0.2) 48%, rgba(30, 26, 20, 0.08) 50%, transparent 52%),
    linear-gradient(78deg, transparent 58%, rgba(25, 22, 18, 0.15) 60%, transparent 63%);
}

.bamboo-node {
  position: absolute;
  left: -2rpx;
  right: -2rpx;
  height: 16rpx;
  border-radius: 8rpx;
  background: linear-gradient(
    180deg,
    rgba(25, 22, 18, 0.55) 0%,
    rgba(80, 70, 55, 0.12) 42%,
    rgba(15, 13, 10, 0.45) 100%
  );
  border-top: 1rpx solid rgba(0, 0, 0, 0.35);
  border-bottom: 1rpx solid rgba(120, 105, 80, 0.08);
  box-shadow: inset 0 0 10rpx rgba(0, 0, 0, 0.22);
  pointer-events: none;
}

.bamboo-node--a {
  top: 18%;
}

.bamboo-node--b {
  top: 49%;
  transform: translateY(-50%);
}

.bamboo-node--c {
  bottom: 16%;
}

.bamboo-tube-gloss {
  position: absolute;
  left: 8%;
  top: 10%;
  width: 26%;
  bottom: 14%;
  border-radius: 20rpx;
  background: linear-gradient(90deg, rgba(200, 180, 140, 0.14) 0%, transparent 100%);
  opacity: 0.45;
  pointer-events: none;
}

.bamboo-base-ring {
  width: 168rpx;
  height: 12rpx;
  margin-top: -4rpx;
  border-radius: 0 0 10rpx 10rpx;
  background: linear-gradient(180deg, #3d3428 0%, #221c16 100%);
  border: 1rpx solid rgba(150, 120, 70, 0.35);
  box-shadow: 0 8rpx 16rpx rgba(0, 0, 0, 0.28);
  z-index: 2;
}

.bamboo-ground {
  width: 200rpx;
  height: 10rpx;
  margin-top: 10rpx;
  border-radius: 50%;
  background: radial-gradient(ellipse at center, rgba(55, 48, 38, 0.38) 0%, transparent 72%);
  z-index: 1;
}

.shake-tip {
  position: relative;
  z-index: 2;
  margin-top: 36rpx;
  font-size: 28rpx;
  color: #4d5c42;
  letter-spacing: 1rpx;
  text-shadow: 0 1rpx 0 rgba(255, 255, 255, 0.6);
}

.sim-tip {
  position: relative;
  z-index: 2;
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #6b7a62;
  text-decoration: underline;
  text-decoration-color: rgba(201, 162, 39, 0.45);
  padding: 16rpx;
}

/* —— 运算思考模式 —— */
.lot-thinking {
  background: var(--dao-bg-card);
  margin: 16rpx 20rpx 24rpx;
  border-radius: 20rpx;
  padding: 28rpx 24rpx 36rpx;
  box-shadow: 0 8rpx 28rpx var(--dao-shadow-purple);
  border: 1rpx solid var(--dao-border-gold);
}

.thinking-hint {
  display: block;
  font-size: 24rpx;
  line-height: 1.62;
  font-weight: 500;
  color: var(--dao-ink-muted);
  margin-bottom: 14rpx;
}

.thinking-sub {
  display: block;
  font-size: 24rpx;
  line-height: 1.62;
  color: var(--dao-ink-muted);
  margin-bottom: 22rpx;
}

.thinking-cat-list {
  border-radius: 16rpx;
  background: rgba(255, 254, 248, 0.92);
  border: 1rpx solid rgba(212, 175, 55, 0.18);
  padding: 12rpx 16rpx 8rpx;
  margin-bottom: 16rpx;
}

.thinking-cat-row {
  box-sizing: border-box;
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  padding: 0 6rpx;
  margin-bottom: 0;
  max-height: 0;
  opacity: 0;
  transform: translateY(18rpx);
  overflow: hidden;
  transition:
    max-height 0.62s ease,
    opacity 0.58s ease,
    transform 0.56s ease,
    margin-bottom 0.48s ease,
    padding-top 0.48s ease,
    padding-bottom 0.48s ease;
}

.thinking-cat-row--in {
  max-height: 160rpx;
  opacity: 1;
  transform: translateY(0);
  margin-bottom: 16rpx;
  padding-top: 8rpx;
  padding-bottom: 8rpx;
}

.thinking-cat-mark {
  flex-shrink: 0;
  font-size: 22rpx;
  color: var(--dao-gold-muted);
  line-height: 1.45;
  margin-top: 2rpx;
}

.thinking-cat-text {
  flex: 1;
  font-size: 27rpx;
  line-height: 1.55;
  font-weight: 500;
  color: var(--dao-ink);
}

.thinking-foot {
  display: block;
  font-size: 20rpx;
  line-height: 1.55;
  color: var(--dao-ink-caption);
  margin-bottom: 0;
  max-height: 0;
  opacity: 0;
  overflow: hidden;
  transition: max-height 0.62s ease, opacity 0.56s ease, margin-bottom 0.42s ease;
}

.thinking-foot--in {
  max-height: 280rpx;
  opacity: 1;
  margin-bottom: 16rpx;
}

.thinking-skip {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: var(--dao-purple-mid);
  text-decoration: underline;
  text-decoration-color: rgba(212, 175, 55, 0.35);
  margin-bottom: 8rpx;
}

/* —— 结果 —— */
.lot-result {
  background: #fffef8;
  margin: 16rpx 20rpx 24rpx;
  border-radius: 20rpx;
  padding: 28rpx 24rpx 36rpx;
  box-shadow: 0 8rpx 28rpx rgba(26, 35, 126, 0.08);
  border: 1rpx solid rgba(212, 175, 55, 0.2);
}

.result-head {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.tier {
  font-size: 36rpx;
  font-weight: 700;
}

.btn-redraw {
  margin: 0 !important;
  padding: 0 20rpx !important;
  font-size: 22rpx !important;
  line-height: 1.8 !important;
  color: #5c4d3d !important;
  background: rgba(212, 175, 55, 0.2) !important;
  border: 1rpx solid rgba(139, 115, 85, 0.4) !important;
  border-radius: 8rpx !important;
}

.btn-redraw::after {
  border: none;
}

.lot-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #2c2416;
  margin-bottom: 20rpx;
}

/* 未揭晓：与箴言配图同尺寸的神秘黑金闪动封面 */
.sealed-mystery-outer {
  display: flex;
  justify-content: center;
  align-items: center;
  width: 100%;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.sealed-mystery--hover {
  opacity: 0.88;
}

.sealed-mystery {
  position: relative;
  max-width: 100%;
  box-sizing: border-box;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow:
    0 12rpx 40rpx rgba(0, 0, 0, 0.35),
    0 0 0 1rpx rgba(201, 162, 39, 0.25);
}

.sealed-mystery-base {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(155deg, #050505 0%, #12100c 38%, #1c1810 72%, #0a0906 100%);
}

.sealed-mystery-veins {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  opacity: 0.55;
  background:
    radial-gradient(ellipse 90% 55% at 15% 25%, rgba(212, 175, 55, 0.35), transparent 52%),
    radial-gradient(ellipse 70% 50% at 88% 78%, rgba(180, 140, 50, 0.22), transparent 48%),
    radial-gradient(circle at 50% 50%, transparent 30%, rgba(0, 0, 0, 0.45) 100%);
}

.sealed-mystery-grid {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  opacity: 0.4;
  background-image:
    repeating-linear-gradient(
      -42deg,
      transparent,
      transparent 5rpx,
      rgba(201, 162, 39, 0.07) 5rpx,
      rgba(201, 162, 39, 0.07) 6rpx
    ),
    repeating-linear-gradient(
      38deg,
      transparent,
      transparent 5rpx,
      rgba(140, 110, 50, 0.06) 5rpx,
      rgba(140, 110, 50, 0.06) 6rpx
    );
}

.sealed-mystery-shine {
  position: absolute;
  top: 0;
  left: -60%;
  width: 55%;
  height: 100%;
  background: linear-gradient(
    100deg,
    transparent 0%,
    rgba(255, 236, 180, 0.08) 40%,
    rgba(255, 248, 220, 0.38) 50%,
    rgba(255, 236, 180, 0.1) 60%,
    transparent 100%
  );
  animation: sealed-mystery-sweep 2.6s ease-in-out infinite;
}

.sealed-mystery-spark {
  position: absolute;
  top: -20%;
  right: -30%;
  width: 70%;
  height: 70%;
  background: radial-gradient(
    circle,
    rgba(255, 230, 160, 0.2) 0%,
    rgba(201, 162, 39, 0.06) 35%,
    transparent 65%
  );
  animation: sealed-mystery-spark 3.4s ease-in-out infinite;
  pointer-events: none;
}

.sealed-mystery-frame {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  border-radius: 16rpx;
  border: 2rpx solid rgba(201, 162, 39, 0.45);
  box-shadow:
    inset 0 0 50rpx rgba(0, 0, 0, 0.55),
    0 0 28rpx rgba(201, 162, 39, 0.2);
  pointer-events: none;
  animation: sealed-mystery-glow 2.2s ease-in-out infinite;
}

.sealed-mystery-caption {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 12rpx 18rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  background: linear-gradient(180deg, transparent, rgba(0, 0, 0, 0.55));
  pointer-events: none;
}

.sealed-mystery-hint {
  font-size: 22rpx;
  letter-spacing: 12rpx;
  color: rgba(232, 212, 160, 0.85);
  text-shadow:
    0 0 16rpx rgba(201, 162, 39, 0.7),
    0 2rpx 8rpx rgba(0, 0, 0, 0.8);
  animation: sealed-mystery-hint-pulse 2s ease-in-out infinite;
}

@keyframes sealed-mystery-sweep {
  0% {
    transform: translateX(0) skewX(-6deg);
  }
  100% {
    transform: translateX(320%) skewX(-6deg);
  }
}

@keyframes sealed-mystery-spark {
  0%,
  100% {
    opacity: 0.35;
    transform: scale(1) translate(0, 0);
  }
  50% {
    opacity: 0.85;
    transform: scale(1.08) translate(-4%, 4%);
  }
}

@keyframes sealed-mystery-glow {
  0%,
  100% {
    border-color: rgba(201, 162, 39, 0.4);
    box-shadow:
      inset 0 0 50rpx rgba(0, 0, 0, 0.55),
      0 0 22rpx rgba(201, 162, 39, 0.18);
  }
  50% {
    border-color: rgba(255, 224, 130, 0.65);
    box-shadow:
      inset 0 0 40rpx rgba(0, 0, 0, 0.45),
      0 0 40rpx rgba(255, 215, 120, 0.35);
  }
}

@keyframes sealed-mystery-hint-pulse {
  0%,
  100% {
    opacity: 0.65;
  }
  50% {
    opacity: 1;
  }
}

.poem {
  display: block;
  font-size: 28rpx;
  color: #3e3428;
  line-height: 1.75;
  margin-bottom: 20rpx;
  font-style: italic;
}

.lot-art-wrap {
  position: relative;
  margin: 8rpx auto 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #2c3e55;
  box-shadow: 0 10rpx 28rpx rgba(26, 35, 126, 0.12);
}

.lot-art-canvas {
  display: block;
}

.block {
  margin-bottom: 20rpx;
}

.b-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #3949ab;
  margin-bottom: 8rpx;
}

.b-body {
  display: block;
  font-size: 26rpx;
  color: #4a4034;
  line-height: 1.65;
}

.adv-line {
  display: block;
  font-size: 26rpx;
  color: #3e3428;
  line-height: 1.7;
  margin-top: 12rpx;
  padding-left: 8rpx;
  border-left: 4rpx solid rgba(57, 73, 171, 0.35);
}

.fine-print {
  display: block;
  margin-top: 28rpx;
  font-size: 22rpx;
  color: #a0907c;
  line-height: 1.5;
}

/* —— 心象展馆 / 成就 圆形入口（贴在底栏上方） —— */
.hall-strip {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 950;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  padding-bottom: 6rpx;
  box-sizing: border-box;
  pointer-events: none;
}

.hall-fade {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  top: 0;
  background: linear-gradient(180deg, transparent 0%, rgba(245, 240, 232, 0.55) 55%, rgba(245, 240, 232, 0.92) 100%);
  pointer-events: none;
}

.hall-btns {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: center;
  gap: 56rpx;
  pointer-events: auto;
}

.hall-col {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.hall-col-hover {
  opacity: 0.92;
}

.hall-meta {
  font-size: 22rpx;
  font-weight: 600;
  color: #6d5d4a;
  letter-spacing: 1rpx;
}

.hall-whisper {
  position: relative;
  z-index: 1;
  display: block;
  text-align: center;
  font-size: 20rpx;
  color: #9a8b7a;
  letter-spacing: 2rpx;
  margin-top: 4rpx;
  padding: 0 24rpx;
  pointer-events: none;
}

.hall-circle {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  border: 3rpx solid rgba(212, 175, 55, 0.65);
  box-shadow:
    0 8rpx 28rpx rgba(45, 34, 74, 0.2),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.35);
}

.hall-c1 {
  background: linear-gradient(160deg, #f0dfa0 0%, #c9a227 48%, #8a6a1f 100%);
}

.hall-c2 {
  background: linear-gradient(160deg, #d4c4f0 0%, #8b6bc4 45%, #5a3d8a 100%);
}

.hall-circle-icon {
  font-size: 34rpx;
  font-weight: 700;
  color: rgba(42, 31, 21, 0.88);
  line-height: 1;
  margin-bottom: 6rpx;
}

.hall-c2 .hall-circle-icon {
  color: rgba(255, 252, 245, 0.95);
}

.hall-circle-t {
  font-size: 20rpx;
  font-weight: 600;
  color: #2a1f15;
  letter-spacing: 1rpx;
  transform: scale(0.92);
  transform-origin: center;
}

.hall-c2 .hall-circle-t {
  color: #f5f0ff;
}

/* —— 底部：主页 + 三入口，紫底金文与顶栏统一 —— */
.bottom-dock {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 900;
  background: linear-gradient(180deg, #35285a 0%, #2a1f4a 42%, #1f1638 100%);
  border-top: 2rpx solid rgba(212, 175, 55, 0.55);
  box-shadow: 0 -6rpx 28rpx rgba(26, 18, 48, 0.45);
  padding: 14rpx 12rpx;
  padding-bottom: calc(14rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: row;
  flex-wrap: nowrap;
  align-items: stretch;
  gap: 8rpx;
  box-sizing: border-box;
}

.dock-home {
  flex: 0 0 76rpx;
  width: 76rpx;
  min-width: 76rpx;
  margin: 0;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(165deg, rgba(100, 82, 150, 0.45) 0%, rgba(61, 43, 105, 0.88) 100%);
  border-radius: 18rpx;
  border: 1rpx solid rgba(212, 175, 55, 0.5);
  box-shadow:
    0 4rpx 14rpx rgba(0, 0, 0, 0.28),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.08);
  box-sizing: border-box;
}

/* 道宫轮廓：与底栏紫金、描金与「道性测验」按钮同系 */
.dock-home-temple {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  padding: 8rpx 0 6rpx;
  box-sizing: border-box;
}

.dock-home-temple-bead {
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  margin-bottom: 2rpx;
  background: radial-gradient(circle at 30% 30%, #fff8e0, #e8d4a8 45%, #c9a227 100%);
  border: 1rpx solid rgba(166, 124, 31, 0.55);
  box-shadow: 0 0 6rpx rgba(212, 175, 55, 0.45);
}

.dock-home-temple-roof {
  width: 44rpx;
  height: 14rpx;
  background: linear-gradient(180deg, #f2e6b8 0%, #d4af37 42%, #b8892a 88%, #8b6914 100%);
  border: 1rpx solid rgba(232, 212, 168, 0.65);
  border-bottom: none;
  border-radius: 22rpx 22rpx 0 0;
  box-shadow:
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.35),
    inset 0 -6rpx 10rpx rgba(0, 0, 0, 0.18);
}

.dock-home-temple-eave {
  width: 48rpx;
  height: 3rpx;
  margin-top: -1rpx;
  background: linear-gradient(
    90deg,
    transparent 0%,
    rgba(232, 212, 168, 0.35) 15%,
    #e8d4a8 50%,
    rgba(232, 212, 168, 0.35) 85%,
    transparent 100%
  );
  border-radius: 1rpx;
  opacity: 0.95;
}

.dock-home-temple-hall {
  width: 40rpx;
  height: 20rpx;
  margin-top: 0;
  box-sizing: border-box;
  background: linear-gradient(180deg, rgba(55, 42, 95, 0.95) 0%, rgba(31, 22, 56, 0.98) 100%);
  border: 1rpx solid rgba(212, 175, 55, 0.5);
  border-top: 1rpx solid rgba(180, 150, 80, 0.35);
  border-radius: 0 0 6rpx 6rpx;
  box-shadow: inset 0 4rpx 12rpx rgba(0, 0, 0, 0.35);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding-bottom: 3rpx;
}

.dock-home-temple-door {
  width: 16rpx;
  height: 12rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(232, 212, 168, 0.45);
  border-bottom: 1rpx solid rgba(212, 175, 55, 0.35);
  border-radius: 10rpx 10rpx 2rpx 2rpx;
  background: linear-gradient(180deg, rgba(20, 16, 40, 0.9), rgba(10, 8, 22, 0.95));
  box-shadow: inset 0 0 8rpx rgba(0, 0, 0, 0.5);
}

.dock-home-hover {
  opacity: 0.88;
  background: linear-gradient(165deg, rgba(110, 92, 165, 0.55) 0%, rgba(70, 52, 118, 0.95) 100%);
}

.dock-home-hover .dock-home-temple-roof {
  background: linear-gradient(180deg, #faf0c8 0%, #e8d4a8 40%, #c9a227 85%, #9a7b2e 100%);
}

.dock-divider--home {
  flex: 0 0 2rpx;
  margin: 0 2rpx;
}

.dock-divider {
  flex: 0 0 2rpx;
  width: 2rpx;
  align-self: center;
  height: 68rpx;
  border-radius: 1rpx;
  background: linear-gradient(
    180deg,
    transparent 0%,
    rgba(212, 175, 55, 0.25) 15%,
    rgba(232, 212, 168, 0.55) 50%,
    rgba(212, 175, 55, 0.25) 85%,
    transparent 100%
  );
  opacity: 0.9;
}

.dock-btn {
  flex: 1;
  min-width: 0;
  margin: 0;
  padding: 18rpx 10rpx;
  background: linear-gradient(165deg, rgba(100, 82, 150, 0.55) 0%, rgba(61, 43, 105, 0.92) 48%, rgba(45, 34, 82, 0.95) 100%);
  border-radius: 18rpx;
  border: 1rpx solid rgba(212, 175, 55, 0.42);
  box-shadow:
    0 4rpx 14rpx rgba(0, 0, 0, 0.28),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.dock-btn-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #e8d4a8;
  letter-spacing: 1rpx;
  line-height: 1.38;
  text-align: center;
  white-space: normal;
  word-break: keep-all;
  text-shadow:
    0 0 18rpx rgba(180, 140, 60, 0.35),
    0 2rpx 4rpx rgba(0, 0, 0, 0.35);
}

.dock-btn-hover {
  opacity: 0.88;
  background: linear-gradient(165deg, rgba(110, 92, 165, 0.65) 0%, rgba(70, 52, 118, 0.95) 100%);
}
