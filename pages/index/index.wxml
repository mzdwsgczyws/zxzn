<view class="home dao-paper-bg">
  <milestone-celebrate
    show="{{showMilestone}}"
    title="{{milestoneText}}"
    streak="{{checkinStreak}}"
    body="坚持本身就是一种修行"
    bind:close="closeMilestone"
  />
  <view class="custom-nav" style="padding-top: {{statusBarH}}px;">
    <view class="nav-inner">
      <text class="nav-title">量化自修正念</text>
    </view>
  </view>

  <view class="main-column" style="padding-top: {{navTotalPx}}px;">
    <!-- iOS：enhanced scroll-view 会与原生 canvas-id 合成错位，签图勿与此同开 -->
    <scroll-view
      scroll-y="{{true}}"
      show-scrollbar="{{true}}"
      class="lot-scroll"
      style="height: {{mainScrollH}}px;"
    >
      <view class="theory-nudge" wx:if="{{theoryBannerEligible && (phase === 'idle' || phase === 'result')}}">
        <view class="theory-nudge-lines">
          <text class="theory-nudge-line">将道教文化意象与量化自观察结合，</text>
          <text class="theory-nudge-line">供参照、非说教。</text>
        </view>
        <view class="theory-nudge-actions">
          <text class="theory-nudge-go" bindtap="readTheoryIntro">阅读简介</text>
          <text class="theory-nudge-x" bindtap="dismissTheoryBanner">关闭</text>
        </view>
      </view>

      <checkin-strip
        wx:if="{{phase === 'idle' || phase === 'result' || phase === 'thinking'}}"
        streak="{{checkinStreak}}"
        totalDays="{{checkinTotalDays}}"
        checkedToday="{{checkinCheckedToday}}"
        expanded="{{checkinExpanded}}"
        selectedMood="{{checkinMood}}"
        bind:checkin="tapCheckIn"
        bind:moodpick="onMoodPick"
        bind:toggle="onCheckinToggle"
      />

      <view class="weekly-challenge" wx:if="{{weeklyChallenge && (phase === 'idle' || phase === 'result')}}">
        <view class="wc-header">
          <text class="wc-icon">⚡</text>
          <text class="wc-title">本周挑战 · {{weeklyChallenge.title}}</text>
        </view>
        <text class="wc-desc">{{weeklyChallenge.desc}}</text>
        <view class="wc-progress-bar">
          <view class="wc-progress-fill" style="width: {{wcProgressPct}}%;"></view>
        </view>
        <text class="wc-progress-text" wx:if="{{weeklyChallenge.completed}}">已完成！获得「{{weeklyChallenge.badge}}」徽章</text>
        <text class="wc-progress-text" wx:else>已达标 {{wcPassDays}} / {{weeklyChallenge.days}} 天</text>
      </view>

      <!-- 未抽取：居中入口 -->
      <view class="lot-panel lot-idle" wx:if="{{phase === 'idle'}}">
        <view class="idle-warm-wrap">
          <view class="idle-warm-lines">
            <text class="idle-warm-line">今日还未抽取心象箴言，</text>
            <text class="idle-warm-line">轻触开始试一试吧。</text>
          </view>
        </view>
        <view class="idle-deco">
          <text class="idle-moon">☽</text>
        </view>
        <text class="idle-tag">今日心象箴言</text>
        <button class="idle-btn" bindtap="tapStartLottery" aria-label="开始摇签抽取心象箴言">
          <view class="idle-btn-inner">
            <text class="idle-btn-line">轻触开始</text>
            <text class="idle-btn-line">摇动揭晓</text>
          </view>
        </button>
        <text class="idle-seasonal" wx:if="{{seasonalHint}}">{{seasonalHint}}</text>
        <view class="idle-hint-wrap">
          <text class="idle-hint-line">点击按钮后感应手机摇动，</text>
          <text class="idle-hint-line">约 9 次有效晃动后生成当日一条</text>
        </view>
        <text class="idle-theory-link" bindtap="openTheoryIntro">量化 × 修道 · 理念简介</text>
        <text class="idle-treehole-link" bindtap="goTreeHole">心事寄此 · 匿名树洞</text>
      </view>

      <!-- 摇动中 / 动画：竹筒 -->
      <view class="lot-panel lot-stage--bamboo" wx:if="{{phase === 'shake' || phase === 'anim'}}">
        <view class="bamboo-ambient"></view>
        <view
          class="bamboo-wrap {{shaking ? 'bamboo-wrap--shaking' : ''}} {{phase === 'anim' ? 'bamboo-wrap--drawing' : ''}}"
        >
          <view class="bamboo-crown"></view>
          <view class="bamboo-slips">
            <view class="bamboo-slip bamboo-slip--1"></view>
            <view class="bamboo-slip bamboo-slip--2"></view>
            <view class="bamboo-slip bamboo-slip--3"></view>
            <view class="bamboo-slip bamboo-slip--4"></view>
            <view class="bamboo-slip bamboo-slip--5"></view>
            <view class="bamboo-slip bamboo-slip--6"></view>
            <view class="bamboo-slip bamboo-slip--7"></view>
          </view>
          <view class="bamboo-tube">
            <view class="bamboo-tube-patina"></view>
            <view class="bamboo-tube-grain"></view>
            <view class="bamboo-tube-crack"></view>
            <view class="bamboo-node bamboo-node--a"></view>
            <view class="bamboo-node bamboo-node--b"></view>
            <view class="bamboo-node bamboo-node--c"></view>
            <view class="bamboo-tube-gloss"></view>
          </view>
          <view class="bamboo-base-ring"></view>
          <view class="bamboo-ground"></view>
        </view>
        <text class="shake-tip">{{shakeHint}}</text>
        <view class="sim-tip-wrap" wx:if="{{phase === 'shake'}}" bindtap="simShake">
          <text class="sim-tip-line">模拟器无感应？</text>
          <text class="sim-tip-line sim-tip-line--link">点此完成生成</text>
        </view>
      </view>

      <!-- 运算思考：展示纳入种子的上下文后再进入箴言卡片 -->
      <view class="lot-panel lot-thinking" wx:if="{{phase === 'thinking'}}">
        <view class="thinking-hint-wrap">
          <text class="thinking-hint">正在结合您已填写的档案与当日情境，</text>
          <text class="thinking-hint">整理纳入本轮箴言上下文的若干门类…</text>
        </view>
        <view class="thinking-sub-wrap">
          <text class="thinking-sub">下列为当日纳入运算的数据门类（不显细节）。</text>
          <text class="thinking-sub">完成后将自动进入箴言卡片。</text>
        </view>
        <view class="thinking-cat-list">
          <view
            wx:for="{{thinkingCategories}}"
            wx:for-index="idx"
            wx:key="*this"
            class="thinking-cat-row {{thinkingVisibleCount > idx ? 'thinking-cat-row--in' : ''}}"
          >
            <text class="thinking-cat-mark">◇</text>
            <text class="thinking-cat-text">{{item}}</text>
          </view>
        </view>
        <text class="thinking-foot {{thinkingFootnoteVisible ? 'thinking-foot--in' : ''}}">{{thinkingFootnote}}</text>
        <text
          class="thinking-skip"
          wx:if="{{thinkingCategories.length > thinkingVisibleCount || !thinkingFootnoteVisible}}"
          bindtap="tapSkipThinkingReveal"
        >跳过显现</text>
      </view>

      <!-- 已生成 -->
      <view class="lot-panel lot-result" wx:if="{{phase === 'result'}}">
        <view class="result-head">
          <text class="tier" style="color: {{tierColor}};">{{lot.tierLabel}}</text>
          <button class="btn-redraw" size="mini" bindtap="redrawLottery">重新抽取</button>
        </view>
        <text class="lot-name" wx:if="{{revealed}}">{{lot.name}}</text>
        <view class="sealed-mystery-outer" wx:else bindtap="reveal" hover-class="sealed-mystery--hover">
          <view class="sealed-mystery" style="width: {{lotArtW}}px; height: {{lotArtH}}px;">
            <view class="sealed-mystery-base"></view>
            <view class="sealed-mystery-veins"></view>
            <view class="sealed-mystery-grid"></view>
            <view class="sealed-mystery-shine"></view>
            <view class="sealed-mystery-spark"></view>
            <view class="sealed-mystery-frame"></view>
            <view class="sealed-mystery-caption">
              <text class="sealed-mystery-hint">轻触揭晓</text>
            </view>
          </view>
        </view>

        <block wx:if="{{revealed}}">
          <text class="poem">{{lot.poem}}</text>
          <view class="lot-art-wrap" style="width: {{lotArtW}}px; height: {{lotArtH}}px;">
            <canvas
              canvas-id="lotArtCanvas"
              class="lot-art-canvas"
              style="width: {{lotArtW}}px; height: {{lotArtH}}px;"
              disable-scroll="{{true}}"
            ></canvas>
          </view>
          <view class="block">
            <text class="b-title">释义</text>
            <text class="b-body">{{lot.interpret}}</text>
          </view>
          <view class="block">
            <text class="b-title">建议</text>
            <text class="adv-line" wx:for="{{adviceList}}" wx:key="*this">{{item}}</text>
            <view class="advice-feedback-row">
              <view class="advice-fb-btn advice-fb-like {{adviceFbDone ? 'advice-fb-done' : ''}}" bindtap="tapAdviceLike">
                <text class="advice-fb-icon">✦</text>
                <text class="advice-fb-text">有启发</text>
              </view>
              <view class="advice-fb-btn advice-fb-skip {{adviceFbDone ? 'advice-fb-done' : ''}}" bindtap="tapAdviceSkip">
                <text class="advice-fb-icon">✗</text>
                <text class="advice-fb-text">不适用</text>
              </view>
            </view>
          </view>
          <micro-action
            actions="{{microActions}}"
            yesterdaySummary="{{yesterdayActionSummary}}"
            bind:change="onMicroActionChange"
          />
          <view class="poster-btn-row" wx:if="{{revealed}}">
            <button class="btn-ghost poster-gen-btn" bindtap="generateMaximPoster">生成箴言分享卡</button>
          </view>
        </block>

        <view class="result-highlight" wx:if="{{weekHighlight}}">
          <text class="rh-text">{{weekHighlight}}</text>
        </view>
        <text class="fine-print">仅供自察与行动参考，请勿替代专业帮助。</text>
        <view class="ritual-close" wx:if="{{revealed}}" bindtap="goTrack">
          <view class="rc-lines">
            <text class="rc-text">记录今日状态，</text>
            <text class="rc-text">让明日箴言更懂你 →</text>
          </view>
        </view>
      </view>
    </scroll-view>

    <view class="hall-strip hall-strip--triple" style="height: {{hallStripH}}px; bottom: {{bottomBarH}}px;">
      <view class="hall-fade"></view>
      <view class="hall-btns">
        <view class="hall-col" hover-class="hall-col-hover" bindtap="goFortuneTrend">
          <view class="hall-circle hall-c0">
            <text class="hall-circle-icon">历</text>
            <text class="hall-circle-t">趋势日历</text>
          </view>
          <text class="hall-meta">{{hallTrendDays}}天</text>
        </view>
        <view class="hall-col" hover-class="hall-col-hover" bindtap="goLotHall">
          <view class="hall-circle hall-c1">
            <text class="hall-circle-icon">箴</text>
            <text class="hall-circle-t">心象展馆</text>
          </view>
          <text class="hall-meta">{{hallLotN}}/64</text>
        </view>
        <view class="hall-col" hover-class="hall-col-hover" bindtap="goAchieveHall">
          <view class="hall-circle hall-c2">
            <text class="hall-circle-icon">勋</text>
            <text class="hall-circle-t">成就展馆</text>
          </view>
          <text class="hall-meta">{{hallAchUnlocked}}/{{hallAchTotal}}</text>
        </view>
        <view class="hall-col" hover-class="hall-col-hover" bindtap="goReport" aria-role="button" aria-label="修炼报告">
          <view class="hall-circle hall-c3">
            <text class="hall-circle-icon">报</text>
            <text class="hall-circle-t">修炼报告</text>
          </view>
          <text class="hall-meta">周/月</text>
        </view>
      </view>
      <view class="hall-whisper-lines">
        <text class="hall-whisper-line">趋势走势示意 · 长按可看释义</text>
        <text class="hall-whisper-line">展馆首次收录</text>
      </view>
    </view>

    <canvas type="2d" id="poster-canvas" class="poster-canvas-offscreen" style="width:600px;height:900px;position:fixed;left:-9999px;top:0;"></canvas>

    <view class="bottom-dock" style="height: {{bottomBarH}}px;">
      <view class="dock-home" hover-class="dock-home-hover" bindtap="goHome">
        <view class="dock-home-temple">
          <view class="dock-home-temple-bead"></view>
          <view class="dock-home-temple-roof"></view>
          <view class="dock-home-temple-eave"></view>
          <view class="dock-home-temple-hall">
            <view class="dock-home-temple-door"></view>
          </view>
        </view>
      </view>
      <view class="dock-divider dock-divider--home"></view>
      <view class="dock-btn" hover-class="dock-btn-hover" bindtap="goQuiz" aria-role="button" aria-label="道性测验">
        <text class="dock-btn-text">道性测验</text>
      </view>
      <view class="dock-divider"></view>
      <view class="dock-btn" hover-class="dock-btn-hover" bindtap="goTrack" aria-role="button" aria-label="自修记录">
        <text class="dock-btn-text">自修记录</text>
      </view>
      <view class="dock-divider"></view>
      <view class="dock-btn" hover-class="dock-btn-hover" bindtap="goProfile" aria-role="button" aria-label="个人档案">
        <text class="dock-btn-text">个人档案</text>
      </view>
    </view>
  </view>
</view>
