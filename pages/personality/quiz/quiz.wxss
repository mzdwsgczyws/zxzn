.page {
  min-height: 100vh;
  padding: 24rpx 0 48rpx;
}

.progress-wrap {
  padding: 0 32rpx 24rpx;
}

.progress-bar {
  height: 12rpx;
  background: #e8e0d4;
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #5c6bc0, #3949ab);
  border-radius: 8rpx;
  transition: width 0.2s ease;
}

.progress-text {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #8d7b68;
  text-align: right;
}

.question-card {
  margin: 0 24rpx;
}

.q-label {
  display: block;
  font-size: 24rpx;
  color: #78909c;
  margin-bottom: 12rpx;
}

.q-text {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #2c2416;
  line-height: 1.55;
  margin-bottom: 32rpx;
}

.opt {
  display: block;
  width: 100%;
  margin-bottom: 20rpx;
  padding: 28rpx 24rpx;
  font-size: 28rpx;
  line-height: 1.5;
  text-align: left;
  background: #f8f6f0;
  color: #2c2416;
  border-radius: 16rpx;
  border: 2rpx solid #e0d8c8;
  transition: background 0.15s, border-color 0.15s;
}

.opt::after {
  border: none;
}

.opt:active {
  background: #ede8dc;
}

.opt--neutral {
  text-align: center;
  color: #78909c;
  font-size: 26rpx;
  background: #f2f0ec;
  border-style: dashed;
}

.opt--selected {
  background: #e8e2f0;
  border-color: #7e57c2;
  color: #4a148c;
}

.opt--neutral.opt--selected {
  background: #ede8f5;
  border-color: #9575cd;
  color: #5e35b1;
}

/* 导航行：上一题 */
.nav-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 32rpx 0;
}

.nav-btn {
  padding: 16rpx 32rpx;
  font-size: 26rpx;
  line-height: 1.4;
  color: #5c4d3d;
  background: rgba(212, 175, 55, 0.15);
  border: 1rpx solid rgba(139, 115, 85, 0.35);
  border-radius: 12rpx;
}

.nav-btn::after {
  border: none;
}

.nav-btn--disabled {
  opacity: 0.35;
}

.nav-mid-hint {
  font-size: 22rpx;
  color: #a0907c;
}

.hint {
  margin: 32rpx 40rpx;
  font-size: 24rpx;
  color: #a0907c;
  line-height: 1.6;
}
