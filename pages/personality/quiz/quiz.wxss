.page {
  min-height: 100vh;
  padding: 24rpx 0 48rpx;
}

.progress-wrap {
  padding: 0 32rpx 24rpx;
}

.progress-bar {
  height: 12rpx;
  background: var(--dao-divider);
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--dao-purple-soft), var(--dao-purple-mid));
  border-radius: 8rpx;
  transition: width 0.2s ease;
}

.progress-text {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: var(--dao-ink-faint);
  text-align: right;
}

.question-card {
  margin: 0 24rpx;
}

.q-label {
  display: block;
  font-size: 24rpx;
  color: #78909c;
  margin-bottom: 12rpx;
}

.q-text {
  display: block;
  font-family: "DaoDisplay", "Songti SC", "STSong", "Noto Serif CJK SC", serif;
  font-size: 34rpx;
  font-weight: 600;
  color: var(--dao-ink);
  line-height: 1.55;
  margin-bottom: 32rpx;
}

.opt {
  display: block;
  width: 100%;
  margin-bottom: 16rpx;
  padding: 24rpx 24rpx;
  font-size: 28rpx;
  line-height: 1.5;
  text-align: left;
  background: var(--dao-bg-card);
  color: var(--dao-ink);
  border-radius: 16rpx;
  border: 2rpx solid #e0d8c8;
  transition: background 0.15s, border-color 0.15s;
}

.opt::after {
  border: none;
}

.opt:active {
  background: #ede8dc;
}

.opt--selected {
  background: #e8e2f0;
  border-color: var(--dao-purple-soft);
  color: #4a148c;
  animation: optPop 0.25s ease;
}

@keyframes optPop {
  0% { transform: scale(1); }
  50% { transform: scale(1.04); }
  100% { transform: scale(1); }
}

.opt--neither {
  background: #f5f2eb;
  border-style: dashed;
  font-size: 26rpx;
  color: var(--dao-ink-muted);
}

/* 导航行 */
.nav-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 32rpx 0;
}

.nav-btn {
  padding: 16rpx 32rpx;
  font-size: 26rpx;
  line-height: 1.4;
  color: var(--dao-brown-warm);
  background: rgba(212, 175, 55, 0.15);
  border: 1rpx solid rgba(139, 115, 85, 0.35);
  border-radius: 12rpx;
}

.nav-btn::after {
  border: none;
}

.nav-btn--disabled {
  opacity: 0.35;
}

.nav-mid-hint {
  font-size: 22rpx;
  color: #a0907c;
}

.early-wrap {
  padding: 8rpx 32rpx 0;
  margin-top: 8rpx;
}

.btn-early {
  width: 100%;
  padding: 20rpx 24rpx;
  font-size: 26rpx;
  line-height: 1.45;
  color: var(--dao-brown-warm);
  background: #fff;
  border: 2rpx dashed #b0a080;
  border-radius: 16rpx;
}

.btn-early::after {
  border: none;
}

.hint {
  margin: 32rpx 40rpx;
  font-size: 24rpx;
  color: #a0907c;
  line-height: 1.6;
}
