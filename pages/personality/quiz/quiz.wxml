<view class="page">
  <view class="progress-wrap">
    <view class="progress-bar">
      <view class="progress-fill" style="width: {{progress}}%;"></view>
    </view>
    <text class="progress-text">{{currentIndex + 1}} / {{total}}</text>
  </view>

  <view class="card question-card" wx:if="{{current}}">
    <text class="q-label">第 {{current.id}} 题</text>
    <text class="q-text">{{current.text}}</text>
    <button
      wx:for="{{current.options}}"
      wx:for-index="oi"
      wx:key="oi"
      class="opt {{selectedIdx === oi ? 'opt--selected' : ''}} {{oi === 2 ? 'opt--neither' : ''}}"
      bindtap="choose"
      data-idx="{{oi}}"
    >{{item.label}}</button>
  </view>

  <view class="nav-row" wx:if="{{current}}">
    <button class="nav-btn {{currentIndex <= 0 ? 'nav-btn--disabled' : ''}}" bindtap="goPrev" disabled="{{currentIndex <= 0}}">上一题</button>
    <text class="nav-mid-hint">{{selectedIdx >= 0 ? '已选，自动进入下一题' : '请选择一项'}}</text>
  </view>

  <view class="early-wrap" wx:if="{{current}}">
    <button class="btn-early" bindtap="finishEarly">不想做后续题目，直接看结果</button>
  </view>

  <view class="hint">提示：没有对错，尽量按第一反应选。每题两栏都是常见、可接受的做法，只问哪边更像你。只有实在选不出时，再用最后一项。未完成全部题目时也可提前看结果。</view>
</view>
