.page {
  min-height: 100vh;
  padding-bottom: 48rpx;
}

.top-bar {
  display: flex;
  justify-content: flex-end;
  padding: 16rpx 32rpx 0;
}

.retest-link {
  font-size: 26rpx;
  color: var(--dao-purple-mid);
  text-decoration: underline;
}

.banner {
  margin: 8rpx 32rpx 0;
  padding: 20rpx 24rpx;
  background: rgba(57, 73, 171, 0.08);
  border-radius: 12rpx;
  border-left: 6rpx solid var(--dao-purple-mid);
}

.tip {
  font-size: 24rpx;
  color: var(--dao-brown-warm);
  line-height: 1.6;
}

.quiz-meta {
  margin: 0 32rpx 8rpx;
  padding: 16rpx 20rpx;
  background: rgba(126, 87, 194, 0.08);
  border-radius: 12rpx;
  border-left: 6rpx solid var(--dao-purple-soft);
}

.quiz-meta-text {
  font-size: 22rpx;
  color: var(--dao-brown-warm);
  line-height: 1.55;
}

.portrait-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 16rpx 32rpx 8rpx;
  padding: 20rpx 0 8rpx;
  background: linear-gradient(180deg, rgba(26, 35, 126, 0.06) 0%, rgba(245, 240, 232, 0.4) 100%);
  border-radius: 20rpx;
  border: 1rpx solid rgba(57, 73, 171, 0.12);
}

.portrait-img {
  display: block;
  width: 280px;
  height: 280px;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(26, 35, 126, 0.15);
  background: var(--dao-divider);
}

.main-card {
  margin-top: 20rpx;
}

.type-name {
  display: block;
  font-family: var(--dao-font-display);
  font-size: 40rpx;
  font-weight: 700;
  color: var(--dao-purple-deep);
}

.figure {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #8d6e63;
}

.summary {
  display: block;
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #3e3428;
  line-height: 1.65;
}

.scores {
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid var(--dao-divider);
}

.score-row {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.score-label {
  font-size: 26rpx;
  color: var(--dao-ink-faint);
  font-weight: 400;
  width: 56rpx;
  text-align: center;
  transition: color 0.2s ease;
}

.score-label--l {
  text-align: right;
  padding-right: 12rpx;
}

.score-label--r {
  text-align: left;
  padding-left: 12rpx;
}

.score-label--dom {
  color: var(--dao-purple-deep);
  font-weight: 700;
  font-size: 28rpx;
}

.dual-bar {
  flex: 1;
  height: 36rpx;
  display: flex;
  border-radius: 18rpx;
  overflow: hidden;
  position: relative;
  background: var(--dao-divider);
}

.dual-bar-left {
  height: 100%;
  background: rgba(126, 87, 194, 0.2);
  border-radius: 18rpx 0 0 18rpx;
  transition: width 0.4s ease;
}

.dual-bar-right {
  height: 100%;
  background: rgba(57, 73, 171, 0.2);
  border-radius: 0 18rpx 18rpx 0;
  transition: width 0.4s ease;
}

.dual-bar-left.dual-bar--dom {
  background: linear-gradient(90deg, #7e57c2, #9575cd);
}

.dual-bar-right.dual-bar--dom {
  background: linear-gradient(90deg, var(--dao-purple-mid), var(--dao-purple-soft));
}

.dual-bar-pct {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  font-size: 22rpx;
  font-weight: 700;
  color: #fff;
  text-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.35);
  z-index: 1;
  white-space: nowrap;
}

.section {
  margin-top: 28rpx;
}

.sec-title {
  display: block;
  font-family: var(--dao-font-display);
  font-size: 28rpx;
  font-weight: 600;
  color: var(--dao-purple-mid);
  margin-bottom: 12rpx;
}

.li {
  display: block;
  font-size: 26rpx;
  color: var(--dao-ink-body);
  line-height: 1.65;
  margin-bottom: 6rpx;
}

.para {
  display: block;
  font-size: 26rpx;
  color: var(--dao-brown-warm);
  line-height: 1.7;
}

.actions {
  padding: 32rpx 48rpx 48rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.actions .btn-primary,
.actions .btn-ghost,
.actions .share-friend {
  width: 100%;
}

.share-friend::after {
  border: none;
}

.hidden-canvas {
  position: fixed;
  left: -2000px;
  top: 0;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 48rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--dao-ink-faint);
  margin-bottom: 40rpx;
}
