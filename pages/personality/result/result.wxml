<view class="page" wx:if="{{hasResult}}">
  <view class="top-bar">
    <text class="retest-link" bindtap="retest">重新测验</text>
  </view>
  <view class="banner">
    <text class="tip">你当前更接近以下状态（非固定标签，可随自修与境遇变化）</text>
  </view>

  <view class="quiz-meta" wx:if="{{quizMetaLine}}">
    <text class="quiz-meta-text">{{quizMetaLine}}</text>
  </view>

  <view class="portrait-block">
    <image
      wx:if="{{portraitSrc}}"
      class="portrait-img"
      src="{{portraitSrc}}"
      mode="aspectFill"
    />
  </view>

  <view class="card main-card">
    <text class="type-name">{{result.typeName}}</text>
    <text class="figure">历史形象取意：{{result.figure}}</text>
    <text class="summary">{{result.summary}}</text>

    <view class="scores">
      <view class="score-item" wx:for="{{scoreList}}" wx:key="k">
        <text class="sk">{{item.k}}</text>
        <view class="bar-bg">
          <view class="bar-fill" style="width: {{item.v}}%;"></view>
        </view>
        <text class="sv">{{item.v}}%</text>
      </view>
    </view>

    <view class="section">
      <text class="sec-title">核心特征</text>
      <text class="li" wx:for="{{result.traits}}" wx:key="*this">· {{item}}</text>
    </view>
    <view class="section">
      <text class="sec-title">风险点</text>
      <text class="li" wx:for="{{result.risks}}" wx:key="*this">· {{item}}</text>
    </view>
    <view class="section">
      <text class="sec-title">自修建议</text>
      <text class="li" wx:for="{{result.advice}}" wx:key="*this">· {{item}}</text>
    </view>
    <view class="section">
      <text class="sec-title">详细说明</text>
      <text class="para">{{result.detail}}</text>
    </view>
  </view>

  <view class="actions safe-bottom">
    <button class="btn-primary share-friend" open-type="share">分享给好友（卡片图）</button>
    <button class="btn-primary" bindtap="savePoster">保存高清海报到相册</button>
    <button class="btn-ghost" bindtap="retest">重新测验</button>
  </view>

  <canvas
    canvas-id="shareCanvas"
    class="hidden-canvas"
    style="width: 500px; height: 400px;"
    width="500"
    height="400"
  ></canvas>
  <canvas
    type="2d"
    id="posterCanvas2d"
    class="hidden-canvas"
    style="width: 750px; height: {{posterCanvasH}}px;"
  ></canvas>
  <canvas
    canvas-id="posterCanvasLegacy"
    class="hidden-canvas"
    style="width: 750px; height: {{posterCanvasH}}px;"
    width="750"
    height="{{posterCanvasH}}"
  ></canvas>
</view>

<view class="empty page" wx:else>
  <text class="empty-text">还没有测验结果</text>
  <button class="btn-primary" bindtap="startQuiz">开始测验</button>
</view>
