.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
  box-sizing: border-box;
  background: #f5f0e8;
}

.card {
  background: #fffef8;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(212, 175, 55, 0.22);
  box-shadow: 0 6rpx 20rpx rgba(26, 35, 126, 0.06);
  box-sizing: border-box;
}

.lead-card {
  border-left: 6rpx solid rgba(201, 162, 39, 0.65);
}

.lead-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #3949ab;
  margin-bottom: 16rpx;
}

.lead-body {
  display: block;
  font-size: 28rpx;
  line-height: 1.75;
  color: #3e3428;
  text-align: justify;
}

.lead-note {
  display: block;
  margin-top: 20rpx;
  font-size: 22rpx;
  line-height: 1.55;
  color: #8d7b68;
}

.sec-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #3949ab;
  margin-bottom: 20rpx;
}

.table-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}

.table-row-last {
  border-bottom: none;
  padding-bottom: 0;
}

.col-a {
  flex: 0 0 88rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #5c4d3d;
}

.col-b {
  flex: 1;
  font-size: 26rpx;
  line-height: 1.6;
  color: #4a4034;
}

.para {
  display: block;
  font-size: 26rpx;
  line-height: 1.65;
  color: #4a4034;
}

.muted-card {
  background: rgba(245, 240, 232, 0.9);
  border-style: dashed;
}

.muted {
  font-size: 24rpx;
  line-height: 1.6;
  color: #8d7b68;
}
