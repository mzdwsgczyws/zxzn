.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
  box-sizing: border-box;
  background: var(--dao-bg-page);
}

.lead-card {
  border-left: 6rpx solid rgba(201, 162, 39, 0.65);
}

.lead-title {
  display: block;
  font-family: "DaoDisplay", "Songti SC", "STSong", "Noto Serif CJK SC", serif;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--dao-purple-mid);
  margin-bottom: 16rpx;
}

.lead-body {
  display: block;
  font-size: 28rpx;
  line-height: 1.75;
  color: #3e3428;
  text-align: justify;
}

.lead-note {
  display: block;
  margin-top: 20rpx;
  font-size: 22rpx;
  line-height: 1.55;
  color: var(--dao-ink-faint);
}

.sec-title {
  display: block;
  font-family: "DaoDisplay", "Songti SC", "STSong", "Noto Serif CJK SC", serif;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--dao-purple-mid);
  margin-bottom: 20rpx;
}

.table-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}

.table-row-last {
  border-bottom: none;
  padding-bottom: 0;
}

.col-a {
  flex: 0 0 88rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--dao-brown-warm);
}

.col-b {
  flex: 1;
  font-size: 26rpx;
  line-height: 1.6;
  color: var(--dao-ink-body);
}

.para {
  display: block;
  font-size: 26rpx;
  line-height: 1.65;
  color: var(--dao-ink-body);
}

.muted-card {
  background: rgba(245, 240, 232, 0.9);
  border-style: dashed;
}

.muted {
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--dao-ink-faint);
}
