.tree-hole-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1028 0%, #2d1f3d 40%, #1e1530 100%);
  padding-bottom: env(safe-area-inset-bottom);
}

/* ── Hero ── */
.th-hero {
  padding: 80rpx 48rpx 40rpx;
  text-align: center;
}
.th-hero-title {
  font-family: "DaoDisplay", "Songti SC", "Noto Serif SC", "STSong", serif;
  font-size: 56rpx;
  font-weight: 700;
  color: #d4a857;
  letter-spacing: 8rpx;
  margin-bottom: 24rpx;
  text-shadow: 0 0 24rpx rgba(212, 168, 87, 0.3);
}
.th-hero-sub {
  font-family: "DaoDisplay", "Songti SC", "Noto Serif SC", "STSong", serif;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.55);
  line-height: 1.8;
}

/* ── 匿名承诺 ── */
.th-anon-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 32rpx 32rpx;
  padding: 16rpx 24rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}
.th-anon-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}
.th-anon-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  letter-spacing: 1rpx;
}

/* ── 写信卡片 ── */
.th-letter-card {
  margin: 0 32rpx 40rpx;
  padding: 36rpx 32rpx 28rpx;
  background: #faf5e8;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
  position: relative;
}
.th-letter-label {
  font-family: "DaoDisplay", "Songti SC", "Noto Serif SC", "STSong", serif;
  font-size: 28rpx;
  color: #5a4a3a;
  margin-bottom: 20rpx;
  letter-spacing: 2rpx;
}
.th-textarea {
  width: 100%;
  min-height: 200rpx;
  max-height: 400rpx;
  font-family: "DaoDisplay", "Songti SC", "Noto Serif SC", "STSong", serif;
  font-size: 28rpx;
  color: #3a2e22;
  line-height: 2;
  background: transparent;
  background-image: repeating-linear-gradient(
    transparent,
    transparent 55rpx,
    rgba(180, 160, 130, 0.2) 55rpx,
    rgba(180, 160, 130, 0.2) 56rpx
  );
  padding: 0;
  box-sizing: border-box;
}
.th-char-count {
  text-align: right;
  font-size: 22rpx;
  color: #b8a88a;
  margin-top: 12rpx;
}

/* ── 提交按钮 ── */
.th-submit-wrap {
  margin-top: 24rpx;
}
.th-submit-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #d4a857 0%, #b8860b 100%);
  color: #fff;
  font-family: "DaoDisplay", "Songti SC", "Noto Serif SC", "STSong", serif;
  font-size: 30rpx;
  letter-spacing: 4rpx;
  border-radius: 12rpx;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(212, 168, 87, 0.3);
  transition: all 0.3s ease;
}
.th-submit-btn::after {
  border: none;
}
.th-submit-btn[disabled] {
  opacity: 0.4;
  background: linear-gradient(135deg, #a08050 0%, #806020 100%);
}
.th-submitting {
  transform: scale(0.97);
}
.th-daily-hint {
  text-align: center;
  font-size: 20rpx;
  color: #b8a88a;
  margin-top: 16rpx;
}

/* ── 飞入动画 ── */
.th-fly-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.5);
  opacity: 0;
  pointer-events: none;
}
.th-fly-active {
  opacity: 1;
  pointer-events: auto;
  animation: flyFadeIn 0.3s ease-out forwards;
}
.th-fly-letter {
  font-size: 100rpx;
  animation: flyIn 1s ease-in-out forwards;
}
@keyframes flyFadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
@keyframes flyIn {
  0% { transform: scale(1) translateY(0); opacity: 1; }
  60% { transform: scale(0.6) translateY(-200rpx); opacity: 0.8; }
  100% { transform: scale(0.1) translateY(-600rpx); opacity: 0; }
}

/* ── 分隔线 ── */
.th-divider {
  display: flex;
  align-items: center;
  margin: 16rpx 48rpx 32rpx;
}
.th-divider-line {
  flex: 1;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(212, 168, 87, 0.3), transparent);
}
.th-divider-text {
  font-family: "DaoDisplay", "Songti SC", "Noto Serif SC", "STSong", serif;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
  margin: 0 24rpx;
  letter-spacing: 4rpx;
}

/* ── 回信卡片 ── */
.th-reply-card {
  margin: 0 32rpx 24rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.06);
  overflow: hidden;
  display: flex;
}
.th-reply-seal {
  width: 8rpx;
  flex-shrink: 0;
  background: linear-gradient(180deg, #c0392b, #a0301e);
  border-radius: 4rpx 0 0 4rpx;
}
.th-reply-body {
  flex: 1;
  padding: 28rpx 28rpx 20rpx;
}
.th-reply-section {
  margin-bottom: 20rpx;
}
.th-reply-label {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.35);
  margin-bottom: 8rpx;
  letter-spacing: 2rpx;
}
.th-reply-content {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.7;
}
.th-reply-answer {
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
}
.th-reply-text {
  color: #d4a857;
}
.th-reply-time {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.25);
}

/* ── 等待中卡片 ── */
.th-pending-card {
  margin: 0 32rpx 24rpx;
  padding: 24rpx 28rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx dashed rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: flex-start;
}
.th-pending-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
  margin-top: 4rpx;
}
.th-pending-body {
  flex: 1;
}
.th-pending-content {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
  line-height: 1.6;
  margin-bottom: 8rpx;
}
.th-pending-hint {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.3);
  font-style: italic;
}
.th-pending-time {
  display: block;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.2);
  margin-top: 8rpx;
}

/* ── 空状态 ── */
.th-empty {
  text-align: center;
  padding: 60rpx 0;
}
.th-empty-icon {
  display: block;
  font-size: 60rpx;
  margin-bottom: 16rpx;
}
.th-empty-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.3);
}

.th-footer {
  height: 60rpx;
}
