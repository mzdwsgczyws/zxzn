.tree-hole-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1028 0%, #2d1f3d 40%, #1e1530 100%);
  background-image:
    radial-gradient(ellipse at 20% 30%, rgba(61, 43, 105, 0.3) 0%, transparent 50%),
    radial-gradient(ellipse at 80% 70%, rgba(42, 31, 74, 0.25) 0%, transparent 50%),
    radial-gradient(circle at 50% 0%, rgba(212, 175, 55, 0.03) 0%, transparent 40%),
    linear-gradient(180deg, #1a1028 0%, #2d1f3d 40%, #1e1530 100%);
  padding-bottom: env(safe-area-inset-bottom);
}

/* ── Hero ── */
.th-hero {
  padding: 80rpx 48rpx 48rpx;
  text-align: center;
  animation: daoHeroIn 0.6s cubic-bezier(0.23, 1, 0.32, 1) both;
}
.th-hero-title {
  font-family: var(--dao-font-display);
  font-size: 56rpx;
  font-weight: 700;
  color: var(--dao-gold);
  letter-spacing: 10rpx;
  margin-bottom: 28rpx;
  text-shadow:
    0 0 20rpx rgba(212, 175, 55, 0.35),
    0 0 60rpx rgba(212, 175, 55, 0.1),
    0 2rpx 0 rgba(60, 40, 20, 0.3);
}
.th-hero-sub {
  font-family: var(--dao-font-display);
  font-size: 26rpx;
  color: rgba(232, 224, 208, 0.5);
  line-height: 1.9;
  letter-spacing: 1rpx;
}

/* ── 匿名承诺 ── */
.th-anon-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 32rpx 36rpx;
  padding: 18rpx 28rpx;
  background: rgba(255, 255, 255, 0.04);
  border-radius: 12rpx;
  border: 1rpx solid rgba(212, 175, 55, 0.1);
  box-shadow: 0 0 20rpx rgba(212, 175, 55, 0.04);
}
.th-anon-icon {
  font-size: 28rpx;
  margin-right: 14rpx;
}
.th-anon-text {
  font-size: var(--dao-fs-caption);
  color: rgba(232, 224, 208, 0.45);
  letter-spacing: 1rpx;
}

/* ── 写信卡片 ── */
.th-letter-card {
  margin: 0 32rpx 40rpx;
  padding: 36rpx 32rpx 28rpx;
  background: #faf5e8;
  border-radius: 16rpx;
  box-shadow:
    0 8rpx 32rpx rgba(0, 0, 0, 0.25),
    0 16rpx 48rpx rgba(0, 0, 0, 0.1),
    3rpx 4rpx 0 rgba(200, 185, 155, 0.35);
  position: relative;
}
.th-letter-card::before {
  content: '';
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  width: 40rpx;
  height: 40rpx;
  border-top: 2rpx solid rgba(192, 64, 64, 0.2);
  border-left: 2rpx solid rgba(192, 64, 64, 0.2);
  border-radius: 4rpx 0 0 0;
  pointer-events: none;
}
.th-letter-card::after {
  content: '';
  position: absolute;
  bottom: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  border-bottom: 2rpx solid rgba(192, 64, 64, 0.2);
  border-right: 2rpx solid rgba(192, 64, 64, 0.2);
  border-radius: 0 0 4rpx 0;
  pointer-events: none;
}
.th-letter-label {
  font-family: var(--dao-font-display);
  font-size: var(--dao-fs-sub);
  color: var(--dao-brown-warm);
  margin-bottom: 20rpx;
  letter-spacing: 3rpx;
}
.th-textarea {
  width: 100%;
  min-height: 200rpx;
  max-height: 400rpx;
  font-family: var(--dao-font-display);
  font-size: var(--dao-fs-sub);
  color: var(--dao-ink);
  line-height: 2;
  background: transparent;
  background-image: repeating-linear-gradient(
    transparent,
    transparent 55rpx,
    rgba(180, 160, 130, 0.15) 55rpx,
    rgba(180, 160, 130, 0.15) 56rpx
  );
  padding: 0;
  box-sizing: border-box;
}
.th-char-count {
  text-align: right;
  font-size: var(--dao-fs-caption);
  color: var(--dao-ink-light);
  margin-top: 12rpx;
}

/* ── 提交按钮 ── */
.th-submit-wrap {
  margin-top: 28rpx;
}
.th-submit-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(165deg, #f0dfa0 0%, #d4af37 40%, #b8892a 100%);
  color: #2a1f15;
  font-family: var(--dao-font-display);
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 5rpx;
  border-radius: 12rpx;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(166, 124, 31, 0.3), 0 1rpx 0 rgba(255, 248, 220, 0.4) inset;
  transition: transform 0.15s ease, box-shadow 0.2s ease;
}
.th-submit-btn::after {
  border: none;
}
.th-submit-btn:active {
  transform: translateY(2rpx);
}
.th-submit-btn[disabled] {
  opacity: 0.35;
  background: linear-gradient(165deg, #a09070 0%, #806828 100%);
}
.th-submitting {
  transform: scale(0.97);
}
.th-daily-hint {
  text-align: center;
  font-size: var(--dao-fs-fine);
  color: var(--dao-ink-light);
  margin-top: 16rpx;
  letter-spacing: 1rpx;
}

/* ── 飞入动画 ── */
.th-fly-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.5);
  opacity: 0;
  pointer-events: none;
}
.th-fly-active {
  opacity: 1;
  pointer-events: auto;
  animation: flyFadeIn 0.3s ease-out forwards;
}
.th-fly-letter {
  font-size: 100rpx;
  animation: flyIn 1s ease-in-out forwards;
}
@keyframes flyFadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
@keyframes flyIn {
  0% { transform: scale(1) translateY(0); opacity: 1; }
  60% { transform: scale(0.6) translateY(-200rpx); opacity: 0.8; }
  100% { transform: scale(0.1) translateY(-600rpx); opacity: 0; }
}

/* ── 分隔线 ── */
.th-divider {
  display: flex;
  align-items: center;
  margin: 24rpx 48rpx 36rpx;
}
.th-divider-line {
  flex: 1;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(212, 175, 55, 0.25), transparent);
}
.th-divider-text {
  font-family: var(--dao-font-display);
  font-size: var(--dao-fs-caption);
  color: rgba(232, 224, 208, 0.35);
  margin: 0 28rpx;
  letter-spacing: 6rpx;
}

/* ── 回信卡片 ── */
.th-reply-card {
  margin: 0 32rpx 24rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(212, 175, 55, 0.08);
  overflow: hidden;
  display: flex;
}
.th-reply-seal {
  width: 10rpx;
  flex-shrink: 0;
  background: linear-gradient(180deg, var(--dao-cinnabar), #8a2020);
  border-radius: 4rpx 0 0 4rpx;
  position: relative;
}
.th-reply-seal::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 6rpx;
  height: 6rpx;
  margin: -3rpx 0 0 -3rpx;
  border-radius: 50%;
  background: rgba(255, 200, 200, 0.3);
}
.th-reply-body {
  flex: 1;
  padding: 28rpx 28rpx 20rpx;
}
.th-reply-section {
  margin-bottom: 20rpx;
}
.th-reply-label {
  display: block;
  font-family: var(--dao-font-display);
  font-size: var(--dao-fs-caption);
  color: rgba(232, 224, 208, 0.3);
  margin-bottom: 10rpx;
  letter-spacing: 3rpx;
}
.th-reply-content {
  display: block;
  font-size: var(--dao-fs-body);
  color: rgba(232, 224, 208, 0.65);
  line-height: 1.75;
}
.th-reply-answer {
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(212, 175, 55, 0.08);
}
.th-reply-text {
  color: var(--dao-gold);
  font-family: var(--dao-font-display);
}
.th-reply-time {
  font-size: var(--dao-fs-fine);
  color: rgba(232, 224, 208, 0.2);
  margin-top: 8rpx;
}

/* ── 等待中卡片 ── */
.th-pending-card {
  margin: 0 32rpx 24rpx;
  padding: 24rpx 28rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.03);
  border: 1rpx dashed rgba(212, 175, 55, 0.12);
  display: flex;
  align-items: flex-start;
}
.th-pending-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
  margin-top: 4rpx;
  animation: daoBreath 3s ease-in-out infinite;
}
.th-pending-body {
  flex: 1;
}
.th-pending-content {
  display: block;
  font-size: var(--dao-fs-body);
  color: rgba(232, 224, 208, 0.45);
  line-height: 1.6;
  margin-bottom: 8rpx;
}
.th-pending-hint {
  display: block;
  font-family: var(--dao-font-display);
  font-size: var(--dao-fs-caption);
  color: rgba(232, 224, 208, 0.25);
  font-style: italic;
  letter-spacing: 1rpx;
}
.th-pending-time {
  display: block;
  font-size: var(--dao-fs-fine);
  color: rgba(232, 224, 208, 0.18);
  margin-top: 8rpx;
}

/* ── 空状态 ── */
.th-empty {
  text-align: center;
  padding: 80rpx 0;
}
.th-empty-icon {
  display: block;
  font-size: 64rpx;
  margin-bottom: 20rpx;
  opacity: 0.6;
}
.th-empty-text {
  font-family: var(--dao-font-display);
  font-size: var(--dao-fs-caption);
  color: rgba(232, 224, 208, 0.25);
  letter-spacing: 2rpx;
}

.th-footer {
  height: 80rpx;
}
