.page {
  min-height: 100vh;
  background: var(--dao-bg-page);
  padding-bottom: env(safe-area-inset-bottom);
}

.period-tabs {
  display: flex;
  justify-content: center;
  gap: 32rpx;
  padding: 32rpx 0 16rpx;
}

.tab {
  font-family: "DaoDisplay", "Songti SC", "STSong", "Noto Serif CJK SC", serif;
  font-size: 28rpx;
  color: var(--dao-ink-muted);
  padding: 8rpx 32rpx;
  border-radius: 32rpx;
  background: transparent;
  transition: all 0.2s;
}

.tab--on {
  color: var(--dao-gold);
  background: var(--dao-ritual-purple-a);
  font-weight: 600;
}

.sec-title {
  display: block;
  font-family: "DaoDisplay", "Songti SC", "STSong", "Noto Serif CJK SC", serif;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--dao-gold-pale);
  margin-bottom: 24rpx;
}

.stat-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-num {
  font-family: var(--dao-font-display);
  font-size: 44rpx;
  font-weight: 700;
  color: var(--dao-purple-deep);
}

.stat-label {
  font-size: 22rpx;
  color: var(--dao-ink-faint);
  margin-top: 4rpx;
}

.mood-bars {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.mood-bar-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.mood-emoji {
  font-size: 32rpx;
  width: 44rpx;
  text-align: center;
}

.mood-bar-track {
  flex: 1;
  height: 20rpx;
  border-radius: 10rpx;
  background: var(--dao-divider);
  overflow: hidden;
}

.mood-bar-fill {
  height: 100%;
  border-radius: 10rpx;
  background: linear-gradient(90deg, var(--dao-purple-mid), var(--dao-purple-deep));
  transition: width 0.3s ease;
}

.mood-count {
  font-size: 22rpx;
  color: var(--dao-ink-faint);
  width: 40rpx;
  text-align: right;
}

.bottom-actions {
  padding: 32rpx 48rpx;
}
