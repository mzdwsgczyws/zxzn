.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #ede8df 0%, #f5f0e8 35%, #ebe4d8 100%);
  box-sizing: border-box;
}

.hero {
  flex-shrink: 0;
  padding: 36rpx 32rpx 28rpx;
  background: linear-gradient(180deg, #3d2b69 0%, #2a1f4a 100%);
  border-bottom: 2rpx solid rgba(212, 175, 55, 0.45);
}

.hero-title {
  display: block;
  font-family: "DaoDisplay", "Songti SC", "STSong", "Noto Serif CJK SC", serif;
  font-size: var(--dao-fs-hero);
  font-weight: 700;
  color: #e8d4a8;
  letter-spacing: 6rpx;
  margin-bottom: 12rpx;
  animation: daoHeroIn 0.5s ease both;
}

.hero-sub {
  display: block;
  font-size: var(--dao-fs-caption);
  color: rgba(232, 212, 168, 0.75);
  line-height: 1.5;
}

.empty {
  padding: 120rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.empty-moon {
  font-size: 88rpx;
  color: rgba(74, 58, 107, 0.35);
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #4a3a6b;
  margin-bottom: 16rpx;
}

.empty-body {
  font-size: 26rpx;
  color: #7a6e62;
  line-height: 1.65;
  max-width: 560rpx;
}

.list {
  flex: 1;
  min-height: 0;
  padding: 24rpx 24rpx calc(32rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.lh-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
  background: rgba(255, 252, 245, 0.92);
  border-radius: 20rpx;
  border: 1rpx solid rgba(212, 175, 55, 0.28);
  box-shadow: 0 8rpx 28rpx rgba(45, 34, 74, 0.08);
  box-sizing: border-box;
  border-left: 6rpx solid transparent;
}

.card-left {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
}

.tier-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.card-text {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.lot-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #2a1f15;
}

.lot-tier {
  font-size: 22rpx;
  font-weight: 600;
}

.card-right {
  flex-shrink: 0;
  text-align: right;
  margin-left: 16rpx;
}

.time-main {
  display: block;
  font-size: 24rpx;
  color: #5c4d3f;
  font-weight: 500;
}

.time-sub {
  display: block;
  font-size: 20rpx;
  color: #9a8b7a;
  margin-top: 4rpx;
}
