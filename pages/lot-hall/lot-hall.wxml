<view class="page">
  <view class="hero">
    <text class="hero-title">首次收录</text>
    <text class="hero-sub">按第一次收录该条的时间排序 · 共 {{rows.length}} / 64 条</text>
  </view>

  <empty-state
    wx:if="{{empty}}"
    icon="☽"
    title="展馆还是空的"
    body="在首页或心象箴言页成功生成后，每一条「第一次」收录的时间会出现在这里。"
  />

  <scroll-view wx:else scroll-y class="list" enhanced="{{true}}">
    <view class="card" wx:for="{{rows}}" wx:key="lotId">
      <view class="card-left">
        <view class="tier-dot" style="background: {{item.tierColor}};"></view>
        <view class="card-text">
          <text class="lot-name">{{item.name}}</text>
          <text class="lot-tier" style="color: {{item.tierColor}};">{{item.tier}}</text>
        </view>
      </view>
      <view class="card-right">
        <text class="time-main">{{item.dateTimeLabel}}</text>
        <text class="time-sub">日历日 {{item.dateStr}}</text>
      </view>
    </view>
  </scroll-view>
</view>
