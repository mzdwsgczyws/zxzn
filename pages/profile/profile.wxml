<view class="page dao-paper-bg">
  <view class="card rank-card" wx:if="{{rankInfo}}">
    <view class="rank-header">
      <text class="rank-title">{{rankInfo.rank.name}}</text>
      <text class="rank-score">修行积分 {{rankInfo.score}}</text>
    </view>
    <view class="rank-bar-wrap">
      <view class="rank-bar-bg">
        <view class="rank-bar-fill" style="width: {{rankInfo.progress}}%;"></view>
      </view>
      <text class="rank-bar-label" wx:if="{{rankInfo.nextRank}}">距「{{rankInfo.nextRank.name}}」还需 {{rankInfo.nextRank.threshold - rankInfo.score}} 分</text>
      <text class="rank-bar-label" wx:else>已臻圆满</text>
    </view>
  </view>

  <view class="card">
    <view class="pf-header" bindtap="toggleForm">
      <view class="pf-header-left">
        <text class="title-lg">个人档案</text>
        <text class="pf-summary">{{profileSummary}}</text>
      </view>
      <text class="pf-toggle-arrow {{formExpanded ? 'pf-toggle-open' : ''}}">›</text>
    </view>

    <view class="pf-form-body {{formExpanded ? 'pf-form-expanded' : 'pf-form-collapsed'}}">
    <text class="subtitle" style="margin-top:16rpx;">用于心象箴言与建议的个性化参考；未填写的项不会使用。以下带「箴言上下文」的项填齐后，抽取时将不再提示完善档案。</text>

    <view class="field section-gap">
      <text class="label">近期状态（箴言上下文）</text>
      <text class="loc-hint">自评近几日整体状态，非医疗记录。</text>
      <picker mode="selector" range="{{recentLabels}}" value="{{recentIndex}}" bindchange="onRecentPick">
        <view class="picker-val">{{recentLabels[recentIndex]}}</view>
      </picker>
    </view>
    <view class="field">
      <text class="label">签文语气匹配（箴言上下文）</text>
      <text class="loc-hint">自动：综合「近期状态」与道性四维（动/刚/散/显）推测；也可固定偏安抚、鼓励、同理，或只用中性签条。</text>
      <picker mode="selector" range="{{emotionLabels}}" value="{{emotionIndex}}" bindchange="onEmotionPick">
        <view class="picker-val">{{emotionLabels[emotionIndex]}}</view>
      </picker>
    </view>
    <view class="field">
      <text class="label">作息倾向（箴言上下文）</text>
      <picker mode="selector" range="{{rhythmLabels}}" value="{{rhythmIndex}}" bindchange="onRhythmPick">
        <view class="picker-val">{{rhythmLabels[rhythmIndex]}}</view>
      </picker>
    </view>
    <view class="field">
      <text class="label">近期关注领域（可多选，箴言上下文）</text>
      <text class="loc-hint">只选大类，不必填写具体事由。</text>
      <view class="tag-row">
        <view
          wx:for="{{focusChips}}"
          wx:key="id"
          class="tag-chip {{item.on ? 'tag-on' : ''}}"
          data-id="{{item.id}}"
          bindtap="toggleFocus"
        >
          <text>{{item.label}}</text>
        </view>
      </view>
    </view>
    <view class="field">
      <text class="label">释义展示偏好（箴言上下文）</text>
      <picker mode="selector" range="{{styleLabels}}" value="{{styleIndex}}" bindchange="onStylePick">
        <view class="picker-val">{{styleLabels[styleIndex]}}</view>
      </picker>
    </view>

    <view class="field">
      <text class="label">年龄</text>
      <input class="input" type="number" placeholder="不填则生成建议时跳过年龄分支" value="{{age}}" bindinput="onAge" />
    </view>
    <view class="field">
      <text class="label">性别</text>
      <picker mode="selector" range="{{genderLabels}}" value="{{genderIndex}}" bindchange="onGenderPick">
        <view class="picker-val">{{genderLabels[genderIndex]}}</view>
      </picker>
    </view>
    <view class="field">
      <text class="label">出生公历年</text>
      <input class="input" type="number" placeholder="如 1995（用于梅花易数与紫微排盘）" value="{{birthYear}}" bindinput="onBirthYear" />
    </view>
    <view class="field">
      <text class="label">出生公历月份（1–12）</text>
      <input class="input" type="number" placeholder="用于紫微斗数宫位排盘" value="{{birthMonth}}" bindinput="onBirthMonth" />
    </view>
    <view class="field">
      <text class="label">出生公历日（1–31）</text>
      <input class="input" type="number" placeholder="如 15（用于梅花起卦与紫微排盘）" value="{{birthDay}}" bindinput="onBirthDay" />
    </view>
    <view class="field">
      <text class="label">出生时辰</text>
      <text class="loc-hint">十二时辰用于梅花易数起卦与紫微斗数命宫安置，不详可跳过。</text>
      <picker mode="selector" range="{{shichenLabels}}" value="{{birthHourIndex}}" bindchange="onBirthHourPick">
        <view class="picker-val">{{shichenLabels[birthHourIndex]}}</view>
      </picker>
    </view>

    <view class="field section-gap">
      <text class="label">参考地区（可选）</text>
      <text class="loc-hint">手动选择国家、省/直辖市与二级城市，可补充街道等文字；保存时将尝试解析经纬度以获取天气（不调用地图与定位权限）。</text>

      <text class="label label-sm">国家 / 地区</text>
      <picker mode="selector" range="{{countryLabels}}" value="{{countryIndex}}" bindchange="onCountryPick">
        <view class="picker-val">{{countryLabels[countryIndex]}}</view>
      </picker>

      <text class="label label-sm">省 / 直辖市</text>
      <picker wx:if="{{!addrIsOther}}" mode="selector" range="{{provinceLabels}}" value="{{provinceIndex}}" bindchange="onProvincePick">
        <view class="picker-val">{{provinceLabels[provinceIndex]}}</view>
      </picker>
      <view wx:else class="picker-val picker-muted">—</view>

      <text class="label label-sm">二级城市</text>
      <picker wx:if="{{!addrIsOther}}" mode="selector" range="{{cityLabels}}" value="{{cityIndex}}" bindchange="onCityPick">
        <view class="picker-val">{{cityLabels[cityIndex]}}</view>
      </picker>
      <view wx:else class="picker-val picker-muted">—</view>

      <text class="label label-sm">详细地址（可选）</text>
      <textarea
        class="input textarea"
        value="{{addrDetail}}"
        bindinput="onAddrDetail"
        placeholder="如：街道、小区、门牌等，选填"
        maxlength="120"
        auto-height
      />

      <view class="loc-row" wx:if="{{addrSummary}}">
        <text class="loc-name">{{addrSummary}}</text>
      </view>
      <text class="loc-empty" wx:elif="{{!hasAddressText}}">当前未填写地区</text>
      <text class="loc-hint" wx:if="{{geocodeHint}}">{{geocodeHint}}</text>

      <view class="loc-row">
        <button class="btn-ghost loc-clear" bindtap="clearAddress">清除地区</button>
      </view>
    </view>

    <view class="field section-gap">
      <text class="label">显示设置</text>
      <view class="row-switch">
        <text class="label" style="margin-bottom:0;">大字体模式</text>
        <switch checked="{{largeFont}}" bindchange="onLargeFontChange" />
      </view>
    </view>

    <button class="btn-primary" bindtap="save">保存</button>

    <view class="field section-gap">
      <text class="label">数据备份</text>
      <view class="backup-row">
        <button class="btn-backup" hover-class="btn-hover" bindtap="onExport">导出数据</button>
        <button class="btn-backup" hover-class="btn-hover" bindtap="onImport">导入数据</button>
      </view>
    </view>
    </view><!-- pf-form-body -->
  </view>

  <view class="card muted-card">
    <text class="muted">未完成道性测验时，箴言建议会略偏通用；测验后通常更贴个人状态。</text>
  </view>

  <view class="card theory-card">
    <text class="title-lg theory-card-title">量化 × 修道</text>
    <text class="subtitle theory-card-sub">文化意象与系统科学的类比简介，可随时回看，不必每次阅读。</text>
    <button class="btn-ghost theory-card-btn" bindtap="goTheoryIntro">查看简介</button>
  </view>

  <view class="card hall-links-card">
    <text class="title-lg hall-links-title">展馆与报告</text>
    <text class="subtitle hall-links-sub">趋势走势、已收录条目、成就与修炼报告。</text>
    <view class="hall-links-row">
      <button class="btn-ghost hall-link-btn" bindtap="goFortuneTrend">趋势日历</button>
      <button class="btn-ghost hall-link-btn" bindtap="goLotHall">心象展馆</button>
      <button class="btn-ghost hall-link-btn" bindtap="goAchieveHall">成就展馆</button>
      <button class="btn-ghost hall-link-btn" bindtap="goReport">修炼报告</button>
      <button class="btn-ghost hall-link-btn" bindtap="goAnnualReport">年度报告</button>
      <button class="btn-ghost hall-link-btn" bindtap="goCompatibility">道性配对</button>
    </view>
  </view>

  <view class="card treehole-entry-card" bindtap="goTreeHole">
    <text class="treehole-entry-icon">🌿</text>
    <view class="treehole-entry-body">
      <text class="treehole-entry-title">心事寄此 · 匿名树洞</text>
      <text class="treehole-entry-sub">写下烦恼，静候道观主人回信</text>
    </view>
    <text class="treehole-entry-arrow">›</text>
  </view>
</view>
