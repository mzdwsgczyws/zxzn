<view class="page">
  <view class="card">
    <text class="title-lg">用于箴言上下文与解读（仅存本机）</text>
    <text class="subtitle">用于心象箴言与建议的个性化参考；未填写的项不会使用。以下带「箴言上下文」的项填齐后，抽取时将不再提示完善档案。</text>

    <view class="field section-gap">
      <text class="label">近期状态（箴言上下文）</text>
      <text class="loc-hint">自评近几日整体状态，非医疗记录。</text>
      <picker mode="selector" range="{{recentLabels}}" value="{{recentIndex}}" bindchange="onRecentPick">
        <view class="picker-val">{{recentLabels[recentIndex]}}</view>
      </picker>
    </view>
    <view class="field">
      <text class="label">签文语气匹配（箴言上下文）</text>
      <text class="loc-hint">自动：综合「近期状态」与道性四维（动/刚/散/显）推测；也可固定偏安抚、鼓励、同理，或只用中性签条。</text>
      <picker mode="selector" range="{{emotionLabels}}" value="{{emotionIndex}}" bindchange="onEmotionPick">
        <view class="picker-val">{{emotionLabels[emotionIndex]}}</view>
      </picker>
    </view>
    <view class="field">
      <text class="label">作息倾向（箴言上下文）</text>
      <picker mode="selector" range="{{rhythmLabels}}" value="{{rhythmIndex}}" bindchange="onRhythmPick">
        <view class="picker-val">{{rhythmLabels[rhythmIndex]}}</view>
      </picker>
    </view>
    <view class="field">
      <text class="label">近期关注领域（可多选，箴言上下文）</text>
      <text class="loc-hint">只选大类，不必填写具体事由。</text>
      <view class="tag-row">
        <view
          wx:for="{{focusChips}}"
          wx:key="id"
          class="tag-chip {{item.on ? 'tag-on' : ''}}"
          data-id="{{item.id}}"
          bindtap="toggleFocus"
        >
          <text>{{item.label}}</text>
        </view>
      </view>
    </view>
    <view class="field">
      <text class="label">释义展示偏好（箴言上下文）</text>
      <picker mode="selector" range="{{styleLabels}}" value="{{styleIndex}}" bindchange="onStylePick">
        <view class="picker-val">{{styleLabels[styleIndex]}}</view>
      </picker>
    </view>

    <view class="field">
      <text class="label">年龄</text>
      <input class="input" type="number" placeholder="不填则生成建议时跳过年龄分支" value="{{age}}" bindinput="onAge" />
    </view>
    <view class="field">
      <text class="label">性别</text>
      <picker mode="selector" range="{{genderLabels}}" value="{{genderIndex}}" bindchange="onGenderPick">
        <view class="picker-val">{{genderLabels[genderIndex]}}</view>
      </picker>
    </view>
    <view class="field">
      <text class="label">出生公历月份（1–12）</text>
      <input class="input" type="number" placeholder="用于简化斗数宫位映射" value="{{birthMonth}}" bindinput="onBirthMonth" />
    </view>

    <view class="field section-gap">
      <text class="label">参考地区（可选）</text>
      <text class="loc-hint">手动选择国家、省/直辖市与二级城市，可补充街道等文字；保存时将尝试解析经纬度以获取天气（不调用地图与定位权限）。</text>

      <text class="label label-sm">国家 / 地区</text>
      <picker mode="selector" range="{{countryLabels}}" value="{{countryIndex}}" bindchange="onCountryPick">
        <view class="picker-val">{{countryLabels[countryIndex]}}</view>
      </picker>

      <text class="label label-sm">省 / 直辖市</text>
      <picker wx:if="{{!addrIsOther}}" mode="selector" range="{{provinceLabels}}" value="{{provinceIndex}}" bindchange="onProvincePick">
        <view class="picker-val">{{provinceLabels[provinceIndex]}}</view>
      </picker>
      <view wx:else class="picker-val picker-muted">—</view>

      <text class="label label-sm">二级城市</text>
      <picker wx:if="{{!addrIsOther}}" mode="selector" range="{{cityLabels}}" value="{{cityIndex}}" bindchange="onCityPick">
        <view class="picker-val">{{cityLabels[cityIndex]}}</view>
      </picker>
      <view wx:else class="picker-val picker-muted">—</view>

      <text class="label label-sm">详细地址（可选）</text>
      <textarea
        class="input textarea"
        value="{{addrDetail}}"
        bindinput="onAddrDetail"
        placeholder="如：街道、小区、门牌等，选填"
        maxlength="120"
        auto-height
      />

      <view class="loc-row" wx:if="{{addrSummary}}">
        <text class="loc-name">{{addrSummary}}</text>
      </view>
      <text class="loc-empty" wx:elif="{{!hasAddressText}}">当前未填写地区</text>
      <text class="loc-hint" wx:if="{{geocodeHint}}">{{geocodeHint}}</text>

      <view class="loc-row">
        <button class="btn-ghost loc-clear" bindtap="clearAddress">清除地区</button>
      </view>
    </view>

    <button class="btn-primary" bindtap="save">保存</button>
  </view>

  <view class="card muted-card">
    <text class="muted">未完成道性测验时，箴言建议会略偏通用；测验后通常更贴个人状态。</text>
  </view>

  <view class="card theory-card">
    <text class="title-lg theory-card-title">量化 × 修道</text>
    <text class="subtitle theory-card-sub">文化意象与系统科学的类比简介，可随时回看，不必每次阅读。</text>
    <button class="btn-ghost theory-card-btn" bindtap="goTheoryIntro">查看简介</button>
  </view>

  <view class="card hall-links-card">
    <text class="title-lg hall-links-title">展馆</text>
    <text class="subtitle hall-links-sub">心象日历、已收录条目与成就（与首页入口一致）。</text>
    <view class="hall-links-row">
      <button class="btn-ghost hall-link-btn" bindtap="goFortuneTrend">心象日历</button>
      <button class="btn-ghost hall-link-btn" bindtap="goLotHall">心象展馆</button>
      <button class="btn-ghost hall-link-btn" bindtap="goAchieveHall">成就展馆</button>
    </view>
  </view>
</view>
