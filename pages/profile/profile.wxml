<view class="page">
  <view class="card">
    <text class="title-lg">用于签运与解读（仅存本机）</text>
    <text class="subtitle">用于灵签与建议的个性化参考；未填写的项不会使用。以下带「签运增强」的项填齐后，抽签将不再提示完善档案。</text>

    <view class="field section-gap">
      <text class="label">近期状态（签运增强）</text>
      <text class="loc-hint">自评近几日整体状态，非医疗记录。</text>
      <picker mode="selector" range="{{recentLabels}}" value="{{recentIndex}}" bindchange="onRecentPick">
        <view class="picker-val">{{recentLabels[recentIndex]}}</view>
      </picker>
    </view>
    <view class="field">
      <text class="label">作息倾向（签运增强）</text>
      <picker mode="selector" range="{{rhythmLabels}}" value="{{rhythmIndex}}" bindchange="onRhythmPick">
        <view class="picker-val">{{rhythmLabels[rhythmIndex]}}</view>
      </picker>
    </view>
    <view class="field">
      <text class="label">近期关注领域（可多选，签运增强）</text>
      <text class="loc-hint">只选大类，不必填写具体事由。</text>
      <view class="tag-row">
        <view
          wx:for="{{focusChips}}"
          wx:key="id"
          class="tag-chip {{item.on ? 'tag-on' : ''}}"
          data-id="{{item.id}}"
          bindtap="toggleFocus"
        >
          <text>{{item.label}}</text>
        </view>
      </view>
    </view>
    <view class="field">
      <text class="label">签文释义展示偏好（签运增强）</text>
      <picker mode="selector" range="{{styleLabels}}" value="{{styleIndex}}" bindchange="onStylePick">
        <view class="picker-val">{{styleLabels[styleIndex]}}</view>
      </picker>
    </view>

    <view class="field">
      <text class="label">年龄</text>
      <input class="input" type="number" placeholder="不填则签运中跳过年龄分支" value="{{age}}" bindinput="onAge" />
    </view>
    <view class="field">
      <text class="label">性别</text>
      <picker mode="selector" range="{{genderLabels}}" value="{{genderIndex}}" bindchange="onGenderPick">
        <view class="picker-val">{{genderLabels[genderIndex]}}</view>
      </picker>
    </view>
    <view class="field">
      <text class="label">出生公历月份（1–12）</text>
      <input class="input" type="number" placeholder="用于简化斗数宫位映射" value="{{birthMonth}}" bindinput="onBirthMonth" />
    </view>

    <view class="field">
      <text class="label">参考位置（可选）</text>
      <text class="loc-hint">用于灵签结合当地天气；不选则不会读取定位，也不请求天气。</text>
      <view class="loc-row">
        <button class="btn-ghost loc-pick" bindtap="pickLocation">在地图上选择</button>
        <button wx:if="{{latitude != null}}" class="btn-ghost loc-clear" bindtap="clearLocation">清除</button>
      </view>
      <text class="loc-name" wx:if="{{locationName}}">{{locationName}}</text>
      <text class="loc-empty" wx:else>当前未保存位置</text>
    </view>

    <button class="btn-primary" bindtap="save">保存</button>
  </view>

  <view class="card muted-card">
    <text class="muted">未完成道性测验时，签文建议会略偏通用；测验后通常更贴个人状态。</text>
  </view>
</view>
