.page {
  min-height: 100vh;
  padding: 24rpx 0 64rpx;
}

.subtitle {
  display: block;
  margin: 12rpx 0 32rpx;
  font-size: 24rpx;
  color: var(--dao-ink-muted);
  line-height: 1.55;
}

.section-gap {
  margin-top: 8rpx;
  padding-top: 24rpx;
  border-top: 1rpx dashed rgba(139, 115, 85, 0.35);
}

.field {
  margin-bottom: 28rpx;
}

.tag-row {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 8rpx;
}

.tag-chip {
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  color: var(--dao-brown-warm);
  background: #f0ebe3;
  border: 2rpx solid #e0d8c8;
}

.tag-on {
  color: var(--dao-brown-warm);
  background: rgba(212, 175, 55, 0.12);
  border-color: var(--dao-gold);
}

.label {
  display: block;
  font-size: 26rpx;
  color: var(--dao-ink-body);
  margin-bottom: 12rpx;
}

.input {
  background: var(--dao-bg-card);
  border: 2rpx solid var(--dao-border-gold);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
}

.picker-val {
  background: var(--dao-bg-card);
  border: 2rpx solid var(--dao-border-gold);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: var(--dao-ink);
}

.muted-card {
  background: rgba(141, 123, 104, 0.08);
}

.muted {
  font-size: 24rpx;
  color: var(--dao-ink-caption);
  line-height: 1.6;
}

.loc-hint {
  display: block;
  font-size: 22rpx;
  color: var(--dao-ink-faint);
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.loc-row {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16rpx;
  align-items: center;
  margin-bottom: 12rpx;
}

.loc-pick,
.loc-clear {
  margin: 0 !important;
  flex: 1;
  min-width: 200rpx;
  font-size: 26rpx !important;
  padding: 16rpx 20rpx !important;
}

.loc-clear {
  flex: 0 0 auto;
  min-width: 120rpx;
}

.loc-name {
  display: block;
  font-size: 26rpx;
  color: var(--dao-purple-mid);
  line-height: 1.45;
}

.loc-empty {
  display: block;
  font-size: 24rpx;
  color: var(--dao-ink-caption);
}

.label-sm {
  margin-top: 20rpx;
  font-size: 24rpx;
  color: var(--dao-ink-muted);
}

.textarea {
  min-height: 120rpx;
  width: 100%;
  box-sizing: border-box;
  border: 2rpx solid var(--dao-border-gold);
  border-radius: 12rpx;
}

.picker-muted {
  color: var(--dao-ink-caption);
}

.theory-card {
  border-left: 6rpx solid rgba(201, 162, 39, 0.55);
}

.theory-card-title {
  color: var(--dao-purple-mid);
}

.theory-card-sub {
  margin-bottom: 20rpx !important;
}

.theory-card-btn {
  width: 100%;
  margin-top: 4rpx;
}

.hall-links-card .hall-links-title {
  font-size: 30rpx;
}

.hall-links-sub {
  margin-bottom: 24rpx !important;
}

.hall-links-row {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16rpx;
}

.hall-link-btn {
  flex: 1;
  min-width: 200rpx;
  margin: 0 !important;
  font-size: 26rpx !important;
  padding: 18rpx 20rpx !important;
}

.backup-row {
  display: flex;
  gap: 20rpx;
  margin-top: 16rpx;
}

.btn-backup {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 26rpx;
  border-radius: 36rpx;
  background: var(--dao-bg-card);
  color: var(--dao-purple-deep);
  border: 1rpx solid var(--dao-border-gold);
  padding: 0;
  margin: 0;
}

.btn-backup::after {
  border: none;
}

.btn-hover {
  opacity: 0.85;
}

/* ── 树洞入口 ── */
.treehole-entry-card {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  margin-top: 20rpx;
  background: linear-gradient(135deg, rgba(26, 16, 40, 0.04), rgba(212, 168, 87, 0.06));
  border: 1rpx solid rgba(212, 175, 55, 0.3);
  border-radius: 20rpx;
  box-shadow: 0 0 16rpx rgba(212, 175, 55, 0.1), 0 0 40rpx rgba(212, 175, 55, 0.04);
}
.treehole-entry-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}
.treehole-entry-body {
  flex: 1;
}
.treehole-entry-title {
  display: block;
  font-family: "DaoDisplay", "Songti SC", "Noto Serif SC", "STSong", serif;
  font-size: 28rpx;
  color: var(--dao-purple-deep, #3a2e5c);
  letter-spacing: 2rpx;
}
.treehole-entry-sub {
  display: block;
  font-size: 22rpx;
  color: var(--dao-ink-light, #999);
  margin-top: 4rpx;
}
.treehole-entry-arrow {
  font-size: 36rpx;
  color: var(--dao-ink-light, #999);
}

/* ── 档案表单折叠 ── */
.pf-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 4rpx 0;
}
.pf-header-left {
  flex: 1;
  min-width: 0;
}
.pf-summary {
  display: block;
  font-size: var(--dao-fs-caption);
  color: var(--dao-ink-caption);
  margin-top: 8rpx;
  letter-spacing: 1rpx;
}
.pf-toggle-arrow {
  font-size: 40rpx;
  color: var(--dao-gold-muted);
  transition: transform 0.3s ease;
  flex-shrink: 0;
  margin-left: 16rpx;
}
.pf-toggle-open {
  transform: rotate(90deg);
}

.pf-form-body {
  overflow: hidden;
  transition: max-height 0.4s cubic-bezier(0.23, 1, 0.32, 1), opacity 0.3s ease;
}
.pf-form-collapsed {
  max-height: 0;
  opacity: 0;
  pointer-events: none;
}
.pf-form-expanded {
  max-height: 8000rpx;
  opacity: 1;
  pointer-events: auto;
}

/* ── 修行品阶 ── */
.rank-card {
  background: linear-gradient(135deg, #1f1638 0%, #2a1f4a 100%);
  border: 1rpx solid rgba(212, 175, 55, 0.35);
  padding: 28rpx 28rpx 24rpx;
}

.rank-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.rank-title {
  font-family: "DaoDisplay", "Songti SC", "STSong", serif;
  font-size: 36rpx;
  font-weight: 700;
  color: #e8d4a8;
  letter-spacing: 4rpx;
}

.rank-score {
  font-size: 24rpx;
  color: rgba(232, 212, 168, 0.7);
}

.rank-bar-wrap {
  margin-top: 4rpx;
}

.rank-bar-bg {
  height: 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.12);
  overflow: hidden;
}

.rank-bar-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #c9a227, #e8d4a8);
  transition: width 0.4s ease;
}

.rank-bar-label {
  display: block;
  font-size: 22rpx;
  color: rgba(232, 212, 168, 0.6);
  margin-top: 10rpx;
  text-align: right;
}
