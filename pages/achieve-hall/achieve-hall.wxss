.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(165deg, #1f1638 0%, #2a1f4a 38%, #ede8df 38.2%, #f5f0e8 100%);
  position: relative;
  box-sizing: border-box;
}

.hero {
  flex-shrink: 0;
  padding: 28rpx 32rpx 28rpx;
}

.hero-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #e8d4a8;
  letter-spacing: 8rpx;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.35);
}

.hero-sub {
  display: block;
  font-size: 24rpx;
  color: rgba(232, 212, 168, 0.78);
  line-height: 1.5;
  margin-bottom: 28rpx;
}

.progress-wrap {
  margin-top: 8rpx;
}

.progress-bar {
  height: 12rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.22);
  overflow: hidden;
  margin-bottom: 12rpx;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #c9a227, #f0dfa0, #e8c547);
  transition: width 0.35s ease;
}

.progress-text {
  font-size: 24rpx;
  color: rgba(232, 212, 168, 0.9);
}

.scroll {
  flex: 1;
  min-height: 0;
  padding: 8rpx 20rpx 0;
  box-sizing: border-box;
}

.grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 20rpx 0;
}

.ach {
  width: 48%;
  min-height: 220rpx;
  border-radius: 8rpx 28rpx 8rpx 28rpx;
  padding: 3rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

.ach::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: inherit;
  opacity: 0.45;
  pointer-events: none;
}

.acc-gold {
  background: linear-gradient(145deg, rgba(201, 162, 39, 0.95), rgba(240, 223, 160, 0.55));
  box-shadow: 0 10rpx 32rpx rgba(166, 124, 31, 0.25);
}

.acc-rose {
  background: linear-gradient(145deg, rgba(183, 96, 120, 0.88), rgba(240, 200, 210, 0.5));
  box-shadow: 0 10rpx 28rpx rgba(120, 50, 70, 0.2);
}

.acc-violet {
  background: linear-gradient(145deg, rgba(90, 70, 140, 0.92), rgba(160, 140, 200, 0.45));
  box-shadow: 0 10rpx 28rpx rgba(45, 34, 82, 0.22);
}

.acc-blue {
  background: linear-gradient(145deg, rgba(50, 90, 150, 0.9), rgba(130, 180, 230, 0.45));
  box-shadow: 0 10rpx 28rpx rgba(30, 60, 100, 0.2);
}

.acc-slate {
  background: linear-gradient(145deg, rgba(70, 80, 95, 0.92), rgba(140, 150, 165, 0.4));
  box-shadow: 0 10rpx 28rpx rgba(30, 35, 45, 0.25);
}

.acc-amber {
  background: linear-gradient(145deg, rgba(180, 120, 50, 0.9), rgba(240, 200, 130, 0.5));
  box-shadow: 0 10rpx 28rpx rgba(120, 80, 30, 0.22);
}

.ach-inner {
  border-radius: 6rpx 26rpx 6rpx 26rpx;
  background: rgba(255, 252, 248, 0.94);
  padding: 22rpx 18rpx 18rpx;
  min-height: 214rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  position: relative;
  z-index: 1;
}

.ach-off .ach-inner {
  background: rgba(245, 242, 238, 0.72);
}

.ach-off {
  opacity: 0.62;
  filter: saturate(0.45);
}

.ach-on .ach-inner {
  animation: achBounceIn 0.4s ease both;
}

@keyframes achBounceIn {
  0% {
    transform: scale(0.8);
    opacity: 0;
  }
  60% {
    transform: scale(1.06);
    opacity: 1;
  }
  100% {
    transform: scale(1);
    opacity: 1;
  }
}

.ach-crown {
  font-size: 28rpx;
  color: #c9a227;
  margin-bottom: 8rpx;
  line-height: 1;
}

.ach-off .ach-crown {
  color: #9a9a9a;
}

.ach-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #2a1f15;
  letter-spacing: 2rpx;
  margin-bottom: 10rpx;
}

.ach-sub {
  font-size: 22rpx;
  color: #6b5d4f;
  line-height: 1.45;
  flex: 1;
}

.ach-hint {
  font-size: 20rpx;
  color: #a89888;
  margin-top: 12rpx;
}

.footer-space {
  height: calc(48rpx + env(safe-area-inset-bottom));
}

.press-layer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  top: 0;
  z-index: 9999;
  pointer-events: none;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 40rpx 32rpx;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: rgba(20, 15, 35, 0.25);
}

.press-panel {
  max-width: 100%;
  width: 100%;
  background: linear-gradient(180deg, #2d2248 0%, #1a1428 100%);
  border: 2rpx solid rgba(212, 175, 55, 0.55);
  border-radius: 24rpx;
  padding: 28rpx 32rpx 32rpx;
  box-shadow: 0 -8rpx 40rpx rgba(0, 0, 0, 0.35);
  animation: popIn 0.2s ease;
}

@keyframes popIn {
  from {
    opacity: 0;
    transform: translateY(24rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.press-title {
  display: block;
  font-size: 24rpx;
  color: #c9a227;
  letter-spacing: 4rpx;
  margin-bottom: 16rpx;
  font-weight: 600;
}

.press-body {
  display: block;
  font-size: 28rpx;
  color: #e8e0d5;
  line-height: 1.65;
  white-space: pre-wrap;
}
