<view class="page">
  <view class="hero">
    <text class="hero-title">心象成就</text>
    <text class="hero-sub">长按成就块查看趣味评语 · 松开即消失</text>
    <progress-bar
      percent="{{progressPct}}"
      caption="已解锁 {{unlockedCount}} / {{total}}"
      ariaLabel="成就进度"
    />
  </view>

  <scroll-view scroll-y class="scroll" enhanced="{{true}}">
    <view class="grid">
      <view
        wx:for="{{achievements}}"
        wx:key="id"
        class="ach acc-{{item.accent}} {{item.unlocked ? 'ach-on' : 'ach-off'}} ach-s{{item.stars}}"
        bindtouchstart="onAchPressStart"
        bindtouchmove="onAchPressMove"
        bindtouchend="onAchPressEnd"
        bindtouchcancel="onAchPressEnd"
        data-id="{{item.id}}"
      >
        <view class="ach-inner">
          <view class="ach-stars">
            <text wx:for="{{item.starsArr}}" wx:for-item="s" wx:key="*this" class="ach-star {{item.unlocked ? 'ach-star--lit' : ''}}">★</text>
          </view>
          <text class="ach-name">{{item.name}}</text>
          <text class="ach-sub">{{item.subtitle}}</text>
          <text class="ach-hint">长按看评语</text>
          <text class="ach-share-btn" wx:if="{{item.unlocked}}" catchtap="shareAchieve" data-id="{{item.id}}">分享</text>
        </view>
      </view>
    </view>
    <view class="solar-section" wx:if="{{solarBadges.length}}">
    <text class="solar-title">节气徽章册 · 已集 {{solarCount}}/24</text>
    <view class="solar-grid">
      <view wx:for="{{solarBadges}}" wx:key="name" class="solar-cell {{item.collected ? 'solar-on' : 'solar-off'}}">
        <text class="solar-name">{{item.name}}</text>
        <text class="solar-date" wx:if="{{item.collectDate}}">{{item.collectDate}}</text>
      </view>
    </view>
    </view>
    <view class="footer-space"></view>
  </scroll-view>

  <view class="press-layer" wx:if="{{pressVisible}}">
    <view class="press-panel">
      <text class="press-title">趣评碎碎念</text>
      <text class="press-body">{{pressComment}}</text>
    </view>
  </view>
  <canvas type="2d" id="poster-canvas" class="poster-canvas-offscreen" style="width:600px;height:800px;position:fixed;left:-9999px;top:0;"></canvas>
</view>
