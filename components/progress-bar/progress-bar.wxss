.pb-wrap {
  width: 100%;
}

.pb-bar {
  height: 12rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.12);
  overflow: hidden;
  margin-bottom: 12rpx;
}

.pb-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, var(--dao-gold-muted), var(--dao-gold-pale), #e8c547);
  transition: width 0.35s ease;
}

.pb-caption {
  font-size: 24rpx;
  color: var(--dao-ink-muted);
}
