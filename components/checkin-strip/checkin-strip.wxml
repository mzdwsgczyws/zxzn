<view class="cs-root {{expanded ? 'cs-root--open' : ''}}">
  <view class="cs-main">
    <view class="cs-left">
      <text class="cs-streak">已连续 {{streak}} 天</text>
      <text class="cs-sub">累计 {{totalDays}} 天 · {{checkedToday ? '今日已记' : '点右侧完成今日一记'}}</text>
    </view>
    <button
      class="cs-btn {{checkinFlash ? 'cs-btn--flash' : ''}}"
      size="mini"
      catchtap="onTapCheckin"
      disabled="{{checkedToday}}"
      hover-class="cs-btn-hover"
      aria-label="{{checkedToday ? '今日已打卡' : '今日打卡'}}"
      aria-role="button"
    >
      {{checkedToday ? '✓ 已打卡' : '今日打卡'}}
    </button>
  </view>
  <view class="cs-expand" wx:if="{{expanded}}">
    <text class="cs-expand-title">今日心境（选填）</text>
    <view class="cs-moods">
      <view
        wx:for="{{moodOptions}}"
        wx:key="*this"
        class="cs-mood {{selectedMood === item ? 'cs-mood--on' : ''}}"
        data-mood="{{item}}"
        catchtap="onPickMood"
        aria-role="button"
        aria-label="心境 {{item}}"
      >{{item}}</view>
    </view>
  </view>
</view>
