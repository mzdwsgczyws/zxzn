/* —— 摇动舞台：竹筒 —— */
.bs-stage {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  overflow: hidden;
}

.bs-stage.bs-stage--home {
  padding-top: 56rpx;
  padding-bottom: 64rpx;
}

.bamboo-ambient {
  position: absolute;
  left: 50%;
  top: 42%;
  width: 420rpx;
  height: 440rpx;
  margin-left: -210rpx;
  margin-top: -220rpx;
  border-radius: 50%;
  background: radial-gradient(
    circle,
    rgba(92, 78, 58, 0.16) 0%,
    rgba(245, 238, 225, 0.4) 45%,
    transparent 70%
  );
  pointer-events: none;
  z-index: 0;
}

.bamboo-wrap {
  position: relative;
  z-index: 1;
  width: 240rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  transform-origin: 50% 85%;
}

.bamboo-wrap--shaking {
  animation: bamboo-sway 0.58s cubic-bezier(0.45, 0, 0.55, 1) infinite;
}

.bamboo-wrap--drawing {
  animation: bamboo-draw-breathe 0.72s ease-in-out infinite;
}

@keyframes bamboo-sway {
  0%,
  100% {
    transform: rotate(-4deg) translateY(0);
  }
  50% {
    transform: rotate(4deg) translateY(-6rpx);
  }
}

@keyframes bamboo-draw-breathe {
  0%,
  100% {
    transform: scale(1) translateY(0);
    filter: brightness(1);
  }
  50% {
    transform: scale(1.03) translateY(-4rpx);
    filter: brightness(1.06);
  }
}

.bamboo-crown {
  width: 168rpx;
  height: 14rpx;
  border-radius: 8rpx 8rpx 4rpx 4rpx;
  background: linear-gradient(180deg, #4a3f32 0%, #2e261c 100%);
  border: 1rpx solid rgba(180, 150, 90, 0.4);
  box-shadow:
    0 2rpx 8rpx rgba(0, 0, 0, 0.25),
    inset 0 1rpx 0 rgba(120, 100, 70, 0.25);
  z-index: 4;
}

.bamboo-slips {
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  justify-content: center;
  gap: 5rpx;
  margin-top: -2rpx;
  margin-bottom: -10rpx;
  z-index: 3;
  height: 102rpx;
  max-width: 100%;
  padding: 0 4rpx;
  box-sizing: border-box;
}

/* 黑金签条：与揭晓封面同系（深底 + 金边 + 暗纹） */
.bamboo-slip {
  flex-shrink: 0;
  width: 13rpx;
  height: 88rpx;
  border-radius: 4rpx 4rpx 2rpx 2rpx;
  background: linear-gradient(
    90deg,
    #060606 0%,
    #141210 22%,
    #1f1c18 50%,
    #12100c 78%,
    #080807 100%
  );
  border: 1rpx solid rgba(201, 162, 39, 0.5);
  box-shadow:
    0 4rpx 14rpx rgba(0, 0, 0, 0.45),
    0 0 10rpx rgba(201, 162, 39, 0.12),
    inset 0 0 0 1rpx rgba(212, 175, 55, 0.12),
    inset 3rpx 0 8rpx rgba(255, 220, 160, 0.06);
}

.bamboo-slip--1 {
  transform: rotate(-9deg);
  height: 74rpx;
}

.bamboo-slip--2 {
  transform: rotate(-5deg);
  height: 82rpx;
}

.bamboo-slip--3 {
  transform: rotate(-2deg);
  height: 90rpx;
}

.bamboo-slip--4 {
  height: 98rpx;
}

.bamboo-slip--5 {
  transform: rotate(2deg);
  height: 90rpx;
}

.bamboo-slip--6 {
  transform: rotate(5deg);
  height: 82rpx;
}

.bamboo-slip--7 {
  transform: rotate(9deg);
  height: 74rpx;
}

.bamboo-wrap--shaking .bamboo-slip--1 {
  animation: bamboo-rattle-l1 0.48s ease-in-out infinite;
  animation-delay: 0s;
}

.bamboo-wrap--shaking .bamboo-slip--2 {
  animation: bamboo-rattle-l2 0.48s ease-in-out infinite;
  animation-delay: 0.06s;
}

.bamboo-wrap--shaking .bamboo-slip--3 {
  animation: bamboo-rattle-c3 0.48s ease-in-out infinite;
  animation-delay: 0s;
}

.bamboo-wrap--shaking .bamboo-slip--4 {
  animation: bamboo-rattle-c4 0.48s ease-in-out infinite;
  animation-delay: 0.09s;
}

.bamboo-wrap--shaking .bamboo-slip--5 {
  animation: bamboo-rattle-c5 0.48s ease-in-out infinite;
  animation-delay: 0.18s;
}

.bamboo-wrap--shaking .bamboo-slip--6 {
  animation: bamboo-rattle-r6 0.48s ease-in-out infinite;
  animation-delay: 0.04s;
}

.bamboo-wrap--shaking .bamboo-slip--7 {
  animation: bamboo-rattle-r7 0.48s ease-in-out infinite;
  animation-delay: 0.11s;
}

@keyframes bamboo-rattle-l1 {
  0%,
  100% {
    transform: rotate(-9deg) translateY(0);
  }
  35% {
    transform: rotate(-8deg) translateY(-11rpx);
  }
  70% {
    transform: rotate(-10deg) translateY(5rpx);
  }
}

@keyframes bamboo-rattle-l2 {
  0%,
  100% {
    transform: rotate(-5deg) translateY(0);
  }
  35% {
    transform: rotate(-4deg) translateY(-11rpx);
  }
  70% {
    transform: rotate(-6deg) translateY(5rpx);
  }
}

@keyframes bamboo-rattle-c3 {
  0%,
  100% {
    transform: rotate(-2deg) translateY(0);
  }
  35% {
    transform: rotate(-2deg) translateY(-12rpx);
  }
  70% {
    transform: rotate(-2deg) translateY(5rpx);
  }
}

@keyframes bamboo-rattle-c4 {
  0%,
  100% {
    transform: translateY(0);
  }
  35% {
    transform: translateY(-12rpx);
  }
  70% {
    transform: translateY(5rpx);
  }
}

@keyframes bamboo-rattle-c5 {
  0%,
  100% {
    transform: rotate(2deg) translateY(0);
  }
  35% {
    transform: rotate(2deg) translateY(-12rpx);
  }
  70% {
    transform: rotate(2deg) translateY(5rpx);
  }
}

@keyframes bamboo-rattle-r6 {
  0%,
  100% {
    transform: rotate(5deg) translateY(0);
  }
  35% {
    transform: rotate(4deg) translateY(-11rpx);
  }
  70% {
    transform: rotate(6deg) translateY(5rpx);
  }
}

@keyframes bamboo-rattle-r7 {
  0%,
  100% {
    transform: rotate(9deg) translateY(0);
  }
  35% {
    transform: rotate(8deg) translateY(-11rpx);
  }
  70% {
    transform: rotate(10deg) translateY(5rpx);
  }
}

/* 老竹筒：枯褐、灰黄、风化斑与细裂纹 */
.bamboo-tube {
  position: relative;
  width: 152rpx;
  height: 256rpx;
  border-radius: 14rpx 14rpx 20rpx 20rpx;
  background: linear-gradient(
    90deg,
    #2a241c 0%,
    #4a3f32 14%,
    #6b5d48 32%,
    #7a6a52 50%,
    #5c5040 68%,
    #3d352a 86%,
    #221c18 100%
  );
  border: 1rpx solid rgba(55, 48, 38, 0.9);
  box-shadow:
    inset 5rpx 0 14rpx rgba(140, 120, 95, 0.12),
    inset -8rpx 0 20rpx rgba(0, 0, 0, 0.35),
    0 18rpx 36rpx rgba(30, 26, 20, 0.38),
    0 0 0 1rpx rgba(160, 130, 70, 0.15);
  z-index: 2;
  overflow: hidden;
}

.bamboo-tube-patina {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  opacity: 0.55;
  pointer-events: none;
  background:
    radial-gradient(ellipse 55% 35% at 18% 28%, rgba(60, 52, 42, 0.45), transparent 58%),
    radial-gradient(ellipse 45% 30% at 82% 62%, rgba(45, 38, 30, 0.5), transparent 55%),
    radial-gradient(ellipse 30% 22% at 55% 18%, rgba(90, 78, 58, 0.25), transparent 60%);
}

.bamboo-tube-grain {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  opacity: 0.38;
  pointer-events: none;
  background-image:
    repeating-linear-gradient(
      90deg,
      transparent,
      transparent 4rpx,
      rgba(35, 30, 24, 0.14) 4rpx,
      rgba(35, 30, 24, 0.14) 5rpx
    ),
    repeating-linear-gradient(
      0deg,
      transparent,
      transparent 22rpx,
      rgba(40, 34, 28, 0.12) 22rpx,
      rgba(40, 34, 28, 0.12) 23rpx
    );
}

.bamboo-tube-crack {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  opacity: 0.35;
  pointer-events: none;
  background:
    linear-gradient(102deg, transparent 46%, rgba(20, 18, 14, 0.2) 48%, rgba(30, 26, 20, 0.08) 50%, transparent 52%),
    linear-gradient(78deg, transparent 58%, rgba(25, 22, 18, 0.15) 60%, transparent 63%);
}

.bamboo-node {
  position: absolute;
  left: -2rpx;
  right: -2rpx;
  height: 16rpx;
  border-radius: 8rpx;
  background: linear-gradient(
    180deg,
    rgba(25, 22, 18, 0.55) 0%,
    rgba(80, 70, 55, 0.12) 42%,
    rgba(15, 13, 10, 0.45) 100%
  );
  border-top: 1rpx solid rgba(0, 0, 0, 0.35);
  border-bottom: 1rpx solid rgba(120, 105, 80, 0.08);
  box-shadow: inset 0 0 10rpx rgba(0, 0, 0, 0.22);
  pointer-events: none;
}

.bamboo-node--a {
  top: 18%;
}

.bamboo-node--b {
  top: 49%;
  transform: translateY(-50%);
}

.bamboo-node--c {
  bottom: 16%;
}

.bamboo-tube-gloss {
  position: absolute;
  left: 8%;
  top: 10%;
  width: 26%;
  bottom: 14%;
  border-radius: 20rpx;
  background: linear-gradient(90deg, rgba(200, 180, 140, 0.14) 0%, transparent 100%);
  opacity: 0.45;
  pointer-events: none;
}

.bamboo-base-ring {
  width: 168rpx;
  height: 12rpx;
  margin-top: -4rpx;
  border-radius: 0 0 10rpx 10rpx;
  background: linear-gradient(180deg, #3d3428 0%, #221c16 100%);
  border: 1rpx solid rgba(150, 120, 70, 0.35);
  box-shadow: 0 8rpx 16rpx rgba(0, 0, 0, 0.28);
  z-index: 2;
}

.bamboo-ground {
  width: 200rpx;
  height: 10rpx;
  margin-top: 10rpx;
  border-radius: 50%;
  background: radial-gradient(ellipse at center, rgba(55, 48, 38, 0.38) 0%, transparent 72%);
  z-index: 1;
}

.shake-tip {
  position: relative;
  z-index: 2;
  margin-top: 36rpx;
  font-size: 28rpx;
  color: #4d5c42;
  letter-spacing: 1rpx;
  text-shadow: 0 1rpx 0 rgba(255, 255, 255, 0.6);
}

.sim-tip {
  position: relative;
  z-index: 2;
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #6b7a62;
  text-decoration: underline;
  text-decoration-color: rgba(201, 162, 39, 0.45);
  padding: 16rpx;
}

.bs-stage.bs-stage--page {
  padding: 44rpx 0 72rpx;
}

