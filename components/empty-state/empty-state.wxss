.es-root {
  padding: 80rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  box-sizing: border-box;
}

.es-icon {
  font-size: 88rpx;
  color: var(--dao-purple-soft);
  opacity: 0.45;
  margin-bottom: 24rpx;
  background: radial-gradient(circle, rgba(57, 73, 171, 0.06) 0%, transparent 70%);
  border-radius: 50%;
  width: 120rpx;
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.es-title {
  font-family: "DaoDisplay", "Songti SC", "STSong", "Noto Serif CJK SC", serif;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--dao-purple-deep);
  margin-bottom: 16rpx;
}

.es-body {
  font-size: 26rpx;
  color: var(--dao-ink-muted);
  line-height: 1.65;
  max-width: 560rpx;
  margin-bottom: 28rpx;
}
