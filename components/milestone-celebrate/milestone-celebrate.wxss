.mc-overlay {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  background: rgba(26, 21, 32, 0.65);
  display: flex;
  align-items: center;
  justify-content: center;
  animation: mcFadeIn 0.3s ease;
}

@keyframes mcFadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.mc-card {
  width: 560rpx;
  background: linear-gradient(165deg, var(--dao-ritual-purple-a) 0%, var(--dao-bg-card) 55%);
  border-radius: 24rpx;
  padding: 56rpx 40rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  border: 2rpx solid var(--dao-border-gold-strong);
  box-shadow: 0 16rpx 64rpx rgba(0, 0, 0, 0.3);
  animation: mcBounce 0.4s ease;
}

@keyframes mcBounce {
  0% { transform: scale(0.8); opacity: 0; }
  60% { transform: scale(1.05); opacity: 1; }
  100% { transform: scale(1); }
}

.mc-icon {
  font-size: 72rpx;
  color: var(--dao-gold);
  margin-bottom: 24rpx;
}

.mc-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--dao-gold-pale);
  letter-spacing: 4rpx;
  margin-bottom: 12rpx;
}

.mc-streak {
  font-family: var(--dao-font-display);
  font-size: 28rpx;
  color: var(--dao-purple-deep);
  font-weight: 600;
  margin-bottom: 20rpx;
}

.mc-body {
  font-size: 26rpx;
  color: var(--dao-ink-body);
  line-height: 1.65;
  margin-bottom: 32rpx;
}

.mc-actions {
  display: flex;
  gap: 20rpx;
}
