/**
 * 全局样式与「紫金墨」设计令牌（详见 docs/UI_DESIGN_SYSTEM.md）
 * 新页面优先使用 var(--dao-*)，避免重复 hex。
 */
page {
  /* —— 色彩 —— */
  --dao-bg-page: #f5f0e8;
  --dao-bg-card: #fffef8;
  --dao-ink: #2c2416;
  --dao-ink-muted: #6d5d4a;
  --dao-ink-faint: #8d7b68;
  --dao-ink-caption: #9a8b7a;
  --dao-ink-body: #4a4034;
  --dao-brown-warm: #5c4d3d;
  --dao-purple-deep: #1a237e;
  --dao-purple-mid: #3949ab;
  --dao-purple-soft: #5c6bc0;
  --dao-purple-tint: #7986cb;
  --dao-ritual-purple-a: #3d2b69;
  --dao-ritual-purple-b: #2a1f4a;
  --dao-gold: #d4af37;
  --dao-gold-pale: #e8d4a8;
  --dao-gold-muted: #9a7b2e;
  --dao-border-gold: rgba(212, 175, 55, 0.2);
  --dao-border-gold-strong: rgba(212, 175, 55, 0.45);
  --dao-shadow-purple: rgba(26, 35, 126, 0.08);
  --dao-divider: #ece5d8;

  background-color: var(--dao-bg-page);
  color: var(--dao-ink);
  font-size: 28rpx;
  line-height: 1.6;
  letter-spacing: 0.5rpx;
  box-sizing: border-box;
  -webkit-font-smoothing: antialiased;
}

.safe-bottom {
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.card {
  background: var(--dao-bg-card);
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  margin: 20rpx 24rpx;
  box-shadow:
    0 2rpx 8rpx rgba(26, 35, 126, 0.04),
    0 8rpx 32rpx var(--dao-shadow-purple);
  border: 1rpx solid var(--dao-border-gold);
  transition: box-shadow 0.3s ease;
}

.btn-primary {
  background: linear-gradient(135deg, var(--dao-purple-mid) 0%, var(--dao-purple-deep) 100%);
  color: #fff;
  border-radius: 48rpx;
  padding: 24rpx 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(26, 35, 126, 0.18);
  transition: opacity 0.2s ease, box-shadow 0.2s ease;
}

.btn-primary::after {
  border: none;
}

.btn-primary:active {
  opacity: 0.88;
  box-shadow: 0 2rpx 8rpx rgba(26, 35, 126, 0.12);
}

.btn-ghost {
  background: transparent;
  color: var(--dao-purple-mid);
  border: 2rpx solid var(--dao-purple-mid);
  border-radius: 48rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
  transition: background 0.2s ease, opacity 0.2s ease;
}

.btn-ghost::after {
  border: none;
}

.btn-ghost:active {
  background: rgba(57, 73, 171, 0.06);
  opacity: 0.88;
}

.title-lg {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--dao-purple-deep);
}

.subtitle {
  font-size: 26rpx;
  color: var(--dao-ink-muted);
  margin-top: 12rpx;
}

/* —— 全局入场动效 —— */
@keyframes daoFadeSlideIn {
  from {
    opacity: 0;
    transform: translateY(24rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes daoScaleBounce {
  0% { transform: scale(0.85); opacity: 0; }
  60% { transform: scale(1.05); opacity: 1; }
  100% { transform: scale(1); opacity: 1; }
}

@keyframes daoPop {
  0% { transform: scale(1); }
  40% { transform: scale(1.12); }
  100% { transform: scale(1); }
}

.dao-enter {
  animation: daoFadeSlideIn 0.35s ease both;
}

@media (prefers-color-scheme: dark) {
  page {
    --dao-bg-page: #121018;
    --dao-bg-card: #1e1a28;
    --dao-ink: #e0d8cc;
    --dao-ink-muted: #a09888;
    --dao-ink-faint: #7a6e62;
    --dao-ink-caption: #6d6258;
    --dao-ink-body: #c4b8a8;
    --dao-brown-warm: #b0a090;
    --dao-purple-deep: #9fa8da;
    --dao-purple-mid: #7986cb;
    --dao-purple-soft: #5c6bc0;
    --dao-purple-tint: #3949ab;
    --dao-ritual-purple-a: #2d2248;
    --dao-ritual-purple-b: #1a1530;
    --dao-gold: #d4af37;
    --dao-gold-pale: #c9a848;
    --dao-gold-muted: #a8923a;
    --dao-border-gold: rgba(212, 175, 55, 0.15);
    --dao-border-gold-strong: rgba(212, 175, 55, 0.35);
    --dao-shadow-purple: rgba(0, 0, 0, 0.25);
    --dao-divider: #2a2535;
  }
}
