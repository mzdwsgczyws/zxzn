/**
 * 全局样式与「紫金墨」设计令牌（详见 docs/UI_DESIGN_SYSTEM.md）
 * 新页面优先使用 var(--dao-*)，避免重复 hex。
 */
page {
  /* —— 色彩 —— */
  --dao-bg-page: #f5f0e8;
  --dao-bg-card: #fffef8;
  --dao-ink: #2c2416;
  --dao-ink-muted: #6d5d4a;
  --dao-ink-faint: #8d7b68;
  --dao-ink-caption: #9a8b7a;
  --dao-ink-body: #4a4034;
  --dao-brown-warm: #5c4d3d;
  --dao-purple-deep: #1a237e;
  --dao-purple-mid: #3949ab;
  --dao-purple-soft: #5c6bc0;
  --dao-purple-tint: #7986cb;
  --dao-ritual-purple-a: #3d2b69;
  --dao-ritual-purple-b: #2a1f4a;
  --dao-gold: #d4af37;
  --dao-gold-pale: #e8d4a8;
  --dao-gold-muted: #9a7b2e;
  --dao-border-gold: rgba(212, 175, 55, 0.2);
  --dao-border-gold-strong: rgba(212, 175, 55, 0.45);
  --dao-shadow-purple: rgba(26, 35, 126, 0.08);
  --dao-divider: #ece5d8;

  background-color: var(--dao-bg-page);
  color: var(--dao-ink);
  font-size: 28rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

.safe-bottom {
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.card {
  background: var(--dao-bg-card);
  border-radius: 20rpx;
  padding: 32rpx;
  margin: 24rpx;
  box-shadow: 0 8rpx 32rpx var(--dao-shadow-purple);
  border: 1rpx solid var(--dao-border-gold);
}

.btn-primary {
  background: linear-gradient(135deg, var(--dao-purple-mid) 0%, var(--dao-purple-deep) 100%);
  color: #fff;
  border-radius: 48rpx;
  padding: 24rpx 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
}

.btn-primary::after {
  border: none;
}

.btn-ghost {
  background: transparent;
  color: var(--dao-purple-mid);
  border: 2rpx solid var(--dao-purple-mid);
  border-radius: 48rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.btn-ghost::after {
  border: none;
}

.title-lg {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--dao-purple-deep);
}

.subtitle {
  font-size: 26rpx;
  color: var(--dao-ink-muted);
  margin-top: 12rpx;
}

/* 心象箴言配图：cover-view 叠在原生 canvas 上，隶书由 wx.loadFontFace 的 DaoLotLiShu 生效 */
.lot-art-wrap {
  position: relative;
}

.lot-art-cover-root {
  position: absolute;
  left: 0;
  top: 0;
  z-index: 2;
  pointer-events: none;
  overflow: hidden;
}

.lot-art-title-cv,
.lot-art-sub-cv {
  position: absolute;
  left: 0;
  right: 0;
  width: 100%;
  text-align: center;
  font-family: 'DaoLotLiShu', 'KaiTi', 'STKaiti', serif;
  font-weight: normal;
  box-sizing: border-box;
  padding: 0 8px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.lot-art-title-cv {
  top: 46%;
  transform: translateY(-50%);
}

.lot-art-sub-cv {
  top: 80%;
  transform: translateY(-50%);
}
