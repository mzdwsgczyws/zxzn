/**
 * 全局样式与「紫金墨」设计令牌
 * 千年赛博道观：静如宣纸，动如流水；金线勾勒，紫墨铺底。
 */
page {
  /* —— 字体 —— */
  --dao-font-display: "DaoDisplay", "Songti SC", "STSong", "Noto Serif CJK SC", serif;
  --dao-font-body: -apple-system, "Helvetica Neue", "PingFang SC", "Noto Sans CJK SC", sans-serif;

  /* —— 字号阶梯 —— */
  --dao-fs-hero: 44rpx;
  --dao-fs-title: 34rpx;
  --dao-fs-sub: 28rpx;
  --dao-fs-body: 26rpx;
  --dao-fs-caption: 22rpx;
  --dao-fs-fine: 20rpx;

  /* —— 色彩 —— */
  --dao-bg-page: #f5f0e8;
  --dao-bg-card: #fffef8;
  --dao-ink: #2c2416;
  --dao-ink-muted: #6d5d4a;
  --dao-ink-faint: #8d7b68;
  --dao-ink-caption: #9a8b7a;
  --dao-ink-body: #4a4034;
  --dao-ink-light: #b8a990;
  --dao-brown-warm: #5c4d3d;
  --dao-purple-deep: #1a237e;
  --dao-purple-mid: #3949ab;
  --dao-purple-soft: #5c6bc0;
  --dao-purple-tint: #7986cb;
  --dao-ritual-purple-a: #3d2b69;
  --dao-ritual-purple-b: #2a1f4a;
  --dao-gold: #d4af37;
  --dao-gold-bright: #e8c84a;
  --dao-gold-pale: #e8d4a8;
  --dao-gold-muted: #9a7b2e;
  --dao-jade: #5d8a68;
  --dao-jade-pale: #a8c5ad;
  --dao-cinnabar: #c04040;
  --dao-border-gold: rgba(212, 175, 55, 0.2);
  --dao-border-gold-strong: rgba(212, 175, 55, 0.45);
  --dao-shadow-purple: rgba(26, 35, 126, 0.08);
  --dao-divider: #ece5d8;
  --dao-glow-gold: 0 0 20rpx rgba(212, 175, 55, 0.2), 0 0 48rpx rgba(212, 175, 55, 0.08);
  --dao-glow-purple: 0 0 20rpx rgba(57, 73, 171, 0.15), 0 0 48rpx rgba(26, 35, 126, 0.06);

  background-color: var(--dao-bg-page);
  color: var(--dao-ink);
  font-family: var(--dao-font-body);
  font-size: var(--dao-fs-body);
  line-height: 1.6;
  letter-spacing: 0.5rpx;
  box-sizing: border-box;
  -webkit-font-smoothing: antialiased;
}

/* —— 宣纸质感底纹（浅色页面使用） —— */
.dao-paper-bg {
  background-color: var(--dao-bg-page);
  background-image:
    radial-gradient(ellipse at 15% 25%, rgba(180, 160, 120, 0.07) 0%, transparent 50%),
    radial-gradient(ellipse at 85% 75%, rgba(160, 140, 100, 0.06) 0%, transparent 50%),
    radial-gradient(ellipse at 50% 50%, rgba(200, 180, 140, 0.04) 0%, transparent 60%),
    repeating-linear-gradient(0deg, transparent, transparent 120rpx, rgba(180, 160, 130, 0.02) 120rpx, rgba(180, 160, 130, 0.02) 121rpx);
}

/* —— 深色殿堂底纹（深色页面使用） —— */
.dao-dark-bg {
  background: linear-gradient(180deg, #1a1028 0%, #2d1f3d 40%, #1e1530 100%);
  background-image:
    radial-gradient(ellipse at 20% 30%, rgba(61, 43, 105, 0.3) 0%, transparent 50%),
    radial-gradient(ellipse at 80% 70%, rgba(42, 31, 74, 0.25) 0%, transparent 50%),
    radial-gradient(circle at 50% 0%, rgba(212, 175, 55, 0.03) 0%, transparent 40%),
    linear-gradient(180deg, #1a1028 0%, #2d1f3d 40%, #1e1530 100%);
}

.safe-bottom {
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.card {
  background: var(--dao-bg-card);
  border-radius: 20rpx;
  padding: 32rpx;
  margin: 20rpx 24rpx;
  box-shadow:
    0 2rpx 8rpx rgba(26, 35, 126, 0.04),
    0 8rpx 32rpx var(--dao-shadow-purple),
    inset 0 0 60rpx rgba(180, 160, 120, 0.04);
  border: 1rpx solid var(--dao-border-gold);
  transition: box-shadow 0.3s ease;
  position: relative;
}

.card::before,
.card::after {
  content: '';
  position: absolute;
  width: 52rpx;
  height: 52rpx;
  border-color: var(--dao-gold);
  border-style: solid;
  opacity: 0.35;
  pointer-events: none;
  z-index: 1;
}

.card::before {
  top: 8rpx;
  left: 8rpx;
  border-width: 2rpx 0 0 2rpx;
  border-radius: 6rpx 0 0 0;
}

.card::after {
  bottom: 8rpx;
  right: 8rpx;
  border-width: 0 2rpx 2rpx 0;
  border-radius: 0 0 6rpx 0;
}

/* —— 玻璃拟态卡片（深色背景浮层） —— */
.card--glass {
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(212, 175, 55, 0.15);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.2), inset 0 1rpx 0 rgba(255, 255, 255, 0.06);
  backdrop-filter: blur(10rpx);
}

.card--glass::before,
.card--glass::after {
  border-color: rgba(212, 175, 55, 0.25);
}

/* —— 信纸卡片（古旧信笺） —— */
.card--letter {
  background: #faf5e8;
  border: 1rpx solid rgba(180, 160, 130, 0.3);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06), 0 12rpx 40rpx rgba(120, 100, 70, 0.08), 2rpx 3rpx 0 rgba(200, 185, 155, 0.3);
}

.btn-primary {
  background: linear-gradient(165deg, #f0dfa0 0%, #d4af37 40%, #b8892a 100%);
  color: #2a1f15;
  border-radius: 12rpx;
  padding: 24rpx 48rpx;
  font-family: var(--dao-font-display);
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 3rpx;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(166, 124, 31, 0.25), 0 1rpx 0 rgba(255, 248, 220, 0.4) inset;
  transition: transform 0.15s ease, box-shadow 0.2s ease;
}

.btn-primary::after {
  border: none;
}

.btn-primary:active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 8rpx rgba(166, 124, 31, 0.2);
}

.btn-ghost {
  background: transparent;
  color: var(--dao-gold-muted);
  border: 1rpx solid var(--dao-border-gold-strong);
  border-radius: 12rpx;
  padding: 20rpx 40rpx;
  font-family: var(--dao-font-display);
  font-size: 28rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
  transition: background 0.2s ease, transform 0.15s ease;
}

.btn-ghost::after {
  border: none;
}

.btn-ghost:active {
  background: rgba(212, 175, 55, 0.06);
  transform: translateY(2rpx);
}

.btn-danger {
  background: linear-gradient(165deg, #d05555 0%, #c04040 100%);
  color: #fff;
  border-radius: 12rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
  border: none;
  transition: transform 0.15s ease;
}

.btn-danger::after { border: none; }
.btn-danger:active { transform: translateY(2rpx); }

.title-lg {
  font-family: "DaoDisplay", "Songti SC", "STSong", "Noto Serif CJK SC", serif;
  font-size: var(--dao-fs-title);
  font-weight: 600;
  color: var(--dao-purple-deep);
  letter-spacing: 4rpx;
}

.subtitle {
  font-size: var(--dao-fs-caption);
  color: var(--dao-ink-muted);
  margin-top: 12rpx;
  line-height: 1.6;
}

/* —— 分隔线 —— */
.dao-divider {
  display: flex;
  align-items: center;
  margin: 32rpx 0;
}

.dao-divider::before,
.dao-divider::after {
  content: '';
  flex: 1;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, var(--dao-border-gold-strong), transparent);
}

.dao-divider::before {
  margin-right: 20rpx;
}

.dao-divider::after {
  margin-left: 20rpx;
}

/* —— 区域标题 —— */
.dao-section-title {
  display: flex;
  align-items: center;
  font-family: var(--dao-font-display);
  font-size: var(--dao-fs-sub);
  font-weight: 600;
  color: var(--dao-ink);
  letter-spacing: 3rpx;
  margin: 32rpx 0 20rpx;
  padding-left: 20rpx;
  position: relative;
}

.dao-section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 4rpx;
  bottom: 4rpx;
  width: 4rpx;
  background: var(--dao-cinnabar);
  border-radius: 2rpx;
}

/* —— 印章装饰 —— */
.dao-seal {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  border: 2rpx solid var(--dao-cinnabar);
  border-radius: 6rpx;
  font-family: var(--dao-font-display);
  font-size: 24rpx;
  color: var(--dao-cinnabar);
  transform: rotate(-4deg);
  opacity: 0.7;
}

/* —— 全局入场动效 —— */
@keyframes daoFadeSlideIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes daoScaleBounce {
  0% { transform: scale(0.85); opacity: 0; }
  60% { transform: scale(1.05); opacity: 1; }
  100% { transform: scale(1); opacity: 1; }
}

@keyframes daoPop {
  0% { transform: scale(1); }
  40% { transform: scale(1.12); }
  100% { transform: scale(1); }
}

@keyframes daoHeroIn {
  from { opacity: 0; transform: translateY(16rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes daoGlowPulse {
  0%, 100% { box-shadow: 0 0 16rpx rgba(212, 175, 55, 0.15), 0 0 40rpx rgba(212, 175, 55, 0.06); }
  50% { box-shadow: 0 0 24rpx rgba(212, 175, 55, 0.3), 0 0 60rpx rgba(212, 175, 55, 0.12); }
}

@keyframes daoGoldPulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.75; }
}

@keyframes daoBreath {
  0%, 100% { opacity: 0.6; }
  50% { opacity: 1; }
}

.dao-enter,
.page {
  animation: daoFadeSlideIn 0.4s cubic-bezier(0.23, 1, 0.32, 1) both;
}

/* —— 卡片错落入场 —— */
.card:nth-child(1) { animation: daoFadeSlideIn 0.45s cubic-bezier(0.23, 1, 0.32, 1) both 0.05s; }
.card:nth-child(2) { animation: daoFadeSlideIn 0.45s cubic-bezier(0.23, 1, 0.32, 1) both 0.13s; }
.card:nth-child(3) { animation: daoFadeSlideIn 0.45s cubic-bezier(0.23, 1, 0.32, 1) both 0.21s; }
.card:nth-child(4) { animation: daoFadeSlideIn 0.45s cubic-bezier(0.23, 1, 0.32, 1) both 0.29s; }
.card:nth-child(5) { animation: daoFadeSlideIn 0.45s cubic-bezier(0.23, 1, 0.32, 1) both 0.37s; }

@media (prefers-color-scheme: dark) {
  page {
    --dao-bg-page: #121018;
    --dao-bg-card: #1e1a28;
    --dao-ink: #e0d8cc;
    --dao-ink-muted: #a09888;
    --dao-ink-faint: #7a6e62;
    --dao-ink-caption: #6d6258;
    --dao-ink-body: #c4b8a8;
    --dao-ink-light: #6a5e52;
    --dao-brown-warm: #b0a090;
    --dao-purple-deep: #9fa8da;
    --dao-purple-mid: #7986cb;
    --dao-purple-soft: #5c6bc0;
    --dao-purple-tint: #3949ab;
    --dao-ritual-purple-a: #2d2248;
    --dao-ritual-purple-b: #1a1530;
    --dao-gold: #d4af37;
    --dao-gold-bright: #e8c84a;
    --dao-gold-pale: #c9a848;
    --dao-gold-muted: #a8923a;
    --dao-jade: #6a9a75;
    --dao-jade-pale: #4a7a58;
    --dao-cinnabar: #d05555;
    --dao-border-gold: rgba(212, 175, 55, 0.15);
    --dao-border-gold-strong: rgba(212, 175, 55, 0.35);
    --dao-shadow-purple: rgba(0, 0, 0, 0.25);
    --dao-divider: #2a2535;
    --dao-glow-gold: 0 0 20rpx rgba(212, 175, 55, 0.15), 0 0 48rpx rgba(212, 175, 55, 0.06);
    --dao-glow-purple: 0 0 20rpx rgba(121, 134, 203, 0.12), 0 0 48rpx rgba(92, 107, 192, 0.05);
  }

  .card::before,
  .card::after {
    opacity: 0.22;
  }

  .card--glass {
    background: rgba(255, 255, 255, 0.04);
    border-color: rgba(212, 175, 55, 0.1);
  }
}
