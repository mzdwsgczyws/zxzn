/**
 * 全局样式与「紫金墨」设计令牌
 * 千年赛博道观：静如宣纸，动如流水；金线勾勒，紫墨铺底。
 */
page {
  /* —— 字体 —— */
  --dao-font-display: "Songti SC", "STSong", "Noto Serif CJK SC", "Source Han Serif SC", serif;
  --dao-font-body: -apple-system, "Helvetica Neue", "PingFang SC", "Noto Sans CJK SC", sans-serif;

  /* —— 字号阶梯 —— */
  --dao-fs-hero: 44rpx;
  --dao-fs-title: 34rpx;
  --dao-fs-sub: 28rpx;
  --dao-fs-body: 26rpx;
  --dao-fs-caption: 22rpx;
  --dao-fs-fine: 20rpx;

  /* —— 色彩 —— */
  --dao-bg-page: #f5f0e8;
  --dao-bg-card: #fffef8;
  --dao-ink: #2c2416;
  --dao-ink-muted: #6d5d4a;
  --dao-ink-faint: #8d7b68;
  --dao-ink-caption: #9a8b7a;
  --dao-ink-body: #4a4034;
  --dao-ink-light: #b8a990;
  --dao-brown-warm: #5c4d3d;
  --dao-purple-deep: #1a237e;
  --dao-purple-mid: #3949ab;
  --dao-purple-soft: #5c6bc0;
  --dao-purple-tint: #7986cb;
  --dao-ritual-purple-a: #3d2b69;
  --dao-ritual-purple-b: #2a1f4a;
  --dao-gold: #d4af37;
  --dao-gold-pale: #e8d4a8;
  --dao-gold-muted: #9a7b2e;
  --dao-jade: #5d8a68;
  --dao-jade-pale: #a8c5ad;
  --dao-cinnabar: #c04040;
  --dao-border-gold: rgba(212, 175, 55, 0.2);
  --dao-border-gold-strong: rgba(212, 175, 55, 0.45);
  --dao-shadow-purple: rgba(26, 35, 126, 0.08);
  --dao-divider: #ece5d8;

  background-color: var(--dao-bg-page);
  color: var(--dao-ink);
  font-family: var(--dao-font-body);
  font-size: var(--dao-fs-body);
  line-height: 1.6;
  letter-spacing: 0.5rpx;
  box-sizing: border-box;
  -webkit-font-smoothing: antialiased;
}

/* —— 宣纸质感底纹 —— */
page::after {
  content: '';
  position: fixed;
  left: 0; top: 0; right: 0; bottom: 0;
  z-index: -1;
  pointer-events: none;
  background:
    radial-gradient(ellipse at 15% 30%, rgba(180, 160, 120, 0.035) 0%, transparent 55%),
    radial-gradient(ellipse at 85% 70%, rgba(140, 120, 90, 0.025) 0%, transparent 55%),
    radial-gradient(ellipse at 50% 10%, rgba(200, 180, 140, 0.02) 0%, transparent 40%);
}

.safe-bottom {
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.card {
  background: var(--dao-bg-card);
  border-radius: 20rpx;
  padding: 32rpx;
  margin: 20rpx 24rpx;
  box-shadow:
    0 2rpx 8rpx rgba(26, 35, 126, 0.04),
    0 8rpx 32rpx var(--dao-shadow-purple),
    inset 0 0 60rpx rgba(180, 160, 120, 0.04);
  border: 1rpx solid var(--dao-border-gold);
  transition: box-shadow 0.3s ease;
  position: relative;
}

.card::before,
.card::after {
  content: '';
  position: absolute;
  width: 36rpx;
  height: 36rpx;
  border-color: var(--dao-gold-pale);
  border-style: solid;
  opacity: 0.12;
  pointer-events: none;
}

.card::before {
  top: 8rpx;
  left: 8rpx;
  border-width: 2rpx 0 0 2rpx;
  border-radius: 6rpx 0 0 0;
}

.card::after {
  bottom: 8rpx;
  right: 8rpx;
  border-width: 0 2rpx 2rpx 0;
  border-radius: 0 0 6rpx 0;
}

.btn-primary {
  background: linear-gradient(135deg, var(--dao-purple-mid) 0%, var(--dao-purple-deep) 100%);
  color: #fff;
  border-radius: 48rpx;
  padding: 24rpx 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(26, 35, 126, 0.18);
  transition: opacity 0.2s ease, box-shadow 0.2s ease;
}

.btn-primary::after {
  border: none;
}

.btn-primary:active {
  opacity: 0.88;
  box-shadow: 0 2rpx 8rpx rgba(26, 35, 126, 0.12);
}

.btn-ghost {
  background: transparent;
  color: var(--dao-purple-mid);
  border: 2rpx solid var(--dao-purple-mid);
  border-radius: 48rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
  transition: background 0.2s ease, opacity 0.2s ease;
}

.btn-ghost::after {
  border: none;
}

.btn-ghost:active {
  background: rgba(57, 73, 171, 0.06);
  opacity: 0.88;
}

.title-lg {
  font-family: var(--dao-font-display);
  font-size: var(--dao-fs-title);
  font-weight: 600;
  color: var(--dao-purple-deep);
  letter-spacing: 4rpx;
}

.subtitle {
  font-size: var(--dao-fs-caption);
  color: var(--dao-ink-muted);
  margin-top: 12rpx;
  line-height: 1.6;
}

/* —— 分隔线渐变消散 —— */
.dao-divider {
  height: 1rpx;
  background: linear-gradient(90deg, transparent, var(--dao-divider) 20%, var(--dao-divider) 80%, transparent);
  border: none;
  margin: 24rpx 0;
}

/* —— 全局入场动效 —— */
@keyframes daoFadeSlideIn {
  from {
    opacity: 0;
    transform: translateY(24rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes daoScaleBounce {
  0% { transform: scale(0.85); opacity: 0; }
  60% { transform: scale(1.05); opacity: 1; }
  100% { transform: scale(1); opacity: 1; }
}

@keyframes daoPop {
  0% { transform: scale(1); }
  40% { transform: scale(1.12); }
  100% { transform: scale(1); }
}

.dao-enter {
  animation: daoFadeSlideIn 0.35s ease both;
}

/* —— 页面统一入场 —— */
.page {
  animation: daoFadeSlideIn 0.35s ease both;
}

/* —— 卡片错落入场 —— */
.card:nth-child(1) { animation: daoFadeSlideIn 0.4s ease both 0.05s; }
.card:nth-child(2) { animation: daoFadeSlideIn 0.4s ease both 0.12s; }
.card:nth-child(3) { animation: daoFadeSlideIn 0.4s ease both 0.19s; }
.card:nth-child(4) { animation: daoFadeSlideIn 0.4s ease both 0.26s; }
.card:nth-child(5) { animation: daoFadeSlideIn 0.4s ease both 0.33s; }

/* —— Hero 标题淡入上移 —— */
@keyframes daoHeroIn {
  from { opacity: 0; transform: translateY(16rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* —— 深色模式金色微呼吸 —— */
@keyframes daoGoldPulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.75; }
}

@media (prefers-color-scheme: dark) {
  page {
    --dao-bg-page: #121018;
    --dao-bg-card: #1e1a28;
    --dao-ink: #e0d8cc;
    --dao-ink-muted: #a09888;
    --dao-ink-faint: #7a6e62;
    --dao-ink-caption: #6d6258;
    --dao-ink-body: #c4b8a8;
    --dao-ink-light: #6a5e52;
    --dao-brown-warm: #b0a090;
    --dao-purple-deep: #9fa8da;
    --dao-purple-mid: #7986cb;
    --dao-purple-soft: #5c6bc0;
    --dao-purple-tint: #3949ab;
    --dao-ritual-purple-a: #2d2248;
    --dao-ritual-purple-b: #1a1530;
    --dao-gold: #d4af37;
    --dao-gold-pale: #c9a848;
    --dao-gold-muted: #a8923a;
    --dao-jade: #6a9a75;
    --dao-jade-pale: #4a7a58;
    --dao-cinnabar: #d05555;
    --dao-border-gold: rgba(212, 175, 55, 0.15);
    --dao-border-gold-strong: rgba(212, 175, 55, 0.35);
    --dao-shadow-purple: rgba(0, 0, 0, 0.25);
    --dao-divider: #2a2535;
  }

  page::after {
    background:
      radial-gradient(ellipse at 15% 30%, rgba(60, 40, 80, 0.04) 0%, transparent 55%),
      radial-gradient(ellipse at 85% 70%, rgba(40, 30, 60, 0.03) 0%, transparent 55%);
  }

  .card::before,
  .card::after {
    opacity: 0.08;
  }
}
