page {
  background-color: #f5f0e8;
  color: #2c2416;
  font-size: 28rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

.safe-bottom {
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.card {
  background: #fffef8;
  border-radius: 20rpx;
  padding: 32rpx;
  margin: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(26, 35, 126, 0.08);
  border: 1rpx solid rgba(212, 175, 55, 0.2);
}

.btn-primary {
  background: linear-gradient(135deg, #3949ab 0%, #1a237e 100%);
  color: #fff;
  border-radius: 48rpx;
  padding: 24rpx 48rpx;
  font-size: 30rpx;
  border: none;
}

.btn-primary::after {
  border: none;
}

.btn-ghost {
  background: transparent;
  color: #3949ab;
  border: 2rpx solid #3949ab;
  border-radius: 48rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
}

.btn-ghost::after {
  border: none;
}

.title-lg {
  font-size: 40rpx;
  font-weight: 600;
  color: #1a237e;
}

.subtitle {
  font-size: 26rpx;
  color: #6d5d4a;
  margin-top: 12rpx;
}
